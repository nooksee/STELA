#!/usr/bin/env bash
set -euo pipefail

hook_fail() {
  echo "ERROR: run llms refresh failed: $*" >&2
  exit 1
}

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || hook_fail "unable to resolve repository root"
cd "${repo_root}"

[[ -x "ops/bin/llms" ]] || hook_fail "missing executable ops/bin/llms"

./ops/bin/llms || hook_fail "ops/bin/llms returned non-zero"
git add llms.txt llms-core.txt llms-full.txt || hook_fail "git add for llms bundles failed"
