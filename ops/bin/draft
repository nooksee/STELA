#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
TEMPLATE_BIN="${REPO_ROOT}/ops/bin/template"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/../lib/scripts/common.sh"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/../lib/scripts/editor.sh"

usage() {
  cat <<'USAGE'
Usage:
  ops/bin/draft --id=DP-OPS-XXXX --title="..." --work-branch=work/... --base-head=<hash> [options]
  ops/bin/draft --addendum=A --base-dp=DP-OPS-XXXX

Required:
- --id=DP-OPS-XXXX
- --title="..."
- --work-branch=work/...
- --base-head=<hash>

Addendum generation mode (all required):
- --addendum=A                        single uppercase letter A-Z
- --base-dp=DP-OPS-XXXX               existing base packet in active intake or TASK leaf lineage
- --slots-file=PATH                   addendum sidecar with required slot blocks

Addendum slots-file required tokens:
- [OPERATOR_AUTHORIZATION]
- [SCOPE_DELTA]
- [ADDENDUM_OBJECTIVE]
- [ADDENDUM_RECEIPT]

Optional:
- --base-branch=main                  (default: main)
- --freshness-stamp=YYYY-MM-DD        (default: UTC today)
- --slots-file=PATH                   sidecar with tagged sections (optional in base DP mode)
- --emit-plan-scaffold=PATH           write plan scaffold template
- --emit-dp-slots-scaffold=PATH       write DP slot scaffold template
- --edit-scaffold                     open emitted scaffold in editor
- --load-scaffold-file=PATH           copy scaffold content from file
- --scaffold-editor=COMMAND           explicit editor command for --edit-scaffold
- --validate-plan-scaffold=PATH       validate plan scaffold content
- --validate-dp-slots-scaffold=PATH   validate DP slots scaffold content
- --dp-load-order="..."
- --objective="..."
- --in-scope="..."
- --out-of-scope="..."
- --safety="..."
- --plan-state="..."
- --plan-request="..."
- --plan-changelog="..."
- --plan-patch="..."
- --receipt-extra="..."

slots-file format:
[DP_SCOPED_LOAD_ORDER]
- tools/lint/dp.sh

[OBJECTIVE]
- One or more lines

[IN_SCOPE]
- One or more lines

[OUT_OF_SCOPE]
- One or more lines

[SAFETY_INVARIANTS]
- One or more lines

[PLAN_STATE]
- One or more lines

[PLAN_REQUEST]
- One or more lines

[PLAN_CHANGELOG]
- One or more lines

[PLAN_PATCH]
- One or more lines

[RECEIPT_EXTRA]
- One or more lines
USAGE
}

sha256_file() {
  local path="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$path" | awk '{print $1}'
    return
  fi
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$path" | awk '{print $1}'
    return
  fi
  die "sha256 tool not found (need sha256sum or shasum)"
}

read_slot() {
  local key="$1"
  local file="$2"
  awk -v key="$key" '
    $0 == "[" key "]" { in_block=1; next }
    in_block && $0 ~ /^\[[A-Z0-9_]+\]$/ { exit }
    in_block { print }
  ' "$file"
}

block_has_content() {
  local value="$1"
  [[ -n "$(printf '%s\n' "$value" | sed '/^[[:space:]]*$/d')" ]]
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

strip_surface_frontmatter() {
  local source_path="$1"
  awk '
    BEGIN { in_frontmatter=0 }
    NR == 1 && $0 == "---" {
      in_frontmatter=1
      next
    }
    in_frontmatter {
      if ($0 == "---") {
        in_frontmatter=0
      }
      next
    }
    { print }
  ' "$source_path"
}

TASK_SURFACE_SOURCE_PATH=""
TASK_SURFACE_RESOLVED_PATH=""
TASK_SURFACE_CONTENT_PATH=""
TASK_SURFACE_CLEANUP_PATH=""

cleanup_task_surface_context() {
  if [[ -n "$TASK_SURFACE_CLEANUP_PATH" ]]; then
    rm -f "$TASK_SURFACE_CLEANUP_PATH"
  fi
  TASK_SURFACE_CLEANUP_PATH=""
  return 0
}

resolve_task_surface_source() {
  local task_path="$1"
  TASK_SURFACE_SOURCE_PATH="$task_path"
  TASK_SURFACE_RESOLVED_PATH="$task_path"
  TASK_SURFACE_CONTENT_PATH="$task_path"
  TASK_SURFACE_CLEANUP_PATH=""

  [[ -f "$task_path" ]] || die_guard_failure \
    "missing TASK.md" \
    "task_source_exists" \
    "task_source_path" "$task_path" \
    "task_resolved_path" "$task_path"

  local line_count
  line_count="$(awk 'END { print NR }' "$task_path")"
  if [[ "$line_count" != "1" ]]; then
    return 0
  fi

  local pointer_path
  pointer_path="$(trim "$(cat "$task_path")")"
  pointer_path="${pointer_path#./}"
  if [[ "$pointer_path" == "${REPO_ROOT}/"* ]]; then
    pointer_path="${pointer_path#${REPO_ROOT}/}"
  fi

  if [[ ! "$pointer_path" =~ ^archives/surfaces/[A-Za-z0-9._/-]+\.md$ ]]; then
    die_guard_failure \
      "TASK.md is single-line but not a valid archives/surfaces pointer: ${pointer_path}" \
      "task_head_pointer_matches_archives_surfaces_pattern" \
      "task_source_path" "$task_path" \
      "task_resolved_path" "$pointer_path"
  fi

  local target_path="${REPO_ROOT}/${pointer_path}"
  TASK_SURFACE_RESOLVED_PATH="$target_path"
  [[ -f "$target_path" ]] || die_guard_failure \
    "TASK pointer target missing: ${pointer_path}" \
    "task_head_pointer_target_exists" \
    "task_source_path" "$task_path" \
    "task_resolved_path" "$target_path"

  local materialized_path
  materialized_path="$(mktemp)"
  strip_surface_frontmatter "$target_path" > "$materialized_path"
  if [[ ! -s "$materialized_path" ]]; then
    rm -f "$materialized_path"
    die_guard_failure \
      "TASK pointer target has no materialized body: ${pointer_path}" \
      "task_resolved_surface_materializes_to_nonempty_body" \
      "task_source_path" "$task_path" \
      "task_resolved_path" "$target_path"
  fi

  TASK_SURFACE_CONTENT_PATH="$materialized_path"
  TASK_SURFACE_CLEANUP_PATH="$materialized_path"
  return 0
}

require_clean_tree() {
  if [[ "${DRAFT_ALLOW_DIRTY_TREE:-0}" == "1" ]]; then
    return 0
  fi
  local porcelain
  porcelain="$(git -C "$REPO_ROOT" status --porcelain)"
  if [[ -n "$porcelain" ]]; then
    die "refusing to run on dirty tree"
  fi
  return 0
}

read_lint_constants() {
  local lint_path="$REPO_ROOT/tools/lint/dp.sh"
  local template_hash

  [[ -f "$lint_path" ]] || die "missing tools/lint/dp.sh"

  DP_TEMPLATE_PATH="$(awk -F'"' '/^CANONICAL_DP_TEMPLATE_PATH="/{print $2; exit}' "$lint_path")"
  template_hash="$(awk -F'"' '/^CANONICAL_DP_TEMPLATE_SHA256="/{print $2; exit}' "$lint_path")"

  [[ -n "$DP_TEMPLATE_PATH" ]] || die "failed to read CANONICAL_DP_TEMPLATE_PATH from tools/lint/dp.sh"
  [[ -n "$template_hash" ]] || die "failed to read CANONICAL_DP_TEMPLATE_SHA256 from tools/lint/dp.sh"
  [[ "$template_hash" =~ ^[0-9a-f]{64}$ ]] || die "invalid CANONICAL_DP_TEMPLATE_SHA256 in tools/lint/dp.sh"

  DP_TEMPLATE_PATH="$REPO_ROOT/$DP_TEMPLATE_PATH"
  [[ -f "$DP_TEMPLATE_PATH" ]] || die "canonical DP template missing: ${DP_TEMPLATE_PATH}"

  local actual_hash
  actual_hash="$(sha256_file "$DP_TEMPLATE_PATH")"
  if [[ "$actual_hash" != "$template_hash" ]]; then
    die "template preflight failed: canonical template hash mismatch (expected ${template_hash}, got ${actual_hash})"
  fi
  return 0
}

read_addendum_lint_constants() {
  local lint_path="$REPO_ROOT/tools/lint/dp.sh"
  local template_hash

  [[ -f "$lint_path" ]] || die "missing tools/lint/dp.sh"

  ADDENDUM_TEMPLATE_PATH="$(awk -F'"' '/^CANONICAL_ADDENDUM_TEMPLATE_PATH="/{print $2; exit}' "$lint_path")"
  template_hash="$(awk -F'"' '/^CANONICAL_ADDENDUM_TEMPLATE_SHA256="/{print $2; exit}' "$lint_path")"

  [[ -n "$ADDENDUM_TEMPLATE_PATH" ]] || die "failed to read CANONICAL_ADDENDUM_TEMPLATE_PATH from tools/lint/dp.sh"
  [[ -n "$template_hash" ]] || die "failed to read CANONICAL_ADDENDUM_TEMPLATE_SHA256 from tools/lint/dp.sh"
  [[ "$template_hash" =~ ^[0-9a-f]{64}$ ]] || die "invalid CANONICAL_ADDENDUM_TEMPLATE_SHA256 in tools/lint/dp.sh"

  ADDENDUM_TEMPLATE_PATH="$REPO_ROOT/$ADDENDUM_TEMPLATE_PATH"
  [[ -f "$ADDENDUM_TEMPLATE_PATH" ]] || die "canonical addendum template missing: ${ADDENDUM_TEMPLATE_PATH}"

  local actual_hash
  actual_hash="$(sha256_file "$ADDENDUM_TEMPLATE_PATH")"
  if [[ "$actual_hash" != "$template_hash" ]]; then
    die "template preflight failed: canonical addendum template hash mismatch (expected ${template_hash}, got ${actual_hash})"
  fi
  return 0
}

require_task_markers() {
  local task_path="$REPO_ROOT/TASK.md"
  local source_path
  resolve_task_surface_source "$task_path"
  source_path="$TASK_SURFACE_CONTENT_PATH"

  local section_count
  local dp_count
  section_count="$(grep -cE '^##[[:space:]]*3[.][[:space:]]*Current Dispatch Packet \(DP\)[[:space:]]*$' "$source_path" || true)"
  if [[ "$section_count" != "1" ]]; then
    cleanup_task_surface_context
    die_guard_failure \
      "TASK.md must contain exactly one '## 3. Current Dispatch Packet (DP)' heading" \
      "task_section_3_heading_count == 1" \
      "task_source_path" "$TASK_SURFACE_SOURCE_PATH" \
      "task_resolved_path" "$TASK_SURFACE_RESOLVED_PATH" \
      "observed_count" "$section_count" \
      "expected_count" "1"
  fi

  dp_count="$(awk '
    BEGIN { in_section=0; count=0 }
    /^##[[:space:]]*3[.][[:space:]]*Current Dispatch Packet \(DP\)[[:space:]]*$/ { in_section=1; next }
    in_section && /^##[[:space:]]*[0-9]+[.]/ && $0 !~ /^##[[:space:]]*3[.]/ { in_section=0 }
    in_section && /^### DP-/ { count++ }
    END { print count }
  ' "$source_path")"

  if [[ "$dp_count" != "1" ]]; then
    cleanup_task_surface_context
    die_guard_failure \
      "TASK.md must contain exactly one active '### DP-' block under Section 3" \
      "task_section_3_active_dp_block_count == 1" \
      "task_source_path" "$TASK_SURFACE_SOURCE_PATH" \
      "task_resolved_path" "$TASK_SURFACE_RESOLVED_PATH" \
      "observed_count" "$dp_count" \
      "expected_count" "1"
  fi

  cleanup_task_surface_context
  return 0
}

resolve_repo_path() {
  local value="$1"
  [[ -n "$value" ]] || die "path argument is empty"
  if [[ "$value" == /* ]]; then
    printf '%s' "$value"
    return 0
  fi
  printf '%s/%s' "$REPO_ROOT" "$value"
}

rel_path_for_output() {
  local value="$1"
  if [[ "$value" == "$REPO_ROOT/"* ]]; then
    printf '%s' "${value#${REPO_ROOT}/}"
    return 0
  fi
  printf '%s' "$value"
}

render_dp() {
  local out_path="$1"
  local proposed_work_branch="$WORK_BRANCH"
  [[ -x "$TEMPLATE_BIN" ]] || die "template binary missing or not executable: ${TEMPLATE_BIN}"

  local -a cmd=(
    "$TEMPLATE_BIN" render dp
    "--out=${out_path}"
    "--slot=DP_ID=${DP_ID}"
    "--slot=DP_TITLE=${DP_TITLE}"
    "--slot=BASE_BRANCH=${BASE_BRANCH}"
    "--slot=PROPOSED_WORK_BRANCH=${proposed_work_branch}"
    "--slot=BASE_HEAD=${BASE_HEAD}"
    "--slot=FRESHNESS_STAMP=${FRESHNESS_STAMP}"
    "--slot=DP_SCOPED_LOAD_ORDER=${DP_SCOPED_LOAD_ORDER}"
    "--slot=OBJECTIVE=${OBJECTIVE}"
    "--slot=IN_SCOPE=${IN_SCOPE}"
    "--slot=OUT_OF_SCOPE=${OUT_OF_SCOPE}"
    "--slot=SAFETY_INVARIANTS=${SAFETY_INVARIANTS}"
    "--slot=PLAN_STATE=${PLAN_STATE}"
    "--slot=PLAN_REQUEST=${PLAN_REQUEST}"
    "--slot=PLAN_CHANGELOG=${PLAN_CHANGELOG}"
    "--slot=PLAN_PATCH=${PLAN_PATCH}"
    "--slot=RECEIPT_EXTRA=${RECEIPT_EXTRA}"
    "--slot=CBC_PREFLIGHT=${CBC_PREFLIGHT}"
  )

  if [[ -n "$SLOTS_FILE" ]]; then
    cmd+=("--slots-file=${SLOTS_FILE}")
  fi

  "${cmd[@]}"
}

base_dp_source_path() {
  local base_dp="$1"
  local intake_path="$REPO_ROOT/storage/dp/intake/DP.md"
  local task_path="$REPO_ROOT/TASK.md"
  local pointer_rel=""

  if [[ -f "$intake_path" ]] && grep -Eq "^###[[:space:]]+${base_dp}:" "$intake_path"; then
    printf '%s' "$intake_path"
    return 0
  fi

  if [[ -f "$task_path" ]] && [[ "$(awk 'END { print NR }' "$task_path")" == "1" ]]; then
    pointer_rel="$(trim "$(cat "$task_path")")"
    pointer_rel="${pointer_rel#./}"
    if [[ -n "$pointer_rel" && -f "$REPO_ROOT/$pointer_rel" ]] && awk -v expected="$base_dp" '
      /^packet_id:[[:space:]]*/ {
        line=$0
        sub(/^packet_id:[[:space:]]*/, "", line)
        if (line == expected) {
          found=1
          exit
        }
      }
      /^###[[:space:]]*/ {
        line=$0
        sub(/^###[[:space:]]*/, "", line)
        sub(/:.*/, "", line)
        if (line == expected) {
          found=1
          exit
        }
      }
      END { exit found ? 0 : 1 }
    ' "$REPO_ROOT/$pointer_rel"; then
      printf '%s' "$REPO_ROOT/$pointer_rel"
      return 0
    fi
  fi

  mapfile -t matches < <(find "$REPO_ROOT/archives/surfaces" -maxdepth 1 -type f -name "TASK-${base_dp}-*.md" | sort)
  if (( ${#matches[@]} > 0 )); then
    printf '%s' "${matches[-1]}"
    return 0
  fi

  return 1
}

render_addendum_intake() {
  local base_dp="$1"
  local addendum_id="$2"
  local slots_file="$3"
  local out_path="$4"
  [[ -x "$TEMPLATE_BIN" ]] || die "template binary missing or not executable: ${TEMPLATE_BIN}"

  "$TEMPLATE_BIN" render addendum \
    "--out=${out_path}" \
    "--slots-file=${slots_file}" \
    "--slot=BASE_DP_ID=${base_dp}" \
    "--slot=ADDENDUM_ID=${addendum_id}"
}

render_closing_sidecar() {
  local dp_label="$1"
  local out_path="$2"
  [[ -x "$TEMPLATE_BIN" ]] || die "template binary missing or not executable: ${TEMPLATE_BIN}"

  "$TEMPLATE_BIN" render closing \
    "--out=${out_path}" \
    "--slot=DP_ID=${dp_label}"
}

update_task() {
  local rendered_path="$1"
  local task_path="$REPO_ROOT/TASK.md"
  local source_path
  local tmp_path
  local wrote_marker_path

  resolve_task_surface_source "$task_path"
  source_path="$TASK_SURFACE_CONTENT_PATH"
  tmp_path="$(mktemp)"
  wrote_marker_path="$(mktemp)"

  awk -v replacement="$rendered_path" -v wrote_marker="$wrote_marker_path" '
    BEGIN {
      in_section=0
      wrote=0
      skip_rest=0
    }
    /^##[[:space:]]*3[.][[:space:]]*Current Dispatch Packet \(DP\)[[:space:]]*$/ {
      in_section=1
      print
      next
    }
    in_section && /^### DP-/ && wrote==0 {
      while ((getline line < replacement) > 0) {
        print line
      }
      close(replacement)
      wrote=1
      print "1" > wrote_marker
      skip_rest=1
      next
    }
    skip_rest && /^##[[:space:]]*[0-9]+[.][[:space:]]/ && $0 !~ /^##[[:space:]]*3[.]/ {
      skip_rest=0
    }
    skip_rest {
      next
    }
    {
      print
    }
  ' "$source_path" > "$tmp_path"

  if [[ ! -s "$wrote_marker_path" ]]; then
    rm -f "$tmp_path" "$wrote_marker_path"
    cleanup_task_surface_context
    die_guard_failure \
      "failed to locate active DP heading inside TASK section 3" \
      "task_section_3_active_dp_heading_present_for_replacement" \
      "task_source_path" "$TASK_SURFACE_SOURCE_PATH" \
      "task_resolved_path" "$TASK_SURFACE_RESOLVED_PATH" \
      "replacement_source_path" "$rendered_path"
  fi

  rm -f "$wrote_marker_path"

  mv "$tmp_path" "$task_path"
  cleanup_task_surface_context
  return 0
}

DP_ID=""
DP_TITLE=""
BASE_BRANCH="main"
WORK_BRANCH=""
BASE_HEAD=""
FRESHNESS_STAMP="$(date -u +%F)"
SLOTS_FILE=""
ADDENDUM_LETTER=""
BASE_DP_ID=""

DP_SCOPED_LOAD_ORDER=""
OBJECTIVE=""
IN_SCOPE=""
OUT_OF_SCOPE=""
SAFETY_INVARIANTS=""
PLAN_STATE=""
PLAN_REQUEST=""
PLAN_CHANGELOG=""
PLAN_PATCH=""
RECEIPT_EXTRA=""
CBC_PREFLIGHT=""

INTAKE_ONLY=0
EMIT_PLAN_SCAFFOLD=""
EMIT_DP_SLOTS_SCAFFOLD=""
EDIT_SCAFFOLD=0
LOAD_SCAFFOLD_FILE=""
SCAFFOLD_EDITOR=""
VALIDATE_PLAN_SCAFFOLD=""
VALIDATE_DP_SLOTS_SCAFFOLD=""

for arg in "$@"; do
  case "$arg" in
    --id=*)
      DP_ID="${arg#--id=}"
      ;;
    --title=*)
      DP_TITLE="${arg#--title=}"
      ;;
    --base-branch=*)
      BASE_BRANCH="${arg#--base-branch=}"
      ;;
    --work-branch=*)
      WORK_BRANCH="${arg#--work-branch=}"
      ;;
    --base-head=*)
      BASE_HEAD="${arg#--base-head=}"
      ;;
    --freshness-stamp=*)
      FRESHNESS_STAMP="${arg#--freshness-stamp=}"
      ;;
    --emit-plan-scaffold=*)
      EMIT_PLAN_SCAFFOLD="${arg#--emit-plan-scaffold=}"
      ;;
    --emit-dp-slots-scaffold=*)
      EMIT_DP_SLOTS_SCAFFOLD="${arg#--emit-dp-slots-scaffold=}"
      ;;
    --edit-scaffold)
      EDIT_SCAFFOLD=1
      ;;
    --load-scaffold-file=*)
      LOAD_SCAFFOLD_FILE="${arg#--load-scaffold-file=}"
      ;;
    --scaffold-editor=*)
      SCAFFOLD_EDITOR="${arg#--scaffold-editor=}"
      ;;
    --validate-plan-scaffold=*)
      VALIDATE_PLAN_SCAFFOLD="${arg#--validate-plan-scaffold=}"
      ;;
    --validate-dp-slots-scaffold=*)
      VALIDATE_DP_SLOTS_SCAFFOLD="${arg#--validate-dp-slots-scaffold=}"
      ;;
    --slots-file=*)
      SLOTS_FILE="${arg#--slots-file=}"
      ;;
    --addendum=*)
      ADDENDUM_LETTER="${arg#--addendum=}"
      ;;
    --base-dp=*)
      BASE_DP_ID="${arg#--base-dp=}"
      ;;
    --dp-load-order=*)
      DP_SCOPED_LOAD_ORDER="${arg#--dp-load-order=}"
      ;;
    --objective=*)
      OBJECTIVE="${arg#--objective=}"
      ;;
    --in-scope=*)
      IN_SCOPE="${arg#--in-scope=}"
      ;;
    --out-of-scope=*)
      OUT_OF_SCOPE="${arg#--out-of-scope=}"
      ;;
    --safety=*)
      SAFETY_INVARIANTS="${arg#--safety=}"
      ;;
    --plan-state=*)
      PLAN_STATE="${arg#--plan-state=}"
      ;;
    --plan-request=*)
      PLAN_REQUEST="${arg#--plan-request=}"
      ;;
    --plan-changelog=*)
      PLAN_CHANGELOG="${arg#--plan-changelog=}"
      ;;
    --plan-patch=*)
      PLAN_PATCH="${arg#--plan-patch=}"
      ;;
    --cbc-preflight=*)
      CBC_PREFLIGHT="${arg#--cbc-preflight=}"
      ;;
    --receipt-extra=*)
      RECEIPT_EXTRA="${arg#--receipt-extra=}"
      ;;
    --receipt-commands=*)
      # Backward-compatible alias retained for older automation wrappers.
      RECEIPT_EXTRA="${arg#--receipt-commands=}"
      ;;
    --intake-only)
      INTAKE_ONLY=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown arg: ${arg}"
      ;;
  esac
done

ASSIST_MODE=0
if [[ -n "$EMIT_PLAN_SCAFFOLD" \
  || -n "$EMIT_DP_SLOTS_SCAFFOLD" \
  || "$EDIT_SCAFFOLD" == "1" \
  || -n "$LOAD_SCAFFOLD_FILE" \
  || -n "$SCAFFOLD_EDITOR" \
  || -n "$VALIDATE_PLAN_SCAFFOLD" \
  || -n "$VALIDATE_DP_SLOTS_SCAFFOLD" ]]; then
  ASSIST_MODE=1
fi

if (( ASSIST_MODE )); then
  if [[ -n "$ADDENDUM_LETTER" || -n "$BASE_DP_ID" ]]; then
    die "scaffold assist mode cannot be combined with addendum generation flags"
  fi
  if [[ -n "$DP_ID" || -n "$DP_TITLE" || -n "$WORK_BRANCH" || -n "$BASE_HEAD" ]]; then
    die "scaffold assist mode cannot be combined with base DP generation flags"
  fi

  if (( EDIT_SCAFFOLD )) && [[ -z "$EMIT_PLAN_SCAFFOLD" && -z "$EMIT_DP_SLOTS_SCAFFOLD" ]]; then
    die "--edit-scaffold requires --emit-plan-scaffold or --emit-dp-slots-scaffold"
  fi
  if [[ -n "$LOAD_SCAFFOLD_FILE" && -z "$EMIT_PLAN_SCAFFOLD" && -z "$EMIT_DP_SLOTS_SCAFFOLD" ]]; then
    die "--load-scaffold-file requires --emit-plan-scaffold or --emit-dp-slots-scaffold"
  fi
  if [[ -n "$SCAFFOLD_EDITOR" && "$EDIT_SCAFFOLD" != "1" ]]; then
    die "--scaffold-editor requires --edit-scaffold"
  fi

  if (( EDIT_SCAFFOLD )) && [[ -n "$EMIT_PLAN_SCAFFOLD" && -n "$EMIT_DP_SLOTS_SCAFFOLD" ]]; then
    die "--edit-scaffold supports one emitted scaffold target at a time"
  fi
  if [[ -n "$LOAD_SCAFFOLD_FILE" && -n "$EMIT_PLAN_SCAFFOLD" && -n "$EMIT_DP_SLOTS_SCAFFOLD" ]]; then
    die "--load-scaffold-file supports one emitted scaffold target at a time"
  fi

  if [[ -n "$EMIT_PLAN_SCAFFOLD" ]]; then
    emit_plan_path="$(resolve_repo_path "$EMIT_PLAN_SCAFFOLD")"
    mkdir -p "$(dirname "$emit_plan_path")"
    editor_write_plan_scaffold "$emit_plan_path"
    echo "Wrote: $(rel_path_for_output "$emit_plan_path")"

    if [[ -n "$LOAD_SCAFFOLD_FILE" ]]; then
      editor_load_scaffold_from_file "$LOAD_SCAFFOLD_FILE" "$emit_plan_path"
    fi
    if (( EDIT_SCAFFOLD )); then
      editor_capture_scaffold_interactive "PLAN SCAFFOLD" "$emit_plan_path" "$SCAFFOLD_EDITOR"
    fi
    if [[ -n "$LOAD_SCAFFOLD_FILE" || "$EDIT_SCAFFOLD" == "1" ]]; then
      editor_validate_plan_scaffold_file "$emit_plan_path"
      echo "PASS: draft: plan scaffold: $(rel_path_for_output "$emit_plan_path")"
    fi
  fi

  if [[ -n "$EMIT_DP_SLOTS_SCAFFOLD" ]]; then
    emit_slots_path="$(resolve_repo_path "$EMIT_DP_SLOTS_SCAFFOLD")"
    mkdir -p "$(dirname "$emit_slots_path")"
    editor_write_draft_slots_scaffold "$emit_slots_path"
    echo "Wrote: $(rel_path_for_output "$emit_slots_path")"

    if [[ -n "$LOAD_SCAFFOLD_FILE" ]]; then
      editor_load_scaffold_from_file "$LOAD_SCAFFOLD_FILE" "$emit_slots_path"
    fi
    if (( EDIT_SCAFFOLD )); then
      editor_capture_scaffold_interactive "DP SLOTS SCAFFOLD" "$emit_slots_path" "$SCAFFOLD_EDITOR"
    fi
    if [[ -n "$LOAD_SCAFFOLD_FILE" || "$EDIT_SCAFFOLD" == "1" ]]; then
      editor_validate_draft_slots_scaffold_file "$emit_slots_path"
      echo "PASS: draft: dp slots scaffold: $(rel_path_for_output "$emit_slots_path")"
    fi
  fi

  if [[ -n "$VALIDATE_PLAN_SCAFFOLD" ]]; then
    validate_plan_path="$(resolve_repo_path "$VALIDATE_PLAN_SCAFFOLD")"
    editor_validate_plan_scaffold_file "$validate_plan_path"
    echo "PASS: draft: plan scaffold validation: $(rel_path_for_output "$validate_plan_path")"
  fi

  if [[ -n "$VALIDATE_DP_SLOTS_SCAFFOLD" ]]; then
    validate_slots_path="$(resolve_repo_path "$VALIDATE_DP_SLOTS_SCAFFOLD")"
    editor_validate_draft_slots_scaffold_file "$validate_slots_path"
    echo "PASS: draft: dp slots scaffold validation: $(rel_path_for_output "$validate_slots_path")"
  fi

  if [[ -z "$EMIT_PLAN_SCAFFOLD" \
    && -z "$EMIT_DP_SLOTS_SCAFFOLD" \
    && -z "$VALIDATE_PLAN_SCAFFOLD" \
    && -z "$VALIDATE_DP_SLOTS_SCAFFOLD" ]]; then
    die "scaffold assist mode requires emit or validate flags"
  fi

  exit 0
fi

if [[ -n "$ADDENDUM_LETTER" && -z "$BASE_DP_ID" ]]; then
  die "--addendum requires --base-dp"
fi
if [[ -n "$BASE_DP_ID" && -z "$ADDENDUM_LETTER" ]]; then
  die "--base-dp requires --addendum"
fi

ADDENDUM_MODE=0
if [[ -n "$ADDENDUM_LETTER" && -n "$BASE_DP_ID" ]]; then
  ADDENDUM_MODE=1
fi

if (( ADDENDUM_MODE )); then
  [[ "$ADDENDUM_LETTER" =~ ^[A-Z]$ ]] || die "invalid --addendum value (expected a single uppercase letter A-Z): ${ADDENDUM_LETTER}"
  [[ "$BASE_DP_ID" =~ ^DP-OPS-[0-9]{4}$ ]] || die "invalid --base-dp format (expected DP-OPS-XXXX): ${BASE_DP_ID}"
  [[ -n "$SLOTS_FILE" ]] || die "--addendum/--base-dp mode requires --slots-file=PATH"
else
  [[ -n "$DP_ID" ]] || die "missing required --id"
  [[ -n "$DP_TITLE" ]] || die "missing required --title"
  [[ -n "$WORK_BRANCH" ]] || die "missing required --work-branch"
  [[ -n "$BASE_HEAD" ]] || die "missing required --base-head"
  [[ "$DP_ID" =~ ^DP-[A-Z]+-[0-9]{4,}$ ]] || die "invalid --id format: ${DP_ID}"
fi

if [[ -n "$SLOTS_FILE" ]]; then
  [[ -f "$SLOTS_FILE" ]] || die "slots file not found: ${SLOTS_FILE}"

  if (( ! ADDENDUM_MODE )); then
    [[ -n "$DP_SCOPED_LOAD_ORDER" ]] || DP_SCOPED_LOAD_ORDER="$(read_slot "DP_SCOPED_LOAD_ORDER" "$SLOTS_FILE")"
    [[ -n "$OBJECTIVE" ]] || OBJECTIVE="$(read_slot "OBJECTIVE" "$SLOTS_FILE")"
    [[ -n "$IN_SCOPE" ]] || IN_SCOPE="$(read_slot "IN_SCOPE" "$SLOTS_FILE")"
    [[ -n "$OUT_OF_SCOPE" ]] || OUT_OF_SCOPE="$(read_slot "OUT_OF_SCOPE" "$SLOTS_FILE")"
    [[ -n "$SAFETY_INVARIANTS" ]] || SAFETY_INVARIANTS="$(read_slot "SAFETY_INVARIANTS" "$SLOTS_FILE")"
    [[ -n "$PLAN_STATE" ]] || PLAN_STATE="$(read_slot "PLAN_STATE" "$SLOTS_FILE")"
    [[ -n "$PLAN_REQUEST" ]] || PLAN_REQUEST="$(read_slot "PLAN_REQUEST" "$SLOTS_FILE")"
    [[ -n "$PLAN_CHANGELOG" ]] || PLAN_CHANGELOG="$(read_slot "PLAN_CHANGELOG" "$SLOTS_FILE")"
    [[ -n "$PLAN_PATCH" ]] || PLAN_PATCH="$(read_slot "PLAN_PATCH" "$SLOTS_FILE")"
    [[ -n "$CBC_PREFLIGHT" ]] || CBC_PREFLIGHT="$(read_slot "CBC_PREFLIGHT" "$SLOTS_FILE")"
    if [[ -z "$RECEIPT_EXTRA" ]]; then
      RECEIPT_EXTRA="$(read_slot "RECEIPT_EXTRA" "$SLOTS_FILE")"
    fi
    if [[ -z "$RECEIPT_EXTRA" ]]; then
      RECEIPT_EXTRA="$(read_slot "RECEIPT_COMMANDS" "$SLOTS_FILE")"
    fi
  fi
fi

if (( ! ADDENDUM_MODE )); then
  if ! block_has_content "$DP_SCOPED_LOAD_ORDER"; then
    die "missing required slot: DP_SCOPED_LOAD_ORDER"
  fi
  if ! block_has_content "$OBJECTIVE"; then
    die "missing required slot: OBJECTIVE"
  fi
  if ! block_has_content "$IN_SCOPE"; then
    die "missing required slot: IN_SCOPE"
  fi
  if ! block_has_content "$OUT_OF_SCOPE"; then
    die "missing required slot: OUT_OF_SCOPE"
  fi
  if ! block_has_content "$SAFETY_INVARIANTS"; then
    die "missing required slot: SAFETY_INVARIANTS"
  fi
  if ! block_has_content "$PLAN_STATE"; then
    die "missing required slot: PLAN_STATE"
  fi
  if ! block_has_content "$PLAN_REQUEST"; then
    die "missing required slot: PLAN_REQUEST"
  fi
  if ! block_has_content "$PLAN_CHANGELOG"; then
    die "missing required slot: PLAN_CHANGELOG"
  fi
  if ! block_has_content "$PLAN_PATCH"; then
    die "missing required slot: PLAN_PATCH"
  fi
  if ! block_has_content "$RECEIPT_EXTRA"; then
    die "missing required slot: RECEIPT_EXTRA"
  fi
fi

trap 'emit_binary_leaf "draft" "finish"' EXIT
emit_binary_leaf "draft" "start"

require_clean_tree

if (( ADDENDUM_MODE )); then
  read_addendum_lint_constants
  base_source_path="$(base_dp_source_path "$BASE_DP_ID")" || die "base DP artifact not found in active intake or TASK leaf lineage: ${BASE_DP_ID}"

  mkdir -p "$REPO_ROOT/storage/dp/intake" "$REPO_ROOT/storage/handoff"

  addendum_intake_path="$REPO_ROOT/storage/dp/intake/ADDENDUM.md"
  addendum_closing_path="$REPO_ROOT/storage/handoff/CLOSING.md"

  render_addendum_intake "$BASE_DP_ID" "$ADDENDUM_LETTER" "$SLOTS_FILE" "$addendum_intake_path"
  render_closing_sidecar "${BASE_DP_ID} Addendum ${ADDENDUM_LETTER}" "$addendum_closing_path"

  echo "Base: ${base_source_path#${REPO_ROOT}/}"
  echo "Wrote: ${addendum_intake_path#${REPO_ROOT}/}"
  echo "Wrote: ${addendum_closing_path#${REPO_ROOT}/}"
  exit 0
fi

read_lint_constants
require_task_markers

mkdir -p "$REPO_ROOT/storage/dp/intake"

active_intake_path="$REPO_ROOT/storage/dp/intake/DP.md"
rendered_path="$(mktemp)"

render_dp "$rendered_path"
cp "$rendered_path" "$active_intake_path"
if (( ! INTAKE_ONLY )); then
  update_task "$rendered_path"
fi
rm -f "$rendered_path"

echo "Updated active draft: ${active_intake_path#${REPO_ROOT}/}"
if (( ! INTAKE_ONLY )); then
  echo "Updated: TASK.md"
fi
exit 0
