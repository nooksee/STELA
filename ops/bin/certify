append_command_log_entry \
  "$CMD_ID" \
  "./ops/bin/prune --target=dump --phase=report --dry-run" \
  "$PRUNE_REPORT_STARTED_AT" \
  "$PRUNE_REPORT_FINISHED_AT" \
  "$PRUNE_REPORT_DURATION_SECONDS" \
