  printf '%s' "$COMMAND_LOG" >&2
  die "dump-visible prune report failed"
fi

POST_INTEGRITY_STDOUT_SANITIZED="$(printf '%s' "$POST_INTEGRITY_STDOUT" | sanitize_disposable_refs)"
POST_INTEGRITY_STDERR_SANITIZED="$(printf '%s' "$POST_INTEGRITY_STDERR" | sanitize_disposable_refs)"
INTEGRITY_OUTPUT+=$'\n\nPost-command integrity recheck:\n'
if [[ -n "$(trim "$POST_INTEGRITY_STDOUT_SANITIZED")" ]]; then
  INTEGRITY_OUTPUT+="${POST_INTEGRITY_STDOUT_SANITIZED}"
else
  INTEGRITY_OUTPUT+="(empty)"
fi
if [[ -n "$(trim "$POST_INTEGRITY_STDERR_SANITIZED")" ]]; then
  INTEGRITY_OUTPUT+=$'\nPost-command integrity stderr:\n'
  INTEGRITY_OUTPUT+="${POST_INTEGRITY_STDERR_SANITIZED}"
fi
if [[ -z "$ADDENDUM_ID" && -n "$(trim "${TASK_CONSISTENCY_STDOUT:-}")" ]]; then
  INTEGRITY_OUTPUT+=$'\n\nActive TASK packet-consistency recheck:\n'
  INTEGRITY_OUTPUT+="${TASK_CONSISTENCY_STDOUT}"
fi
if [[ -n "$(trim "$PRUNE_REPORT_STDOUT")" ]]; then
  PRUNE_REPORT_STDOUT_SANITIZED="$(printf '%s' "$PRUNE_REPORT_STDOUT" | sanitize_disposable_refs)"
  INTEGRITY_OUTPUT+=$'\n\nDump-visible prune pressure report:\n'
  INTEGRITY_OUTPUT+="${PRUNE_REPORT_STDOUT_SANITIZED}"
fi
if [[ -n "$(trim "$PRUNE_REPORT_STDERR")" ]]; then
  PRUNE_REPORT_STDERR_SANITIZED="$(printf '%s' "$PRUNE_REPORT_STDERR" | sanitize_disposable_refs)"
  INTEGRITY_OUTPUT+=$'\nDump-visible prune stderr:\n'
  INTEGRITY_OUTPUT+="${PRUNE_REPORT_STDERR_SANITIZED}"
