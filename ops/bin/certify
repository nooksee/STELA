#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
# shellcheck source=/dev/null
source "${REPO_ROOT}/ops/lib/scripts/common.sh"
source "${REPO_ROOT}/ops/lib/scripts/editor.sh"
TASK_PATH="${REPO_ROOT}/TASK.md"
TEMPLATE_BIN="${REPO_ROOT}/ops/bin/template"
INTEGRITY_LINT="${REPO_ROOT}/tools/lint/integrity.sh"
RESULTS_LINT="${REPO_ROOT}/tools/lint/results.sh"
HANDOFF_DIR="${REPO_ROOT}/storage/handoff"
DP_INTAKE_DIR="${REPO_ROOT}/storage/dp/intake"
ACTIVE_DP_REL="storage/dp/intake/DP.md"
ACTIVE_ADDENDUM_REL="storage/dp/intake/ADDENDUM.md"
ACTIVE_RESULTS_REL="storage/handoff/RESULTS.md"
ACTIVE_CLOSING_REL="storage/handoff/CLOSING.md"
LOGS_DIR="${REPO_ROOT}/logs"
TELEMETRY_HEAD_PATH="${LOGS_DIR}/certify.telemetry.head"
SURFACE_ARCHIVE_DIR="${REPO_ROOT}/archives/surfaces"
POW_SURFACE_PATH="${REPO_ROOT}/PoW.md"
SOP_SURFACE_PATH="${REPO_ROOT}/SoP.md"
TASK_SURFACE_PATH="${REPO_ROOT}/TASK.md"

usage() {
  cat <<'USAGE'
Usage: ops/bin/certify --dp=DP-OPS-XXXX [--out=auto|PATH] [--allow-intake-fallback] [--addendum=X] [--narrative-file=PATH]
USAGE
}

CERTIFY_PHASE=""
CERTIFY_PHASE_STARTED_EPOCH=""
CERTIFY_RUN_STARTED_EPOCH="$(date +%s)"
declare -A CERTIFY_PHASE_DURATION_SECONDS=()
declare -a CERTIFY_COMMAND_TIMINGS=()
declare -A CERTIFY_GENERATED_PATHS=()
declare -a CERTIFY_GENERATED_PATH_ORDER=()

certify_set_phase() {
  local next_phase="$1"
  [[ -n "$next_phase" ]] || return 0
  if [[ "$CERTIFY_PHASE" == "$next_phase" ]]; then
    return 0
  fi
  local now_epoch
  now_epoch="$(date +%s)"
  if [[ -n "$CERTIFY_PHASE" && -n "$CERTIFY_PHASE_STARTED_EPOCH" ]]; then
    CERTIFY_PHASE_DURATION_SECONDS["$CERTIFY_PHASE"]=$(( ${CERTIFY_PHASE_DURATION_SECONDS["$CERTIFY_PHASE"]:-0} + now_epoch - CERTIFY_PHASE_STARTED_EPOCH ))
  fi
  CERTIFY_PHASE="$next_phase"
  CERTIFY_PHASE_STARTED_EPOCH="$now_epoch"
  printf 'Certify phase: %s\n' "$CERTIFY_PHASE"
}

certify_finalize_phase_timing() {
  local now_epoch
  now_epoch="$(date +%s)"
  if [[ -n "$CERTIFY_PHASE" && -n "$CERTIFY_PHASE_STARTED_EPOCH" ]]; then
    CERTIFY_PHASE_DURATION_SECONDS["$CERTIFY_PHASE"]=$(( ${CERTIFY_PHASE_DURATION_SECONDS["$CERTIFY_PHASE"]:-0} + now_epoch - CERTIFY_PHASE_STARTED_EPOCH ))
    CERTIFY_PHASE_STARTED_EPOCH="$now_epoch"
  fi
}

build_phase_summary_output() {
  local phase duration_seconds
  for phase in startup preflight replay verify postflight results; do
    duration_seconds="${CERTIFY_PHASE_DURATION_SECONDS[$phase]:-0}"
    printf 'CERTIFY-PHASE: name=%s duration_seconds=%s\n' "$phase" "$duration_seconds"
  done
}

build_long_pole_summary_output() {
  local -a rows=()
  local row rank cmd_id phase duration_seconds command
  if (( ${#CERTIFY_COMMAND_TIMINGS[@]} == 0 )); then
    printf 'CERTIFY-LONG-POLE: none\n'
    return 0
  fi

  mapfile -t rows < <(printf '%s\n' "${CERTIFY_COMMAND_TIMINGS[@]}" | sort -t $'\t' -k3,3nr -k1,1 | head -n 5)
  rank=0
  for row in "${rows[@]}"; do
    IFS=$'\t' read -r cmd_id phase duration_seconds command <<< "$row"
    rank=$((rank + 1))
    printf 'CERTIFY-LONG-POLE: rank=%s phase=%s command_id=%s duration_seconds=%s command=%s\n' \
      "$rank" "$phase" "$cmd_id" "$duration_seconds" "$command"
  done
}

register_certify_generated_path() {
  local path="$1"
  local normalized
  normalized="$(normalize_path "$path")"
  [[ -n "$normalized" ]] || return 0
  if [[ -z "${CERTIFY_GENERATED_PATHS[$normalized]+set}" ]]; then
    CERTIFY_GENERATED_PATHS["$normalized"]=1
    CERTIFY_GENERATED_PATH_ORDER+=("$normalized")
  fi
}

path_is_certify_generated() {
  local path="$1"
  local normalized
  normalized="$(normalize_path "$path")"
  [[ -n "$normalized" ]] || return 1
  [[ -n "${CERTIFY_GENERATED_PATHS[$normalized]+set}" ]]
}

task_lineage_leaf_rel() {
  local dp_id="$1"
  local git_short_hash="$2"
  printf 'archives/surfaces/TASK-%s-%s.md' "$dp_id" "$git_short_hash"
}

addendum_lineage_leaf_rel() {
  local dp_id="$1"
  local git_short_hash="$2"
  printf 'archives/surfaces/ADDENDUM-%s-%s.md' "$dp_id" "$git_short_hash"
}

task_lineage_leaf_contains_packet() {
  local source_path="$1"
  local dp_id="$2"
  awk -v expected="$dp_id" '
    /^packet_id:[[:space:]]*/ {
      line=$0
      sub(/^packet_id:[[:space:]]*/, "", line)
      if (line == expected) {
        found=1
        exit
      }
    }
    /^###[[:space:]]*/ {
      line=$0
      sub(/^###[[:space:]]*/, "", line)
      sub(/:.*/, "", line)
      if (line == expected) {
        found=1
        exit
      }
    }
    END { exit found ? 0 : 1 }
  ' "$source_path"
}

find_task_lineage_leaf_rel_for_packet() {
  local dp_id="$1"
  local pointer_rel=""

  if pointer_rel="$(read_surface_head_pointer "$TASK_SURFACE_PATH")"; then
    if [[ -f "${REPO_ROOT}/${pointer_rel}" ]] && task_lineage_leaf_contains_packet "${REPO_ROOT}/${pointer_rel}" "$dp_id"; then
      printf '%s' "$pointer_rel"
      return 0
    fi
  fi

  mapfile -t matches < <(find "${REPO_ROOT}/archives/surfaces" -maxdepth 1 -type f -name "TASK-${dp_id}-*.md" | sort)
  if (( ${#matches[@]} > 0 )); then
    printf '%s' "${matches[-1]#${REPO_ROOT}/}"
    return 0
  fi

  return 1
}

register_certify_generated_surface_paths() {
  local packet_id="$1"
  local freshness_stamp="$2"
  local git_short_hash="$3"
  local addendum_id="${4:-}"

  CERTIFY_GENERATED_PATHS=()
  CERTIFY_GENERATED_PATH_ORDER=()

  register_certify_generated_path "PoW.md"
  register_certify_generated_path "SoP.md"
  register_certify_generated_path "TASK.md"
  register_certify_generated_path "archives/surfaces/PoW-${freshness_stamp}-${git_short_hash}.md"
  register_certify_generated_path "archives/surfaces/SoP-${freshness_stamp}-${git_short_hash}.md"
  register_certify_generated_path "$(task_lineage_leaf_rel "$packet_id" "$git_short_hash")"
  if [[ -n "$addendum_id" ]]; then
    register_certify_generated_path "$(addendum_lineage_leaf_rel "$packet_id" "$git_short_hash")"
  fi
}

build_generated_surface_policy_output() {
  local path
  echo "Generated surface ownership policy:"
  for path in "${CERTIFY_GENERATED_PATH_ORDER[@]}"; do
    printf -- "- %s\n" "$path"
  done
}

die() {
  if [[ -n "$CERTIFY_PHASE" ]]; then
    echo "ERROR [${CERTIFY_PHASE}]: $*" >&2
  else
    echo "ERROR: $*" >&2
  fi
  exit 1
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

normalize_path() {
  local value
  value="$(trim "$1")"
  value="${value#\`}"
  value="${value%\`}"
  value="${value#./}"
  if [[ "$value" == "${REPO_ROOT}/"* ]]; then
    value="${value#${REPO_ROOT}/}"
  fi
  printf '%s' "$value"
}

CLOSING_LABELS_MANIFEST_PATH="${REPO_ROOT}/ops/lib/manifests/CLOSING.md"
declare -a CLOSING_LABELS_CURRENT=()
CLOSING_LABELS_CURRENT_LOADED=0

load_closing_labels_current() {
  if (( CLOSING_LABELS_CURRENT_LOADED )); then
    return 0
  fi

  [[ -f "$CLOSING_LABELS_MANIFEST_PATH" ]] || die "closing labels manifest missing: ${CLOSING_LABELS_MANIFEST_PATH#${REPO_ROOT}/}"
  if ! grep -Eq '^##[[:space:]]+Section 1:[[:space:]]+Current Closeout Labels[[:space:]]*$' "$CLOSING_LABELS_MANIFEST_PATH"; then
    die "closing labels manifest missing required SSOT section heading"
  fi

  mapfile -t CLOSING_LABELS_CURRENT < <(
    awk '
      /^##[[:space:]]+Section 1:[[:space:]]+Current Closeout Labels[[:space:]]*$/ { in_section=1; next }
      in_section && /^##[[:space:]]+/ { exit }
      in_section && /[^[:space:]]/ { print }
    ' "$CLOSING_LABELS_MANIFEST_PATH"
  )

  if [[ "${#CLOSING_LABELS_CURRENT[@]}" -ne 6 ]]; then
    die "closing labels manifest must define exactly six current labels (found ${#CLOSING_LABELS_CURRENT[@]})"
  fi

  CLOSING_LABELS_CURRENT_LOADED=1
}

declare -A ALLOWLIST_ENTRIES=()
declare -a ALLOWLIST_PATTERNS=()

load_allowlist_entries() {
  local pointer="$1"
  local allowlist_path="$pointer"
  if [[ "$allowlist_path" != /* ]]; then
    allowlist_path="${REPO_ROOT}/${allowlist_path}"
  fi
  [[ -f "$allowlist_path" ]] || die "allowlist pointer file missing: ${pointer}"

  ALLOWLIST_ENTRIES=()
  ALLOWLIST_PATTERNS=()

  local raw_line=""
  while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
    local entry
    entry="$(normalize_path "$raw_line")"
    [[ -n "$entry" ]] || continue
    if [[ "$entry" == \#* ]]; then
      continue
    fi
    case "$entry" in
      storage/dp/intake/DP.md)
        ;;
      storage/dp/intake/DP-*.md)
        ;;
      storage/dp/intake/*-ADDENDUM-*.md)
        ;;
      storage/handoff/CLOSING-*.md)
        ;;
      storage/handoff/*|storage/dumps/*|storage/dp/intake/*)
        die "allowlist entry must be persistent repo state (runtime artifact prefix forbidden): ${entry}"
        ;;
    esac
    if [[ "$entry" == *"*"* || "$entry" == *"?"* || "$entry" == *"["* ]]; then
      ALLOWLIST_PATTERNS+=("$entry")
      continue
    fi
    ALLOWLIST_ENTRIES["$entry"]=1
  done < "$allowlist_path"
}

extract_addendum_scope_delta() {
  local intake_path="$1"
  [[ -f "$intake_path" ]] || die "addendum intake missing for SCOPE_DELTA extraction: ${intake_path#${REPO_ROOT}/}"
  awk '
    BEGIN { in_block=0 }
    /^SCOPE_DELTA[[:space:]]*$|^- SCOPE_DELTA[[:space:]]*$|^[[:space:]]*SCOPE_DELTA:[[:space:]]*$/ {
      in_block=1; next
    }
    in_block && /^[A-Z_]+:[[:space:]]*$|^- [A-Z_]+[[:space:]]*$/ { in_block=0 }
    in_block {
      line=$0
      sub(/^[[:space:]]*-[[:space:]]*/, "", line)
      sub(/^[[:space:]]+/, "", line)
      sub(/[[:space:]]+$/, "", line)
      if (length(line) > 0) print line
    }
  ' "$intake_path" | while IFS= read -r path_entry || [[ -n "$path_entry" ]]; do
    [[ -n "$path_entry" ]] || continue
    if [[ "$path_entry" == *"*"* || "$path_entry" == *"?"* || "$path_entry" == *"["* || "$path_entry" == *"{"* || "$path_entry" == *"}"* ]]; then
      die "addendum SCOPE_DELTA entry contains forbidden glob or brace expansion token: ${path_entry}"
    fi
    printf '%s\n' "$path_entry"
  done
}

allowlist_contains_path() {
  local path="$1"
  if path_is_certify_generated "$path"; then
    return 0
  fi
  if [[ -n "${ALLOWLIST_ENTRIES[$path]+set}" ]]; then
    return 0
  fi

  local pattern=""
  for pattern in "${ALLOWLIST_PATTERNS[@]}"; do
    if [[ "$path" == $pattern ]]; then
      return 0
    fi
  done

  return 1
}

assert_allowlist_contains_path() {
  local path="$1"
  if ! allowlist_contains_path "$path"; then
    die "path must be present in active allowlist before mutation: ${path}"
  fi
}

resolve_task_source_path() {
  local line_count
  line_count="$(awk 'END { print NR }' "$TASK_SURFACE_PATH")"
  if [[ "$line_count" != "1" ]]; then
    printf '%s' "$TASK_SURFACE_PATH"
    return 0
  fi

  local pointer_path
  pointer_path="$(trim "$(cat "$TASK_SURFACE_PATH")")"
  pointer_path="$(normalize_path "$pointer_path")"
  if [[ ! "$pointer_path" =~ ^archives/surfaces/[A-Za-z0-9._/-]+\.md$ ]]; then
    die "TASK.md is single-line but not a valid archives/surfaces pointer: ${pointer_path}"
  fi

  local target_path="${REPO_ROOT}/${pointer_path}"
  [[ -f "$target_path" ]] || die "TASK pointer target missing: ${pointer_path}"
  printf '%s' "$target_path"
}

read_surface_head_pointer() {
  local surface_abs_path="$1"
  local surface_rel_path="${surface_abs_path#${REPO_ROOT}/}"
  local line_count
  line_count="$(awk 'END { print NR }' "$surface_abs_path")"
  if [[ "$line_count" != "1" ]]; then
    return 1
  fi

  local pointer_path
  pointer_path="$(trim "$(cat "$surface_abs_path")")"
  pointer_path="$(normalize_path "$pointer_path")"
  if [[ ! "$pointer_path" =~ ^archives/surfaces/[A-Za-z0-9._/-]+\.md$ ]]; then
    die "${surface_rel_path} is single-line but not a valid archives/surfaces pointer: ${pointer_path}"
  fi

  local target_path="${REPO_ROOT}/${pointer_path}"
  [[ -f "$target_path" ]] || die "${surface_rel_path} pointer target missing: ${pointer_path}"
  printf '%s' "$pointer_path"
}

read_surface_head_pointer_from_committed_head() {
  local surface_abs_path="$1"
  local surface_rel_path="${surface_abs_path#${REPO_ROOT}/}"
  local snapshot_path="${TMP_DIR}/head-pointer-${surface_rel_path##*/}"

  if ! git -C "$REPO_ROOT" cat-file -e "HEAD:${surface_rel_path}" >/dev/null 2>&1; then
    return 1
  fi
  git -C "$REPO_ROOT" show "HEAD:${surface_rel_path}" > "$snapshot_path" || return 1

  local line_count
  line_count="$(awk 'END { print NR }' "$snapshot_path")"
  if [[ "$line_count" != "1" ]]; then
    return 1
  fi

  local pointer_path
  pointer_path="$(trim "$(cat "$snapshot_path")")"
  pointer_path="$(normalize_path "$pointer_path")"
  if [[ ! "$pointer_path" =~ ^archives/surfaces/[A-Za-z0-9._/-]+\.md$ ]]; then
    return 1
  fi

  local target_path="${REPO_ROOT}/${pointer_path}"
  [[ -f "$target_path" ]] || die "${surface_rel_path} committed HEAD pointer target missing: ${pointer_path}"
  printf '%s' "$pointer_path"
}

extract_surface_entry_header_packet_id() {
  local surface_path="$1"
  awk '
    BEGIN { in_frontmatter=0 }
    NR == 1 && $0 == "---" { in_frontmatter=1; next }
    in_frontmatter && $0 == "---" { in_frontmatter=0; next }
    in_frontmatter { next }
    /^##[[:space:]]+/ {
      if (match($0, /DP-[A-Z]+-[0-9]{4,}/)) {
        print substr($0, RSTART, RLENGTH)
        exit
      }
    }
  ' "$surface_path"
}

count_surface_entry_headers() {
  local surface_path="$1"
  awk '
    BEGIN { in_frontmatter=0 }
    NR == 1 && $0 == "---" { in_frontmatter=1; next }
    in_frontmatter && $0 == "---" { in_frontmatter=0; next }
    in_frontmatter { next }
    /^##[[:space:]]+/ { count++ }
    END { print count + 0 }
  ' "$surface_path"
}

validate_surface_head_authored_for_packet() {
  local surface_abs_path="$1"
  local expected_packet_id="$2"
  local surface_rel_path="${surface_abs_path#${REPO_ROOT}/}"
  local source_path="$surface_abs_path"
  local source_rel_path="$surface_rel_path"
  local head_pointer=""

  if head_pointer="$(read_surface_head_pointer "$surface_abs_path")"; then
    source_path="${REPO_ROOT}/${head_pointer}"
    source_rel_path="$head_pointer"
  fi

  local entry_count
  entry_count="$(count_surface_entry_headers "$source_path")"
  [[ "$entry_count" == "1" ]] || die "${surface_rel_path} current source must contain exactly one entry before certify: source=${source_rel_path} entry_count=${entry_count}"

  local body_packet_id
  body_packet_id="$(trim "$(extract_surface_entry_header_packet_id "$source_path")")"
  [[ -n "$body_packet_id" ]] || die "${surface_rel_path} current source is missing a DP entry header: source=${source_rel_path}"

  if [[ "$body_packet_id" != "$expected_packet_id" ]]; then
    if [[ -n "$head_pointer" ]]; then
      die "${surface_rel_path} still points at ${body_packet_id}; author the current ${expected_packet_id} single-entry head before certify"
    fi
    die "${surface_rel_path} current entry does not match ${expected_packet_id}; author the current single-entry head before certify"
  fi
}

extract_markdown_body_for_snapshot() {
  local source_path="$1"
  awk '
    BEGIN {
      in_frontmatter=0
      saw_frontmatter=0
      closed_frontmatter=0
    }
    NR == 1 {
      if ($0 == "---") {
        in_frontmatter=1
        saw_frontmatter=1
        next
      }
      print
      next
    }
    in_frontmatter {
      if ($0 == "---") {
        in_frontmatter=0
        closed_frontmatter=1
      }
      next
    }
    { print }
    END {
      if (saw_frontmatter && !closed_frontmatter) {
        exit 1
      }
    }
  ' "$source_path"
}

render_task_snapshot_body() {
  local source_path="$1"
  local replacement_dp_path="$2"
  local out_path="$3"
  local source_body_tmp="${TMP_DIR}/task-snapshot-source.body"
  local wrote_marker_path="${TMP_DIR}/task-snapshot-replaced.marker"

  if ! extract_markdown_body_for_snapshot "$source_path" > "$source_body_tmp"; then
    die "failed to extract TASK snapshot body from ${source_path#${REPO_ROOT}/}"
  fi

  rm -f "$wrote_marker_path"
  awk -v replacement="$replacement_dp_path" -v wrote_marker="$wrote_marker_path" '
    BEGIN {
      in_section=0
      wrote=0
      skip_rest=0
    }
    /^##[[:space:]]*3[.][[:space:]]*Current Dispatch Packet \(DP\)[[:space:]]*$/ {
      in_section=1
      print
      next
    }
    in_section && /^### DP-/ && wrote==0 {
      while ((getline line < replacement) > 0) {
        print line
      }
      close(replacement)
      wrote=1
      print "1" > wrote_marker
      skip_rest=1
      next
    }
    skip_rest && /^##[[:space:]]*[0-9]+[.][[:space:]]/ && $0 !~ /^##[[:space:]]*3[.]/ {
      skip_rest=0
    }
    skip_rest { next }
    { print }
  ' "$source_body_tmp" > "$out_path"

  if [[ ! -s "$wrote_marker_path" ]]; then
    die "failed to locate active DP heading inside TASK section 3 while materializing TASK snapshot"
  fi
}

extract_dp_field_value() {
  local dp_path="$1"
  local label="$2"
  awk -v label="$label" '
    $0 ~ ("^[[:space:]]*(-[[:space:]]+)?" label ":[[:space:]]*") {
      value=$0
      sub("^[[:space:]]*(-[[:space:]]+)?[^:]+:[[:space:]]*", "", value)
      print value
      exit
    }
  ' "$dp_path"
}

assert_dp_required_sections() {
  local dp_path="$1"
  local -a required_heading_patterns=(
    '^##([#])?[[:space:]]*3[.]1[[:space:]]'
    '^##([#])?[[:space:]]*3[.]1[.]1[[:space:]]'
    '^##([#])?[[:space:]]*3[.]2[[:space:]]'
    '^##([#])?[[:space:]]*3[.]3[[:space:]]'
    '^##([#])?[[:space:]]*3[.]4[[:space:]]'
    '^###([#])?[[:space:]]*3[.]4[.]1[[:space:]]'
    '^###([#])?[[:space:]]*3[.]4[.]2[[:space:]]'
    '^###([#])?[[:space:]]*3[.]4[.]3[[:space:]]'
    '^###([#])?[[:space:]]*3[.]4[.]4[[:space:]]'
    '^###([#])?[[:space:]]*3[.]4[.]5[[:space:]]'
    '^##([#])?[[:space:]]*3[.]5[[:space:]]'
    '^###([#])?[[:space:]]*3[.]5[.]1[[:space:]]'
  )

  local pattern=""
  for pattern in "${required_heading_patterns[@]}"; do
    if ! grep -Eq "$pattern" "$dp_path"; then
      die "DP payload missing required section heading (pattern: ${pattern})"
    fi
  done
}

assert_addendum_required_sections() {
  local addendum_path="$1"
  local -a required_heading_patterns=(
    '^##([#])?[[:space:]]*A[.]1[[:space:]]'
    '^##([#])?[[:space:]]*A[.]2[[:space:]]'
    '^##([#])?[[:space:]]*A[.]3[[:space:]]'
    '^##([#])?[[:space:]]*A[.]4[[:space:]]'
    '^##([#])?[[:space:]]*A[.]5[[:space:]]'
  )

  local pattern=""
  for pattern in "${required_heading_patterns[@]}"; do
    if ! grep -Eq "$pattern" "$addendum_path"; then
      die "addendum payload missing required section heading (pattern: ${pattern})"
    fi
  done
}

validate_closing_block_sidecar() {
  local closing_path="$1"
  local allowlist_pointer="$2"
  load_closing_labels_current
  local -a required_labels_current=("${CLOSING_LABELS_CURRENT[@]}")

  has_required_labels() {
    local file_path="$1"
    shift
    local label=""
    for label in "$@"; do
      if ! grep -Fxq "$label" "$file_path"; then
        return 1
      fi
    done
    return 0
  }

  if ! has_required_labels "$closing_path" "${required_labels_current[@]}"; then
    die "closing block sidecar missing required mandatory-label schema"
  fi

  local offense=""

  offense="$(grep -nF '{{' "$closing_path" | head -n1 || true)"
  [[ -z "$offense" ]] || die "closing block sidecar contains unresolved slot token marker '{{' at ${offense}"
  offense="$(grep -nF '}}' "$closing_path" | head -n1 || true)"
  [[ -z "$offense" ]] || die "closing block sidecar contains unresolved slot token marker '}}' at ${offense}"

  local -a forbidden_tokens=(
    "{"
    "}"
    "*"
    "["
    "]"
    "\`"
  )
  local token=""
  for token in "${forbidden_tokens[@]}"; do
    offense="$(grep -nF "$token" "$closing_path" | head -n1 || true)"
    [[ -z "$offense" ]] || die "closing block sidecar contains forbidden token '${token}' at ${offense}"
  done

  offense="$(grep -nF '.tools/workflows/' "$closing_path" | head -n1 || true)"
  [[ -z "$offense" ]] || die "closing block sidecar contains banned invented pathing at ${offense}"
  offense="$(grep -nF '$(' "$closing_path" | head -n1 || true)"
  [[ -z "$offense" ]] || die "closing block sidecar contains command substitution token \$\( at ${offense}"

  local normalized_allowlist_pointer
  normalized_allowlist_pointer="$(normalize_path "$allowlist_pointer")"
  [[ -n "$normalized_allowlist_pointer" ]] || die "closing block sidecar validation received empty allowlist pointer"

  declare -A diff_paths=()
  local diff_path=""
  while IFS= read -r diff_path || [[ -n "$diff_path" ]]; do
    diff_path="$(normalize_path "$diff_path")"
    [[ -n "$diff_path" ]] || continue
    diff_paths["$diff_path"]=1
  done < <(git -C "$REPO_ROOT" diff --name-only HEAD)

  local -a allowed_prefixes=(
    ".github/"
    "tools/"
    "ops/"
    "docs/"
    "storage/"
    "archives/"
    "logs/"
  )
  local allowlisted_entry_count=0
  local diff_entry_count=0
  local allowlisted_diff_entry_count=0
  local allowlisted_not_in_diff_entry_count=0
  local diff_only_entry_count=0
  local prefix_match_count=0
  local validated_entries=0
  local has_allowlist_pointer_entry=0

  if allowlist_contains_path "$normalized_allowlist_pointer"; then
    has_allowlist_pointer_entry=1
  fi

  local in_manifest=0
  local found_manifest=0
  local manifest_count=0
  local manifest_start_label="${required_labels_current[4]}"
  local manifest_end_label="${required_labels_current[5]}"

  local raw_line=""
  while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
    local line
    line="$(trim "$raw_line")"

    if [[ "$line" == "$manifest_start_label" ]]; then
      found_manifest=1
      in_manifest=1
      continue
    fi

    if (( in_manifest )); then
      if [[ "$line" == "$manifest_end_label" ]]; then
        in_manifest=0
        break
      fi
      [[ -n "$line" ]] || continue

      if [[ "$line" == /* || "$line" == *".."* || "$line" =~ [[:space:]] ]]; then
        die "closing manifest entry must be a repo-relative literal path: ${line}"
      fi
      if [[ ! "$line" =~ ^[A-Za-z0-9._/-]+$ ]]; then
        die "closing manifest entry contains invalid characters: ${line}"
      fi

      local prefix_ok=0
      local prefix=""
      for prefix in "${allowed_prefixes[@]}"; do
        if [[ "$line" == "$prefix"* ]]; then
          prefix_ok=1
          break
        fi
      done
      if (( prefix_ok == 0 )); then
        die "closing manifest entry must start with an approved repo-relative prefix: ${line}"
      fi

      local path_abs="${REPO_ROOT}/${line}"
      [[ -e "$path_abs" ]] || die "closing manifest entry path does not exist: ${line}"

      local is_allowlisted=0
      local is_in_diff=0
      if allowlist_contains_path "$line"; then
        is_allowlisted=1
      fi
      if [[ -n "${diff_paths[$line]+set}" ]]; then
        is_in_diff=1
      fi

      prefix_match_count=$((prefix_match_count + 1))
      if (( is_allowlisted )); then
        allowlisted_entry_count=$((allowlisted_entry_count + 1))
      fi
      if (( is_in_diff )); then
        diff_entry_count=$((diff_entry_count + 1))
      fi

      if (( is_allowlisted == 0 && is_in_diff == 0 )); then
        die "closing manifest entry must be allowlisted or present in git diff --name-only HEAD: ${line}"
      fi
      if (( is_allowlisted && is_in_diff )); then
        allowlisted_diff_entry_count=$((allowlisted_diff_entry_count + 1))
      elif (( is_allowlisted )); then
        allowlisted_not_in_diff_entry_count=$((allowlisted_not_in_diff_entry_count + 1))
      elif (( is_in_diff )); then
        diff_only_entry_count=$((diff_only_entry_count + 1))
      fi

      manifest_count=$((manifest_count + 1))
      validated_entries=$((validated_entries + 1))
    fi
  done < "$closing_path"

  (( found_manifest == 1 )) || die "closing block sidecar missing file-manifest section start label"
  (( manifest_count > 0 )) || die "closing block sidecar file-manifest section is empty"
  (( has_allowlist_pointer_entry == 1 )) || die "allowlist pointer is not present in active allowlist: ${normalized_allowlist_pointer}"

  cat <<EOF
CLOSING Manifest Validation: PASS
- Sidecar: ${closing_path#${REPO_ROOT}/}
- Allowlist pointer: ${normalized_allowlist_pointer}
- Manifest entries validated: ${validated_entries}
- Manifest entries matched allowlist: ${allowlisted_entry_count}
- Manifest entries matched git diff: ${diff_entry_count}
- Manifest entries matched allowlist and git diff: ${allowlisted_diff_entry_count}
- Manifest entries allowlisted but not in git diff: ${allowlisted_not_in_diff_entry_count}
- Manifest entries matched git diff without allowlist coverage: ${diff_only_entry_count}
- Approved-prefix entries: ${prefix_match_count}
EOF
}

validate_artifact_path_consistency() {
  local dp_id="$1"
  local dp_intake_rel="$ACTIVE_DP_REL"
  local closing_rel="$ACTIVE_CLOSING_REL"
  local results_rel="$ACTIVE_RESULTS_REL"

  [[ -f "${REPO_ROOT}/${dp_intake_rel}" ]] || die "missing canonical intake DP path: ${dp_intake_rel}"
  [[ -f "${REPO_ROOT}/${closing_rel}" ]] || die "missing canonical closing sidecar path: ${closing_rel}"
  grep -Eq "^###[[:space:]]+${dp_id}:" "${REPO_ROOT}/${dp_intake_rel}" \
    || die "active DP surface does not contain expected packet heading: ${dp_id}"

  [[ ! -f "${REPO_ROOT}/${dp_id}.md" ]] || die "non-canonical root DP variant detected: ${dp_id}.md"
  [[ ! -f "${REPO_ROOT}/CLOSING-${dp_id}.md" ]] || die "non-canonical root closing variant detected: CLOSING-${dp_id}.md"
  [[ ! -f "${REPO_ROOT}/${dp_id}-RESULTS.md" ]] || die "non-canonical root results variant detected: ${dp_id}-RESULTS.md"

  cat <<EOF
Artifact Path Consistency: PASS
- Intake DP path: ${dp_intake_rel}
- Closing sidecar path: ${closing_rel}
- Active RESULTS path: ${results_rel}
- Authoritative packet lineage class: archives/surfaces/TASK-${dp_id}-<git-short-hash>.md
- Root-level lookalike variants absent: yes
EOF
}

validate_addendum_artifact_path_consistency() {
  local dp_id="$1"
  local addendum_id="$2"
  local addendum_label="ADDENDUM-${addendum_id}"
  local intake_rel="$ACTIVE_ADDENDUM_REL"
  local closing_rel="$ACTIVE_CLOSING_REL"
  local results_rel="$ACTIVE_RESULTS_REL"

  [[ -f "${REPO_ROOT}/${intake_rel}" ]] || die "missing canonical addendum intake path: ${intake_rel}"
  [[ -f "${REPO_ROOT}/${closing_rel}" ]] || die "missing canonical addendum closing sidecar path: ${closing_rel}"
  grep -Eq "^###[[:space:]]+Addendum[[:space:]]+${addendum_id}[[:space:]]+to[[:space:]]+${dp_id}$" "${REPO_ROOT}/${intake_rel}" \
    || die "active addendum surface does not contain expected heading for ${dp_id} addendum ${addendum_id}"

  [[ ! -f "${REPO_ROOT}/${dp_id}-${addendum_label}.md" ]] \
    || die "non-canonical root addendum DP variant detected: ${dp_id}-${addendum_label}.md"
  [[ ! -f "${REPO_ROOT}/CLOSING-${dp_id}-${addendum_label}.md" ]] \
    || die "non-canonical root addendum closing variant detected: CLOSING-${dp_id}-${addendum_label}.md"
  [[ ! -f "${REPO_ROOT}/${dp_id}-RESULTS-${addendum_id}.md" ]] \
    || die "non-canonical root addendum results variant detected: ${dp_id}-RESULTS-${addendum_id}.md"

  cat <<EOF
Addendum Artifact Path Consistency: PASS
- Addendum intake path: ${intake_rel}
- Addendum closing sidecar path: ${closing_rel}
- Active addendum RESULTS path: ${results_rel}
- Authoritative addendum lineage class: archives/surfaces/ADDENDUM-${dp_id}-<git-short-hash>.md
- Root-level lookalike variants absent: yes
EOF
}

emit_addendum_lineage_leaf() {
  local dp_id="$1"
  local source_abs="$2"
  local git_short_hash="$3"
  local lineage_abs
  local lineage_rel

  [[ -f "$source_abs" ]] || die "DP lineage source missing: ${source_abs#${REPO_ROOT}/}"
  lineage_rel="$(addendum_lineage_leaf_rel "$dp_id" "$git_short_hash")"
  lineage_abs="${REPO_ROOT}/${lineage_rel}"

  mkdir -p "$(dirname "$lineage_abs")"
  cp "$source_abs" "$lineage_abs"
  printf 'Addendum lineage leaf emitted: %s -> %s\n' "${source_abs#${REPO_ROOT}/}" "$lineage_rel"
}

resolve_authoritative_dp_source_for_results() {
  local dp_id="$1"
  local git_short_hash="$2"
  local addendum_id="${3:-}"
  if [[ -n "$addendum_id" ]]; then
    addendum_lineage_leaf_rel "$dp_id" "$git_short_hash"
    return 0
  fi
  task_lineage_leaf_rel "$dp_id" "$git_short_hash"
}

assert_dp_matches_work_branch() {
  local dp_id="$1"
  local branch_name
  branch_name="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)"
  if [[ "$branch_name" =~ ^work/(dp-[a-z0-9]+-[0-9]{4,})-[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    local branch_dp_id
    branch_dp_id="$(printf '%s' "${BASH_REMATCH[1]}" | tr '[:lower:]' '[:upper:]')"
    if [[ "$dp_id" != "$branch_dp_id" ]]; then
      die "--dp '${dp_id}' does not match work-branch packet '${branch_dp_id}' (${branch_name})"
    fi
  fi
}

run_closing_validator_negative_self_check() {
  local allowlist_pointer="$1"
  local fixture_path="${TMP_DIR}/closing-validator-negative-fixture.md"
  local manifest_field_label=""
  local label=""

  load_closing_labels_current
  manifest_field_label="${CLOSING_LABELS_CURRENT[4]}"

  : > "$fixture_path"
  for label in "${CLOSING_LABELS_CURRENT[@]}"; do
    printf '%s\n' "$label" >> "$fixture_path"
    if [[ "$label" == "$manifest_field_label" ]]; then
      printf 'ops/bin/certify{invalid}\n\n' >> "$fixture_path"
    else
      printf 'fixture\n\n' >> "$fixture_path"
    fi
  done

  if (validate_closing_block_sidecar "$fixture_path" "$allowlist_pointer" >/dev/null 2>&1); then
    die "closing manifest validator regression: malformed fixture was accepted"
  fi
}

emit_surface_leaf_and_pointer() {
  local surface_abs_path="$1"
  local leaf_rel_path="$2"
  local trace_id="$3"
  local packet_id="$4"
  local created_at="$5"
  local task_replacement_dp_path="${6:-}"
  local surface_rel_path="${surface_abs_path#${REPO_ROOT}/}"

  [[ -f "$surface_abs_path" ]] || die "surface missing: ${surface_rel_path}"
  assert_allowlist_contains_path "$surface_rel_path"
  assert_allowlist_contains_path "$leaf_rel_path"

  local previous="(none)"
  local source_path="$surface_abs_path"
  local head_pointer=""
  if head_pointer="$(read_surface_head_pointer "$surface_abs_path")"; then
    previous="$head_pointer"
    source_path="${REPO_ROOT}/${head_pointer}"
    # Certify leaf names are deterministic (packet/date/hash). If certify is rerun on
    # the same HEAD before commit, the head pointer can already equal the destination
    # leaf path. Preserve the existing leaf's previous-pointer chain instead of writing
    # a self-referential previous field.
    if [[ "$head_pointer" == "$leaf_rel_path" && -f "$source_path" ]]; then
      local existing_previous
      existing_previous="$(awk '
        BEGIN { in_frontmatter=0 }
        NR == 1 && $0 == "---" { in_frontmatter=1; next }
        in_frontmatter && $0 == "---" { exit }
        in_frontmatter && /^previous:[[:space:]]*/ {
          line=$0
          sub(/^previous:[[:space:]]*/, "", line)
          print line
          exit
        }
      ' "$source_path")"
      existing_previous="$(trim "$existing_previous")"
      if [[ -n "$existing_previous" ]]; then
        previous="$existing_previous"
      fi
    fi
  elif [[ "$surface_rel_path" != "TASK.md" ]] && head_pointer="$(read_surface_head_pointer_from_committed_head "$surface_abs_path")"; then
    # Pre-certify PoW/SoP heads are authored as single current-entry markdown. Preserve
    # archive chain linkage from the committed pointer head while snapshotting the new body.
    previous="$head_pointer"
  fi

  local body_tmp="${TMP_DIR}/snapshot-${surface_rel_path##*/}.body"
  if [[ "$surface_rel_path" == "TASK.md" && -n "$task_replacement_dp_path" ]]; then
    render_task_snapshot_body "$source_path" "$task_replacement_dp_path" "$body_tmp"
  elif ! extract_markdown_body_for_snapshot "$source_path" > "$body_tmp"; then
    die "failed to extract snapshot body from ${source_path#${REPO_ROOT}/}"
  fi

  local leaf_abs_path="${REPO_ROOT}/${leaf_rel_path}"
  mkdir -p "$(dirname "$leaf_abs_path")"
  cat <<EOF > "$leaf_abs_path"
---
trace_id: ${trace_id}
packet_id: ${packet_id}
created_at: ${created_at}
previous: ${previous}
---
EOF
  cat "$body_tmp" >> "$leaf_abs_path"
  printf '%s\n' "$leaf_rel_path" > "$surface_abs_path"
}

emit_surface_leaves_phase() {
  local trace_id="$1"
  local packet_id="$2"
  local freshness_stamp="$3"
  local git_short_hash="$4"
  local created_at="$5"
  local task_replacement_dp_path="${6:-}"

  [[ "$freshness_stamp" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || die "invalid Freshness Stamp format in DP payload: ${freshness_stamp}"
  [[ "$git_short_hash" =~ ^[0-9a-f]{7,}$ ]] || die "invalid short hash for surface leaf naming: ${git_short_hash}"

  local pow_leaf_rel="archives/surfaces/PoW-${freshness_stamp}-${git_short_hash}.md"
  local sop_leaf_rel="archives/surfaces/SoP-${freshness_stamp}-${git_short_hash}.md"
  local task_leaf_rel="archives/surfaces/TASK-${packet_id}-${git_short_hash}.md"

  emit_surface_leaf_and_pointer "$POW_SURFACE_PATH" "$pow_leaf_rel" "$trace_id" "$packet_id" "$created_at"
  emit_surface_leaf_and_pointer "$SOP_SURFACE_PATH" "$sop_leaf_rel" "$trace_id" "$packet_id" "$created_at"
  emit_surface_leaf_and_pointer "$TASK_SURFACE_PATH" "$task_leaf_rel" "$trace_id" "$packet_id" "$created_at" "$task_replacement_dp_path"

  cat <<EOF
Phase 2 surface leaves emitted:
- PoW.md -> ${pow_leaf_rel}
- SoP.md -> ${sop_leaf_rel}
- TASK.md -> ${task_leaf_rel}
EOF
}

normalize_unallowlisted_llms_drift() {
  local -a llms_paths=(
    "llms.txt"
    "llms-core.txt"
    "llms-full.txt"
  )

  local -a normalized_paths=()
  local -a skipped_allowlisted_paths=()
  local -a no_drift_paths=()
  local -a missing_head_paths=()
  local path=""

  echo "Candidate selection pattern:"
  echo "- llms.txt"
  echo "- llms-core.txt"
  echo "- llms-full.txt"
  echo "Candidate evaluation:"

  for path in "${llms_paths[@]}"; do
    local allowlisted_status="no"
    local drift_status="no"
    local action_line=""

    if allowlist_contains_path "$path"; then
      allowlisted_status="yes"
      skipped_allowlisted_paths+=("$path")
      action_line="skipped because allowlisted"
      printf -- "- file=%s allowlisted=%s drift=%s action=%s\n" "$path" "$allowlisted_status" "$drift_status" "$action_line"
      continue
    fi

    if git -C "$REPO_ROOT" cat-file -e "HEAD:${path}" >/dev/null 2>&1; then
      if git -C "$REPO_ROOT" diff --quiet HEAD -- "$path"; then
        no_drift_paths+=("$path")
        action_line="no normalization required"
        printf -- "- file=%s allowlisted=%s drift=%s action=%s\n" "$path" "$allowlisted_status" "$drift_status" "$action_line"
        continue
      fi
      drift_status="yes"
      if git -C "$REPO_ROOT" restore --source=HEAD --staged --worktree -- "$path" >/dev/null 2>&1; then
        action_line="git restore --source=HEAD --staged --worktree -- ${path}"
      else
        git -C "$REPO_ROOT" reset -q HEAD -- "$path"
        git -C "$REPO_ROOT" checkout -- "$path"
        action_line="git reset -q HEAD -- ${path} && git checkout -- ${path}"
      fi
      normalized_paths+=("$path")
      printf -- "- file=%s allowlisted=%s drift=%s action=%s\n" "$path" "$allowlisted_status" "$drift_status" "$action_line"
      continue
    fi
    missing_head_paths+=("$path")
    action_line="skipped because file is absent in HEAD"
    printf -- "- file=%s allowlisted=%s drift=%s action=%s\n" "$path" "$allowlisted_status" "$drift_status" "$action_line"
  done

  if (( ${#normalized_paths[@]} > 0 )); then
    echo "Normalized files:"
    for path in "${normalized_paths[@]}"; do
      printf -- "- %s\n" "$path"
    done
  else
    echo "Normalized files: (none)"
  fi

  if (( ${#skipped_allowlisted_paths[@]} > 0 )); then
    echo "Skipped allowlisted files:"
    for path in "${skipped_allowlisted_paths[@]}"; do
      printf -- "- %s\n" "$path"
    done
  else
    echo "Skipped allowlisted files: (none)"
  fi

  if (( ${#no_drift_paths[@]} > 0 )); then
    echo "No-drift files:"
    for path in "${no_drift_paths[@]}"; do
      printf -- "- %s\n" "$path"
    done
  else
    echo "No-drift files: (none)"
  fi

  if (( ${#missing_head_paths[@]} > 0 )); then
    echo "Missing-from-HEAD files:"
    for path in "${missing_head_paths[@]}"; do
      printf -- "- %s\n" "$path"
    done
  else
    echo "Missing-from-HEAD files: (none)"
  fi
}

verify_changed_files_subset_allowlist() {
  mapfile -t changed_paths < <(git -C "$REPO_ROOT" diff --name-only HEAD | sort)
  local -a unauthorized=()
  local path=""

  for path in "${changed_paths[@]}"; do
    local normalized
    normalized="$(normalize_path "$path")"
    if ! allowlist_contains_path "$normalized"; then
      unauthorized+=("$normalized")
    fi
  done

  if (( ${#unauthorized[@]} > 0 )); then
    echo "Changed files not present in allowlist:"
    for path in "${unauthorized[@]}"; do
      printf -- "- %s\n" "$path"
    done
    return 1
  fi

  echo "Changed-file subset check: PASS"
  echo "Changed files:"
  if (( ${#changed_paths[@]} == 0 )); then
    echo "- (none)"
  else
    for path in "${changed_paths[@]}"; do
      printf -- "- %s\n" "$path"
    done
  fi
}

select_latest_path_by_mtime() {
  local latest_path=""
  local latest_mtime=-1
  local path=""
  local mtime=0

  for path in "$@"; do
    [[ -f "$path" ]] || continue
    mtime="$(stat -c %Y "$path")"
    if (( mtime > latest_mtime )); then
      latest_mtime="$mtime"
      latest_path="$path"
      continue
    fi
    if (( mtime == latest_mtime )) && [[ "$path" > "$latest_path" ]]; then
      latest_path="$path"
    fi
  done

  [[ -n "$latest_path" ]] || return 1
  printf '%s' "$latest_path"
}

select_latest_open_artifact() {
  mapfile -t opens < <(
    find "$HANDOFF_DIR" -maxdepth 1 -type f | awk '
      {
        filename=$0
        sub(/^.*\//, "", filename)
        if (filename ~ /^OPEN-.*\.txt$/ && filename !~ /^OPEN-PORCELAIN-/) {
          print $0
        }
      }
    '
  )
  if (( ${#opens[@]} == 0 )); then
    return 1
  fi
  select_latest_path_by_mtime "${opens[@]}"
}

extract_trace_id_from_open() {
  local open_path="$1"
  [[ -f "$open_path" ]] || return 1
  local trace_id
  trace_id="$(
    awk '
      /STELA_TRACE_ID:[[:space:]]*/ {
        line=$0
        sub(/.*STELA_TRACE_ID:[[:space:]]*/, "", line)
        print line
        exit
      }
    ' "$open_path"
  )"
  trace_id="$(trim "$trace_id")"
  [[ -n "$trace_id" ]] || return 1
  printf '%s' "$trace_id"
}

resolve_trace_id() {
  local trace_id="${STELA_TRACE_ID:-}"
  if [[ -n "$trace_id" ]]; then
    printf '%s' "$trace_id"
    return 0
  fi

  local open_path=""
  open_path="$(select_latest_open_artifact || true)"
  if [[ -n "$open_path" ]]; then
    trace_id="$(extract_trace_id_from_open "$open_path" || true)"
  fi
  [[ -n "$trace_id" ]] || die "failed to resolve STELA_TRACE_ID from environment or latest OPEN artifact"
  printf '%s' "$trace_id"
}

emit_telemetry_leaf() {
  local trace_id="$1"
  local packet_id="$2"
  local created_at="$3"
  local results_path="$4"
  local branch="$5"
  local git_hash="$6"
  local dp_source="$7"
  local total_duration_seconds="$8"
  local phase_summary="$9"
  local long_pole_summary="${10}"

  mkdir -p "$LOGS_DIR"

  local previous="(none)"
  if [[ -f "$TELEMETRY_HEAD_PATH" ]]; then
    local previous_raw
    previous_raw="$(trim "$(cat "$TELEMETRY_HEAD_PATH")")"
    if [[ -n "$previous_raw" ]]; then
      previous="$previous_raw"
    fi
  fi

  local packet_token
  packet_token="$(slugify_token "$packet_id")"
  local stamp
  stamp="$(timestamp_token_utc)"
  local trace_digest
  trace_digest="$(short_hash "$trace_id")"

  local leaf_rel_path="logs/certify-${packet_token}-${stamp}-${trace_digest}.md"
  local leaf_abs_path="${REPO_ROOT}/${leaf_rel_path}"

  cat <<EOF > "$leaf_abs_path"
---
trace_id: ${trace_id}
packet_id: ${packet_id}
created_at: ${created_at}
previous: ${previous}
---
# Certify Telemetry Leaf
- results_path: ${results_path}
- branch: ${branch}
- git_hash: ${git_hash}
- dp_source: ${dp_source}
- total_duration_seconds: ${total_duration_seconds}
## Phase Summary
${phase_summary}
## Long Pole Summary
${long_pole_summary}
- head_pointer: logs/certify.telemetry.head
EOF

  printf '%s\n' "$leaf_rel_path" > "$TELEMETRY_HEAD_PATH"
  printf '%s' "$leaf_rel_path"
}

sanitize_disposable_refs() {
  sed -E \
    -e 's#\./storage/handoff/\*+#redacted-open-artifact-glob#g' \
    -e 's#storage/handoff/\*+#redacted-open-artifact-glob#g' \
    -e 's#\./storage/handoff/OPEN-PORCELAIN-[^[:space:]]+#redacted-porcelain-artifact-path#g' \
    -e 's#storage/handoff/OPEN-PORCELAIN-[^[:space:]]+#redacted-porcelain-artifact-path#g' \
    -e 's#\./storage/handoff/OPEN-[^[:space:]]+#redacted-open-artifact-path#g' \
    -e 's#storage/handoff/OPEN-[^[:space:]]+#redacted-open-artifact-path#g' \
    -e 's#\./storage/dumps/\*+#redacted-dump-artifact-glob#g' \
    -e 's#storage/dumps/\*+#redacted-dump-artifact-glob#g' \
    -e 's#\./storage/dumps/dump-[^[:space:]]+#redacted-dump-artifact-path#g' \
    -e 's#storage/dumps/dump-[^[:space:]]+#redacted-dump-artifact-path#g'
}

forbidden_disposable_pattern() {
  local _tag="Local"
  _tag+=" artifacts:"
  printf '%s|Disposable artifact policy|storage/handoff/\\*|storage/dumps/dump-|storage/dumps/\\*|dump-platform-work-dp-ops-[0-9]+\n' "$_tag"
}

assert_no_disposable_refs() {
  local path="$1"
  local label="$2"
  local pattern
  pattern="$(forbidden_disposable_pattern)"
  if grep -Einq "$pattern" "$path"; then
    echo "Forbidden disposable-artifact references found in ${label}:" >&2
    grep -Ein "$pattern" "$path" >&2 || true
    die "${label} contains forbidden disposable-artifact references"
  fi
}

latest_dump_manifest_pointer() {
  local latest_path=""
  latest_path="$(ls -1t "${REPO_ROOT}"/storage/dumps/*_manifest.txt "${REPO_ROOT}"/storage/dumps/*.manifest.txt 2>/dev/null | head -n1 || true)"
  [[ -n "$latest_path" ]] || return 1
  printf '%s' "$(normalize_path "$latest_path")"
}

extract_dump_manifest_pointer_from_stdout() {
  local stdout_body="$1"
  local raw_pointer=""
  raw_pointer="$(printf '%s\n' "$stdout_body" | awk '
    /^Dump manifest:[[:space:]]*/ {
      line=$0
      sub(/^Dump manifest:[[:space:]]*/, "", line)
      pointer=line
    }
    END {
      if (pointer != "") {
        print pointer
      }
    }
  ')"
  raw_pointer="$(trim "$raw_pointer")"
  [[ -n "$raw_pointer" ]] || return 1
  printf '%s' "$(normalize_path "$raw_pointer")"
}

maybe_capture_dump_manifest_pointer() {
  local command="$1"
  local stdout_body="$2"
  local captured_pointer=""

  if [[ "$command" != *"./ops/bin/dump"* && "$command" != *"ops/bin/dump"* ]]; then
    return 0
  fi

  RECEIPT_HAS_DUMP_COMMAND=1

  if captured_pointer="$(extract_dump_manifest_pointer_from_stdout "$stdout_body")"; then
    DUMP_MANIFEST_POINTER="$(printf '%s' "$captured_pointer" | sanitize_disposable_refs)"
    return 0
  fi

  if captured_pointer="$(latest_dump_manifest_pointer)"; then
    DUMP_MANIFEST_POINTER="$(printf '%s' "$captured_pointer" | sanitize_disposable_refs)"
  fi
}

append_command_log_entry() {
  local cmd_id="$1"
  local command="$2"
  local started_at="$3"
  local finished_at="$4"
  local duration_seconds="$5"
  local exit_code="$6"
  local stdout_body="$7"
  local stderr_body="$8"

  local sanitized_command
  sanitized_command="$(printf '%s' "$command" | sanitize_disposable_refs)"
  stdout_body="$(printf '%s' "$stdout_body" | sanitize_disposable_refs)"
  stderr_body="$(printf '%s' "$stderr_body" | sanitize_disposable_refs)"
  [[ -n "$stdout_body" ]] || stdout_body="(empty)"
  [[ -n "$stderr_body" ]] || stderr_body="(empty)"

  COMMAND_LOG+=$'### Command '"$cmd_id"$'\n'
  COMMAND_LOG+="- Command: \`${sanitized_command}\`"$'\n'
  COMMAND_LOG+="- Started (UTC): ${started_at}"$'\n'
  COMMAND_LOG+="- Finished (UTC): ${finished_at}"$'\n'
  COMMAND_LOG+="- Duration Seconds: ${duration_seconds}"$'\n'
  COMMAND_LOG+="- Exit Code: ${exit_code}"$'\n'
  COMMAND_LOG+=$'\n#### STDOUT\n~~~text\n'"${stdout_body}"$'\n~~~\n'
  COMMAND_LOG+=$'\n#### STDERR\n~~~text\n'"${stderr_body}"$'\n~~~\n\n'
  CERTIFY_COMMAND_TIMINGS+=("${cmd_id}"$'\t'"${CERTIFY_PHASE:-unknown}"$'\t'"${duration_seconds}"$'\t'"${sanitized_command}")
}

run_surface_emission_step() {
  local trace_id="$1"
  local packet_id="$2"
  local freshness_stamp="$3"
  local git_short_hash="$4"
  local task_replacement_dp_path="${5:-}"

  CMD_INDEX=$((CMD_INDEX + 1))
  local cmd_id
  cmd_id="$(printf '%02d' "$CMD_INDEX")"
  local started_at
  started_at="$(utc_now)"
  local start_epoch
  start_epoch="$(date +%s)"
  local created_at
  created_at="$(utc_now)"
  local stdout_body
  stdout_body="$(emit_surface_leaves_phase "$trace_id" "$packet_id" "$freshness_stamp" "$git_short_hash" "$created_at" "$task_replacement_dp_path")"
  local finished_at
  finished_at="$(utc_now)"
  local finish_epoch
  finish_epoch="$(date +%s)"
  local duration_seconds
  duration_seconds=$((finish_epoch - start_epoch))

  append_command_log_entry \
    "$cmd_id" \
    "internal: surface leaf emission and HEAD pointer rewrite" \
    "$started_at" \
    "$finished_at" \
    "$duration_seconds" \
    "0" \
    "$stdout_body" \
    "(empty)"
}

verify_active_task_leaf_packet_consistency() {
  local task_source_path
  task_source_path="$(resolve_task_source_path)"

  local pointer_path
  pointer_path="$(normalize_path "$(cat "$TASK_SURFACE_PATH")")"
  [[ -n "$pointer_path" ]] || die "TASK.md pointer is empty after surface emission"

  local leaf_packet_id
  leaf_packet_id="$(awk '
    BEGIN { in_frontmatter=0 }
    NR == 1 && $0 == "---" { in_frontmatter=1; next }
    in_frontmatter && $0 == "---" { exit }
    in_frontmatter && /^packet_id:[[:space:]]*/ {
      sub(/^packet_id:[[:space:]]*/, "", $0)
      print
      exit
    }
  ' "$task_source_path")"
  leaf_packet_id="$(trim "$leaf_packet_id")"
  [[ -n "$leaf_packet_id" ]] || die "TASK leaf missing packet_id frontmatter: ${task_source_path#${REPO_ROOT}/}"

  local body_packet_id
  body_packet_id="$(awk '
    /^### DP-[A-Z]+-[0-9]{4,}:[[:space:]]+/ {
      value=$0
      sub(/^### /, "", value)
      sub(/:.*/, "", value)
      print value
      exit
    }
  ' "$task_source_path")"
  body_packet_id="$(trim "$body_packet_id")"
  [[ -n "$body_packet_id" ]] || die "TASK leaf missing active DP heading in body: ${task_source_path#${REPO_ROOT}/}"

  if [[ "$leaf_packet_id" != "$body_packet_id" ]]; then
    die "TASK leaf packet/body mismatch: frontmatter=${leaf_packet_id} body=${body_packet_id} path=${pointer_path}"
  fi

  local branch_name
  branch_name="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)"
  local required_work_branch
  required_work_branch="$(awk '
    /^Required Work Branch:[[:space:]]*/ {
      sub(/^Required Work Branch:[[:space:]]*/, "", $0)
      print
      exit
    }
  ' "$task_source_path")"
  required_work_branch="$(trim "$required_work_branch")"
  [[ -n "$required_work_branch" ]] || die "TASK leaf missing Required Work Branch line: ${task_source_path#${REPO_ROOT}/}"

  if [[ "$required_work_branch" != "$branch_name" ]]; then
    die "TASK leaf branch/body mismatch: required_work_branch=${required_work_branch} current_branch=${branch_name} path=${pointer_path}"
  fi

  cat <<EOF
TASK packet-consistency check: PASS
- task_pointer: ${pointer_path}
- frontmatter_packet_id: ${leaf_packet_id}
- body_packet_id: ${body_packet_id}
- required_work_branch: ${required_work_branch}
EOF
}

extract_dp_block_from_task() {
  local dp_id="$1"
  local task_source_path="$2"
  local out_path="$3"
  awk -v dp_id="$dp_id" '
    BEGIN {
      in_section=0
      in_dp=0
    }
    /^##[[:space:]]*3[.][[:space:]]*Current Dispatch Packet [(]DP[)][[:space:]]*$/ {
      in_section=1
      next
    }
    in_section && /^##[[:space:]]*[0-9]+[.]/ && $0 !~ /^##[[:space:]]*3[.]/ {
      in_section=0
      in_dp=0
    }
    in_section && $0 ~ ("^### " dp_id ":[[:space:]].*$") {
      in_dp=1
    }
    in_dp && /^### DP-[A-Z]+-[0-9]{4,}:[[:space:]]+/ && $0 !~ ("^### " dp_id ":[[:space:]].*$") {
      exit
    }
    in_dp {
      print
    }
  ' "$task_source_path" > "$out_path"
}

extract_allowlist_pointer() {
  local dp_path="$1"
  local pointer_line
  pointer_line="$(
    awk '
      BEGIN { in_block=0 }
      /^Target Files allowlist [(]hard gate[)]:[[:space:]]*$/ {
        in_block=1
        next
      }
      in_block && /^[[:space:]]*-[[:space:]]+/ {
        print
        exit
      }
      in_block && /^##[[:space:]]*3[.]4([.]|[[:space:]])/ {
        exit
      }
    ' "$dp_path"
  )"

  [[ -n "$pointer_line" ]] || return 1

  local pointer_path
  pointer_path="$(printf '%s' "$pointer_line" | sed -E 's/^[[:space:]]*-[[:space:]]+//')"
  pointer_path="$(normalize_path "$pointer_path")"
  [[ -n "$pointer_path" ]] || return 1
  printf '%s' "$pointer_path"
}

extract_receipt_block() {
  local dp_path="$1"
  local out_path="$2"
  awk '
    BEGIN { in_block=0 }
    /^### 3[.]4[.]5([.]|[[:space:]])/ || /^#### 3[.]4[.]5([.]|[[:space:]])/ {
      in_block=1
      next
    }
    in_block && /^##[[:space:]]*3[.]5([.]|[[:space:]])/ { exit }
    in_block && /^### 3[.]5([.]|[[:space:]])/ { exit }
    in_block && /^#### 3[.]5([.]|[[:space:]])/ { exit }
    in_block { print }
  ' "$dp_path" > "$out_path"
}

extract_addendum_receipt_block() {
  local addendum_path="$1"
  local out_path="$2"
  awk '
    BEGIN { in_block=0 }
    /^##[[:space:]]*A[.]5([.]|[[:space:]])/ {
      in_block=1
      next
    }
    in_block { print }
  ' "$addendum_path" > "$out_path"
}

extract_commands() {
  local receipt_block_path="$1"
  local out_path="$2"

  : > "$out_path"
  local line=""
  local in_fence=0

  while IFS= read -r line || [[ -n "$line" ]]; do
    local candidate=""
    local emitted_command=""
    local first_token=""
    local trimmed
    local negated=0
    trimmed="$(trim "$line")"

    if [[ "$trimmed" =~ ^\`\`\` || "$trimmed" =~ ^~~~ ]]; then
      if (( in_fence )); then
        in_fence=0
      else
        in_fence=1
      fi
      continue
    fi

    if (( in_fence )); then
      candidate="$trimmed"
    else
      if [[ "$trimmed" =~ ^-[[:space:]]+ ]]; then
        candidate="${trimmed#- }"
      elif [[ "$trimmed" =~ ^[0-9]+[.][[:space:]]+ ]]; then
        candidate="${trimmed#*. }"
      else
        candidate="$trimmed"
      fi
    fi

    candidate="$(trim "$candidate")"
    [[ -n "$candidate" ]] || continue

    if [[ "$candidate" == \`* && "$candidate" == *\` ]]; then
      candidate="${candidate#\`}"
      candidate="${candidate%\`}"
      candidate="$(trim "$candidate")"
    fi

    case "$candidate" in
      "**Mandatory receipt commands"*|"**DP-specific receipt commands"*|"**Addendum-specific receipt commands"*|"Mandatory receipt commands"*|"DP-specific receipt commands"*|"Addendum-specific receipt commands"*|"Required pasted outputs:"*|"Mandatory Closing Block"*|"Mandatory Closing Sidecar"*|"Verify Section "*|"Worker runs"*|"Purpose:"*)
        continue
        ;;
    esac
    # DP receipt annotations in Section 3.4.5 use an explicit "Note:" prefix.
    # These lines are documentation, not executable commands, and must be skipped.
    case "$candidate" in
      "Note: "*)
        continue
        ;;
    esac

    if [[ "$candidate" =~ ^(\./)?ops/bin/certify([[:space:]]|$) ]]; then
      continue
    fi
    if [[ "$candidate" =~ ^bash[[:space:]]+tools/lint/results[.]sh([[:space:]]|$) ]]; then
      continue
    fi
    if [[ "$candidate" =~ (^|[[:space:]])bash[[:space:]]+tools/lint/llms[.]sh([[:space:]]|$) ]] && [[ ! -f "${REPO_ROOT}/tools/lint/llms.sh" ]]; then
      continue
    fi

    if [[ "$candidate" =~ ^![[:space:]]+ ]]; then
      negated=1
      candidate="${candidate#!}"
      candidate="$(trim "$candidate")"
      [[ -n "$candidate" ]] || continue
    fi

    if [[ "$candidate" == *"\`"* ]]; then
      continue
    fi
    if [[ "$candidate" == *'$('* ]]; then
      case "$candidate" in
        'test "$(cat PoW.md)" = "archives/surfaces/'*.md'"'|'test "$(cat SoP.md)" = "archives/surfaces/'*.md'"'|'test "$(cat TASK.md)" = "archives/surfaces/'*.md'"')
          ;;
        *)
          die "unsupported verification command in DP section 3.4.5: command substitution is not allowed (${candidate})"
          ;;
      esac
    fi
    first_token="${candidate%%[[:space:]]*}"
    if [[ "$candidate" == *"{"* || "$candidate" == *"}"* || "$candidate" == *"*"* || "$candidate" == *"?"* || "$candidate" == *"["* ]]; then
      case "$first_token" in
        grep|rg)
          ;;
        *)
          die "unsupported verification command in DP section 3.4.5: brace/glob patterns are not allowed (${candidate})"
          ;;
      esac
    fi

    emitted_command="$candidate"
    if (( negated )); then
      emitted_command="! ${candidate}"
    fi

    case "$first_token" in
      git|bash|./*|comm|cat|ls|cp|mv|rm|find|sed|awk|grep|rg|echo|printf|sh|test)
        printf '%s\n' "$emitted_command" >> "$out_path"
        ;;
      *)
        continue
        ;;
    esac
  done < "$receipt_block_path"
}

rewrite_certify_scoped_command() {
  local command="$1"
  case "$command" in
    "bash tools/verify.sh"|"./tools/verify.sh"|"bash tools/verify.sh --mode=full"|"./tools/verify.sh --mode=full"|"bash tools/verify.sh --mode=certify-critical"|"./tools/verify.sh --mode=certify-critical")
      if [[ -n "${CERTIFY_VERIFY_PATHS_REL:-}" ]]; then
        printf '%s' "bash tools/verify.sh --mode=certify-critical --paths-file=${CERTIFY_VERIFY_PATHS_REL}"
      else
        printf '%s' "bash tools/verify.sh --mode=certify-critical"
      fi
      ;;
    *)
      printf '%s' "$command"
      ;;
  esac
}

certify_phase_for_command() {
  local command="$1"
  case "$command" in
    bash\ tools/verify.sh\ --mode=certify-critical*|"./tools/verify.sh --mode=certify-critical"*|"bash tools/verify.sh"|"./tools/verify.sh"|"bash tools/verify.sh --mode=full"|"./tools/verify.sh --mode=full")
      printf '%s' "verify"
      ;;
    *)
      printf '%s' "replay"
      ;;
  esac
}

build_certify_verify_paths_file() {
  local out_path="$1"
  {
    git -C "$REPO_ROOT" diff --name-only HEAD
    git -C "$REPO_ROOT" ls-files --others --exclude-standard
  } | awk 'NF { print }' | LC_ALL=C sort -u > "$out_path"
}

build_command_plan() {
  local commands_path="$1"
  local pre_path="$2"
  local post_path="$3"

  : > "$pre_path"
  : > "$post_path"

  declare -A seen_pre=()
  declare -A seen_post=()

  enqueue_pre_command() {
    local command="$1"
    command="$(trim "$command")"
    [[ -n "$command" ]] || return 0
    if [[ -n "$ADDENDUM_ID" ]] && [[ "$command" == "git restore --source=HEAD --staged --worktree -- ops/lib/manifests/OPS.md" ]]; then
      printf '%s\n' "$command" >> "$pre_path"
      return 0
    fi
    if [[ -n "${seen_pre[$command]+set}" ]]; then
      return 0
    fi
    printf '%s\n' "$command" >> "$pre_path"
    seen_pre["$command"]=1
  }

  enqueue_post_command() {
    local command="$1"
    command="$(trim "$command")"
    [[ -n "$command" ]] || return 0
    if [[ -n "${seen_post[$command]+set}" ]]; then
      return 0
    fi
    printf '%s\n' "$command" >> "$post_path"
    seen_post["$command"]=1
  }

  enqueue_pre_command "bash tools/lint/dp.sh --test"
  enqueue_pre_command "bash tools/lint/dp.sh TASK.md"
  enqueue_pre_command "bash tools/lint/task.sh"

  local line=""
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="$(trim "$line")"
    [[ -n "$line" ]] || continue
    line="$(rewrite_certify_scoped_command "$line")"
    if [[ -n "$ADDENDUM_ID" ]] && [[ "$line" == comm\ -23*storage/dp/active/allowlist.txt* ]]; then
      continue
    fi
    if [[ "$line" =~ storage/handoff/DP-[A-Z]+-[0-9]{4,}-RESULTS[.]md ]]; then
      enqueue_post_command "$line"
    else
      enqueue_pre_command "$line"
    fi
  done < "$commands_path"
}

DP_ID=""
OUT_ARG="auto"
ALLOW_INTAKE_FALLBACK=0
ADDENDUM_ID=""
NARRATIVE_FILE_ARG=""

for arg in "$@"; do
  case "$arg" in
    --dp=*)
      DP_ID="${arg#--dp=}"
      ;;
    --out=*)
      OUT_ARG="${arg#--out=}"
      ;;
    --allow-intake-fallback)
      ALLOW_INTAKE_FALLBACK=1
      ;;
    --addendum=*)
      ADDENDUM_ID="${arg#--addendum=}"
      ;;
    --narrative-file=*)
      NARRATIVE_FILE_ARG="${arg#--narrative-file=}"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown arg: ${arg}"
      ;;
  esac
done

if [[ -n "$ADDENDUM_ID" ]]; then
  [[ "$ADDENDUM_ID" =~ ^[A-Z]$ ]] || die "--addendum value must be a single uppercase letter A-Z: ${ADDENDUM_ID}"
  [[ -n "$DP_ID" ]] || die "--addendum requires --dp"
fi

emit_binary_leaf "certify" "start"
certify_set_phase "startup"

[[ -n "$DP_ID" ]] || die "missing required --dp"
[[ "$DP_ID" =~ ^DP-[A-Z]+-[0-9]{4,}$ ]] || die "invalid --dp value: ${DP_ID}"
assert_dp_matches_work_branch "$DP_ID"

if [[ "$OUT_ARG" == "auto" || -z "$OUT_ARG" ]]; then
  OUT_PATH=""
else
  OUT_PATH="$OUT_ARG"
  if [[ "$OUT_PATH" != /* ]]; then
    OUT_PATH="${REPO_ROOT}/${OUT_PATH}"
  fi
fi

[[ -x "$TEMPLATE_BIN" ]] || die "template binary missing or not executable: ${TEMPLATE_BIN}"
[[ -x "$INTEGRITY_LINT" ]] || die "integrity lint missing or not executable: ${INTEGRITY_LINT}"
[[ -x "$RESULTS_LINT" ]] || die "results lint missing or not executable: ${RESULTS_LINT}"
[[ -f "$TASK_PATH" ]] || die "missing TASK surface: ${TASK_PATH}"
certify_set_phase "preflight"

mkdir -p "${HANDOFF_DIR}"
mkdir -p "${SURFACE_ARCHIVE_DIR}"

if [[ -n "$ADDENDUM_ID" ]]; then
  ADDENDUM_INTAKE_PATH="${REPO_ROOT}/${ACTIVE_ADDENDUM_REL}"
  CLOSING_PATH="${REPO_ROOT}/${ACTIVE_CLOSING_REL}"
  if [[ -z "$OUT_PATH" ]]; then
    OUT_PATH="${REPO_ROOT}/${ACTIVE_RESULTS_REL}"
  fi
else
  ADDENDUM_INTAKE_PATH=""
  CLOSING_PATH="${REPO_ROOT}/${ACTIVE_CLOSING_REL}"
  if [[ -z "$OUT_PATH" ]]; then
    OUT_PATH="${REPO_ROOT}/${ACTIVE_RESULTS_REL}"
  fi
fi
[[ -f "$CLOSING_PATH" ]] || die "missing closing block sidecar: ${CLOSING_PATH#${REPO_ROOT}/}"
if [[ -z "$(sed '/^[[:space:]]*$/d' "$CLOSING_PATH")" ]]; then
  die "closing block sidecar is empty: ${CLOSING_PATH#${REPO_ROOT}/}"
fi

TMP_DIR="$(mktemp -d "${REPO_ROOT}/var/tmp/certify.${DP_ID}.XXXXXX")"
trap 'emit_binary_leaf "certify" "finish"; rm -rf "$TMP_DIR"' EXIT
CERTIFY_VERIFY_PATHS_REL="${TMP_DIR#${REPO_ROOT}/}/verify-paths.txt"
CERTIFY_VERIFY_PATHS_PATH="${REPO_ROOT}/${CERTIFY_VERIFY_PATHS_REL}"
build_certify_verify_paths_file "$CERTIFY_VERIFY_PATHS_PATH"

DP_BLOCK_PATH="${TMP_DIR}/dp-block.md"
BASE_DP_BLOCK_PATH=""
BASE_DP_SOURCE=""
if [[ -n "$ADDENDUM_ID" ]]; then
  [[ -f "$ADDENDUM_INTAKE_PATH" ]] \
    || die "addendum intake missing and no fallback is permitted: ${ADDENDUM_INTAKE_PATH#${REPO_ROOT}/}"
  cp "$ADDENDUM_INTAKE_PATH" "$DP_BLOCK_PATH"
  DP_SOURCE="${ADDENDUM_INTAKE_PATH#${REPO_ROOT}/}"

  BASE_DP_BLOCK_PATH="${TMP_DIR}/base-dp-block.md"
  TASK_SOURCE_PATH="$(resolve_task_source_path)"
  extract_dp_block_from_task "$DP_ID" "$TASK_SOURCE_PATH" "$BASE_DP_BLOCK_PATH"
  BASE_DP_SOURCE="TASK.md"
  if [[ ! -s "$BASE_DP_BLOCK_PATH" ]]; then
    FALLBACK_BASE_DP_REL="$(find_task_lineage_leaf_rel_for_packet "$DP_ID")" || die "base DP payload not found in TASK.md and TASK leaf fallback is missing for ${DP_ID}"
    FALLBACK_BASE_DP_PATH="${REPO_ROOT}/${FALLBACK_BASE_DP_REL}"
    cp "$FALLBACK_BASE_DP_PATH" "$BASE_DP_BLOCK_PATH"
    BASE_DP_SOURCE="${FALLBACK_BASE_DP_REL}"
  fi
else
  TASK_SOURCE_PATH="$(resolve_task_source_path)"
  task_line_count="$(awk 'END { print NR }' "$TASK_PATH")"
  FALLBACK_DP_PATH="${REPO_ROOT}/${ACTIVE_DP_REL}"

  if [[ "$ALLOW_INTAKE_FALLBACK" == "1" && "$task_line_count" == "1" && -f "$FALLBACK_DP_PATH" ]]; then
    grep -Eq "^###[[:space:]]+${DP_ID}:" "$FALLBACK_DP_PATH" \
      || die "intake fallback blocked: active DP draft does not match ${DP_ID}"
    cp "$FALLBACK_DP_PATH" "$DP_BLOCK_PATH"
    DP_SOURCE="${FALLBACK_DP_PATH#${REPO_ROOT}/}"
  else
    extract_dp_block_from_task "$DP_ID" "$TASK_SOURCE_PATH" "$DP_BLOCK_PATH"

    DP_SOURCE="TASK.md"
    if [[ ! -s "$DP_BLOCK_PATH" ]]; then
      if [[ "$ALLOW_INTAKE_FALLBACK" != "1" ]]; then
        if [[ "$task_line_count" == "1" ]]; then
          ALLOW_INTAKE_FALLBACK=1
          echo "DP section '${DP_ID}' not found in TASK.md; auto-enabling intake fallback because TASK.md is pointer-only."
        else
          die "DP section '${DP_ID}' not found in TASK.md; intake fallback is disabled (pass --allow-intake-fallback to override)"
        fi
      fi
      [[ -f "$FALLBACK_DP_PATH" ]] || die "DP section '${DP_ID}' not found in TASK.md and fallback intake is missing: ${FALLBACK_DP_PATH#${REPO_ROOT}/}"
      grep -Eq "^###[[:space:]]+${DP_ID}:" "$FALLBACK_DP_PATH" \
        || die "intake fallback blocked: active DP draft does not match ${DP_ID}"
      cp "$FALLBACK_DP_PATH" "$DP_BLOCK_PATH"
      DP_SOURCE="${FALLBACK_DP_PATH#${REPO_ROOT}/}"
    fi
  fi
fi

assert_no_disposable_refs "$DP_BLOCK_PATH" "$DP_SOURCE"
if [[ -n "$ADDENDUM_ID" ]]; then
  assert_addendum_required_sections "$DP_BLOCK_PATH"
  assert_no_disposable_refs "$BASE_DP_BLOCK_PATH" "$BASE_DP_SOURCE"
  assert_dp_required_sections "$BASE_DP_BLOCK_PATH"
else
  assert_dp_required_sections "$DP_BLOCK_PATH"
fi

if [[ -n "$ADDENDUM_ID" ]]; then
  FRESHNESS_STAMP="$(trim "$(extract_dp_field_value "$BASE_DP_BLOCK_PATH" "Freshness Stamp")")"
else
  FRESHNESS_STAMP="$(trim "$(extract_dp_field_value "$DP_BLOCK_PATH" "Freshness Stamp")")"
fi
[[ -n "$FRESHNESS_STAMP" ]] || die "failed to extract Freshness Stamp from ${DP_SOURCE}"

ALLOWLIST_POINTER="$(extract_allowlist_pointer "$DP_BLOCK_PATH" || true)"
if [[ -z "$ALLOWLIST_POINTER" ]]; then
  ALLOWLIST_POINTER="storage/dp/active/allowlist.txt"
fi
load_allowlist_entries "$ALLOWLIST_POINTER"
if [[ -n "$ADDENDUM_ID" ]]; then
  SCOPE_DELTA_ADDED=()
  while IFS= read -r delta_path || [[ -n "$delta_path" ]]; do
    [[ -n "$delta_path" ]] || continue
    if [[ -z "${ALLOWLIST_ENTRIES[$delta_path]+set}" ]]; then
      ALLOWLIST_ENTRIES["$delta_path"]=1
      SCOPE_DELTA_ADDED+=("$delta_path")
    fi
  done < <(extract_addendum_scope_delta "$ADDENDUM_INTAKE_PATH")
  echo "Addendum SCOPE_DELTA Extension:"
  if (( ${#SCOPE_DELTA_ADDED[@]} > 0 )); then
    for delta_path in "${SCOPE_DELTA_ADDED[@]}"; do
      printf -- "- %s\n" "$delta_path"
    done
  else
    echo "- (none added; all delta paths already in base allowlist)"
  fi
fi

RECEIPT_BLOCK_PATH="${TMP_DIR}/receipt-block.txt"
COMMANDS_PATH="${TMP_DIR}/commands.txt"
FINAL_COMMANDS_PATH="${TMP_DIR}/commands.pre.final.txt"
FINAL_POST_COMMANDS_PATH="${TMP_DIR}/commands.post.final.txt"
if [[ -n "$ADDENDUM_ID" ]]; then
  extract_addendum_receipt_block "$DP_BLOCK_PATH" "$RECEIPT_BLOCK_PATH"
else
  extract_receipt_block "$DP_BLOCK_PATH" "$RECEIPT_BLOCK_PATH"
fi
extract_commands "$RECEIPT_BLOCK_PATH" "$COMMANDS_PATH"
if [[ ! -s "$COMMANDS_PATH" ]]; then
  die "failed to extract verification commands from ${DP_SOURCE} section 3.4.5"
fi
build_command_plan "$COMMANDS_PATH" "$FINAL_COMMANDS_PATH" "$FINAL_POST_COMMANDS_PATH"
if [[ ! -s "$FINAL_COMMANDS_PATH" ]]; then
  die "no executable verification commands were assembled for ${DP_SOURCE}"
fi

RECEIPT_HAS_DUMP_COMMAND=0
DUMP_MANIFEST_POINTER="none"
if grep -Eq 'ops/bin/dump' "$COMMANDS_PATH"; then
  RECEIPT_HAS_DUMP_COMMAND=1
fi

run_closing_validator_negative_self_check "$ALLOWLIST_POINTER"
validate_closing_block_sidecar "$CLOSING_PATH" "$ALLOWLIST_POINTER" >/dev/null
if [[ -n "$ADDENDUM_ID" ]]; then
  ARTIFACT_PATH_VALIDATION_OUTPUT="$(validate_addendum_artifact_path_consistency "$DP_ID" "$ADDENDUM_ID")"
else
  ARTIFACT_PATH_VALIDATION_OUTPUT="$(validate_artifact_path_consistency "$DP_ID")"
  validate_surface_head_authored_for_packet "$SOP_SURFACE_PATH" "$DP_ID"
  validate_surface_head_authored_for_packet "$POW_SURFACE_PATH" "$DP_ID"
fi

TRACE_ID="$(resolve_trace_id)"

if ! INTEGRITY_OUTPUT="$(bash "$INTEGRITY_LINT" 2>&1)"; then
  printf '%s\n' "$INTEGRITY_OUTPUT" >&2
  die "integrity gate failed"
fi
INTEGRITY_OUTPUT="$(printf '%s' "$INTEGRITY_OUTPUT" | sanitize_disposable_refs)"
INTEGRITY_OUTPUT+=$'\n\n'
INTEGRITY_OUTPUT+="${ARTIFACT_PATH_VALIDATION_OUTPUT}"

NARRATIVE_SCAFFOLD_PATH="${TMP_DIR}/narrative.md"
editor_write_narrative_scaffold "$NARRATIVE_SCAFFOLD_PATH"
if [[ -n "$NARRATIVE_FILE_ARG" ]]; then
  editor_load_narrative_from_file "$NARRATIVE_FILE_ARG" "$NARRATIVE_SCAFFOLD_PATH"
else
  editor_capture_narrative_interactive "$NARRATIVE_SCAFFOLD_PATH"
fi
editor_validate_narrative_file "$NARRATIVE_SCAFFOLD_PATH"
CONTRACTOR_NARRATIVE="$(cat "$NARRATIVE_SCAFFOLD_PATH")"

COMMAND_LOG=""
CMD_INDEX=0
SURFACE_PHASE_DONE=0
VERIFICATION_COMMAND_COUNT=0
GIT_SHORT_HASH="$(git -C "$REPO_ROOT" rev-parse --short HEAD)"
register_certify_generated_surface_paths "$DP_ID" "$FRESHNESS_STAMP" "$GIT_SHORT_HASH" "$ADDENDUM_ID"
GENERATED_SURFACE_POLICY_OUTPUT="$(build_generated_surface_policy_output)"
printf '%s\n' "$GENERATED_SURFACE_POLICY_OUTPUT"
INTEGRITY_OUTPUT+=$'\n\n'"${GENERATED_SURFACE_POLICY_OUTPUT}"

CMD_INDEX=$((CMD_INDEX + 1))
