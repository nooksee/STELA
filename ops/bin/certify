bash -lc "cd \"$REPO_ROOT\" && ./ops/bin/prune --target=dump --phase=report --dry-run" </dev/null >"$PRUNE_REPORT_STDOUT_PATH" 2>"$PRUNE_REPORT_STDERR_PATH"
