  "$INVOCATION_FINISHED_AT" \
  "$INVOCATION_DURATION_SECONDS" \
  "0" \
  "Certify process initialized; invocation captured for receipt provenance." \
  "(empty)"

while IFS= read -r command || [[ -n "$command" ]]; do
  CMD_INDEX=$((CMD_INDEX + 1))
  CMD_ID="$(printf '%02d' "$CMD_INDEX")"

  STARTED_AT="$(utc_now)"
  START_EPOCH="$(date +%s)"

  STDOUT_PATH="${TMP_DIR}/cmd-${CMD_ID}.stdout"
  STDERR_PATH="${TMP_DIR}/cmd-${CMD_ID}.stderr"

  EXEC_COMMAND="$command"
  if [[ "$EXEC_COMMAND" == *"./ops/bin/draft"* \
    && "$EXEC_COMMAND" == *"--addendum="* \
    && "$EXEC_COMMAND" == *"--base-dp="* \
    && "$EXEC_COMMAND" != *"DRAFT_ALLOW_DIRTY_TREE="* ]]; then
    EXEC_COMMAND="DRAFT_ALLOW_DIRTY_TREE=1 ${EXEC_COMMAND}"
  fi
  certify_set_phase "$(certify_phase_for_command "$EXEC_COMMAND")"

  set +e
  bash -lc "cd \"$REPO_ROOT\" && ${EXEC_COMMAND}" </dev/null >"$STDOUT_PATH" 2>"$STDERR_PATH"
  EXIT_CODE=$?
  set -e

  FINISHED_AT="$(utc_now)"
  FINISH_EPOCH="$(date +%s)"
  DURATION_SECONDS=$((FINISH_EPOCH - START_EPOCH))

  STDOUT_BODY="$(cat "$STDOUT_PATH")"
  STDERR_BODY="$(cat "$STDERR_PATH")"
  maybe_capture_dump_manifest_pointer "$command" "$STDOUT_BODY"
  append_command_log_entry "$CMD_ID" "$EXEC_COMMAND" "$STARTED_AT" "$FINISHED_AT" "$DURATION_SECONDS" "$EXIT_CODE" "$STDOUT_BODY" "$STDERR_BODY"

  if [[ "$EXIT_CODE" -ne 0 ]]; then
    printf '%s' "$COMMAND_LOG" >&2
    die "verification command failed (command ${CMD_ID}): ${command}"
  fi

  if [[ "$command" =~ (^|[[:space:]])bash[[:space:]]+tools/lint/llms[.]sh([[:space:]]|$) ]]; then
    CMD_INDEX=$((CMD_INDEX + 1))
    CMD_ID="$(printf '%02d' "$CMD_INDEX")"
    NORMALIZE_STARTED_AT="$(utc_now)"
    NORMALIZE_START_EPOCH="$(date +%s)"
    NORMALIZE_STDOUT="$(normalize_unallowlisted_llms_drift)"
    NORMALIZE_FINISHED_AT="$(utc_now)"
    NORMALIZE_FINISH_EPOCH="$(date +%s)"
    NORMALIZE_DURATION_SECONDS=$((NORMALIZE_FINISH_EPOCH - NORMALIZE_START_EPOCH))
    append_command_log_entry \
      "$CMD_ID" \
      "internal: normalize unallowlisted llms outputs to HEAD (allowlist guard)" \
      "$NORMALIZE_STARTED_AT" \
      "$NORMALIZE_FINISHED_AT" \
      "$NORMALIZE_DURATION_SECONDS" \
      "0" \
      "$NORMALIZE_STDOUT" \
      "(empty)"
  fi

  VERIFICATION_COMMAND_COUNT=$((VERIFICATION_COMMAND_COUNT + 1))
  if (( SURFACE_PHASE_DONE == 0 && VERIFICATION_COMMAND_COUNT >= 3 )); then
    if [[ -z "$ADDENDUM_ID" ]]; then
      run_surface_emission_step "$TRACE_ID" "$DP_ID" "$FRESHNESS_STAMP" "$GIT_SHORT_HASH" "$DP_BLOCK_PATH"
    else
      run_surface_emission_step "$TRACE_ID" "$DP_ID" "$FRESHNESS_STAMP" "$GIT_SHORT_HASH"
    fi
    SURFACE_PHASE_DONE=1
  fi
done < "$FINAL_COMMANDS_PATH"

if (( SURFACE_PHASE_DONE == 0 )); then
  if [[ -z "$ADDENDUM_ID" ]]; then
    run_surface_emission_step "$TRACE_ID" "$DP_ID" "$FRESHNESS_STAMP" "$GIT_SHORT_HASH" "$DP_BLOCK_PATH"
  else
    run_surface_emission_step "$TRACE_ID" "$DP_ID" "$FRESHNESS_STAMP" "$GIT_SHORT_HASH"
  fi
  SURFACE_PHASE_DONE=1
fi

certify_set_phase "postflight"
CMD_INDEX=$((CMD_INDEX + 1))
CMD_ID="$(printf '%02d' "$CMD_INDEX")"
POST_INTEGRITY_STARTED_AT="$(utc_now)"
POST_INTEGRITY_START_EPOCH="$(date +%s)"
POST_INTEGRITY_STDOUT_PATH="${TMP_DIR}/post-integrity.stdout"
POST_INTEGRITY_STDERR_PATH="${TMP_DIR}/post-integrity.stderr"
set +e
bash -lc "cd \"$REPO_ROOT\" && bash tools/lint/integrity.sh" </dev/null >"$POST_INTEGRITY_STDOUT_PATH" 2>"$POST_INTEGRITY_STDERR_PATH"
POST_INTEGRITY_EXIT_CODE=$?
set -e
POST_INTEGRITY_FINISHED_AT="$(utc_now)"
POST_INTEGRITY_FINISH_EPOCH="$(date +%s)"
POST_INTEGRITY_DURATION_SECONDS=$((POST_INTEGRITY_FINISH_EPOCH - POST_INTEGRITY_START_EPOCH))
POST_INTEGRITY_STDOUT="$(cat "$POST_INTEGRITY_STDOUT_PATH")"
POST_INTEGRITY_STDERR="$(cat "$POST_INTEGRITY_STDERR_PATH")"
append_command_log_entry \
  "$CMD_ID" \
  "bash tools/lint/integrity.sh" \
  "$POST_INTEGRITY_STARTED_AT" \
  "$POST_INTEGRITY_FINISHED_AT" \
  "$POST_INTEGRITY_DURATION_SECONDS" \
  "$POST_INTEGRITY_EXIT_CODE" \
  "$POST_INTEGRITY_STDOUT" \
  "$POST_INTEGRITY_STDERR"
if [[ "$POST_INTEGRITY_EXIT_CODE" -ne 0 ]]; then
  printf '%s' "$COMMAND_LOG" >&2
  die "post-command integrity gate failed"
fi

if [[ -z "$ADDENDUM_ID" ]]; then
  CMD_INDEX=$((CMD_INDEX + 1))
  CMD_ID="$(printf '%02d' "$CMD_INDEX")"
  TASK_CONSISTENCY_STARTED_AT="$(utc_now)"
  TASK_CONSISTENCY_START_EPOCH="$(date +%s)"
  set +e
  TASK_CONSISTENCY_STDOUT="$(verify_active_task_leaf_packet_consistency)"
  TASK_CONSISTENCY_EXIT_CODE=$?
  set -e
  TASK_CONSISTENCY_FINISHED_AT="$(utc_now)"
  TASK_CONSISTENCY_FINISH_EPOCH="$(date +%s)"
  TASK_CONSISTENCY_DURATION_SECONDS=$((TASK_CONSISTENCY_FINISH_EPOCH - TASK_CONSISTENCY_START_EPOCH))
  append_command_log_entry \
