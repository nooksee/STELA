    "internal: verify active TASK leaf packet consistency" \
    "$TASK_CONSISTENCY_STARTED_AT" \
    "$TASK_CONSISTENCY_FINISHED_AT" \
    "$TASK_CONSISTENCY_DURATION_SECONDS" \
    "$TASK_CONSISTENCY_EXIT_CODE" \
    "$TASK_CONSISTENCY_STDOUT" \
    "(empty)"
  if [[ "$TASK_CONSISTENCY_EXIT_CODE" -ne 0 ]]; then
    printf '%s' "$COMMAND_LOG" >&2
    die "active TASK packet-consistency check failed"
  fi
fi

CMD_INDEX=$((CMD_INDEX + 1))
CMD_ID="$(printf '%02d' "$CMD_INDEX")"
ALLOWLIST_CHECK_STARTED_AT="$(utc_now)"
ALLOWLIST_CHECK_START_EPOCH="$(date +%s)"
set +e
