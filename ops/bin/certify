  TELEMETRY_PACKET_ID="${DP_ID}-ADDENDUM-${ADDENDUM_ID}"
fi

TELEMETRY_LEAF="$(
  emit_telemetry_leaf \
    "$TRACE_ID" \
    "$TELEMETRY_PACKET_ID" \
    "$CERTIFIED_AT" \
    "${OUT_PATH#${REPO_ROOT}/}" \
    "$BRANCH" \
    "$GIT_HASH" \
    "$RESULTS_DP_SOURCE" \
    "$CERTIFY_TOTAL_DURATION_SECONDS" \
    "$CERTIFY_PHASE_SUMMARY_OUTPUT" \
    "$CERTIFY_LONG_POLE_SUMMARY_OUTPUT"
)"

echo "DP replay source: ${DP_SOURCE}"
echo "DP source: ${RESULTS_DP_SOURCE}"
echo "RESULTS saved: ${OUT_PATH#${REPO_ROOT}/}"
echo "${DP_PACKET_MOVE_OUTPUT}"
echo "Telemetry leaf: ${TELEMETRY_LEAF}"
