  INTEGRITY_OUTPUT+="${RESULTS_LINT_STDERR}"
fi
INTEGRITY_OUTPUT+=$'\n'
INTEGRITY_OUTPUT+="${TEMPLATE_STRUCTURE_OUTPUT}"$'\n'
INTEGRITY_OUTPUT+="${HASH_PARITY_OUTPUT}"$'\n'
INTEGRITY_OUTPUT+="${SLOT_TOKEN_CHECK_OUTPUT}"

RESULTS_ALLOWLIST_POINTER="$ALLOWLIST_POINTER"
RESULTS_ALLOWLIST_POINTER+=$'\n'"- dp_source: ${RESULTS_DP_SOURCE}"
RESULTS_ALLOWLIST_POINTER+=$'\n'"- dump_manifest: ${DUMP_MANIFEST_POINTER}"

"$TEMPLATE_BIN" render results --out="$OUT_PATH" \
  "--slot=DP_ID=${DP_ID}" \
  "--slot=CERTIFIED_AT=${CERTIFIED_AT}" \
  "--slot=BRANCH=${BRANCH}" \
  "--slot=GIT_HASH=${GIT_HASH}" \
  "--slot=ALLOWLIST_POINTER=${RESULTS_ALLOWLIST_POINTER}" \
  "--slot=INTEGRITY_OUTPUT=${INTEGRITY_OUTPUT}" \
  "--slot=COMMAND_LOG=${COMMAND_LOG}" \
  "--slot=DIFF_NAME_ONLY=${DIFF_NAME_ONLY}" \
  "--slot=DIFF_STAT=${DIFF_STAT}" \
  "--slot=CONTRACTOR_NARRATIVE=${CONTRACTOR_NARRATIVE}"
assert_no_disposable_refs "$OUT_PATH" "${OUT_PATH#${REPO_ROOT}/}"
bash "$RESULTS_LINT" "$OUT_PATH"
DP_PACKET_MOVE_OUTPUT="DP lineage leaf emission: not applicable (base packet uses TASK leaf chain)"
if [[ -n "$ADDENDUM_ID" ]]; then
  DP_PACKET_MOVE_OUTPUT="$(emit_addendum_lineage_leaf "$DP_ID" "$DP_BLOCK_PATH" "$GIT_SHORT_HASH")"
fi

certify_finalize_phase_timing
CERTIFY_TOTAL_DURATION_SECONDS=$(( $(date +%s) - CERTIFY_RUN_STARTED_EPOCH ))
CERTIFY_PHASE_SUMMARY_OUTPUT="$(build_phase_summary_output)"
