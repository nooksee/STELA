#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
# shellcheck source=/dev/null
source "${REPO_ROOT}/ops/lib/scripts/common.sh"

format="chatgpt"
intent=""
dp="(none)"
out=""
tag=""

usage() {
  cat <<'USAGE'
Usage: ops/bin/open [--format=chatgpt|gemini] [--intent="..."] [--dp="DP-XXXX / YYYY-MM-DD"] [--out=auto] [--tag=token]
USAGE
}

generate_trace_id() {
  local stamp
  local suffix
  stamp="$(date -u '+%Y%m%dT%H%M%SZ')"
  suffix="$(printf '%04x%04x' "$RANDOM" "$RANDOM")"
  printf 'stela-%s-%s' "$stamp" "$suffix"
}

for arg in "$@"; do
  case "$arg" in
    --format=chatgpt|--format=gemini)
      format="${arg#--format=}"
      ;;
    --intent=*)
      intent="${arg#--intent=}"
      ;;
    --dp=*)
      dp="${arg#--dp=}"
      ;;
    --out=auto)
      out="auto"
      ;;
    --tag=*)
      tag="${arg#--tag=}"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown arg: $arg"
      ;;
  esac
done

trap 'emit_binary_leaf "open" "finish"' EXIT
emit_binary_leaf "open" "start"

branch="$(git rev-parse --abbrev-ref HEAD)"
head_short="$(git rev-parse --short HEAD)"
branch_safe="${branch//\//-}"
STELA_TRACE_ID="$(generate_trace_id)"

tag_prefix=""
if [[ -n "$tag" ]]; then
  tag_prefix="${tag}-"
fi

status_summary="clean"
porcelain_count=0
porcelain_output=""
porcelain_preview=""
porcelain_path="storage/handoff/OPEN-PORCELAIN-${tag_prefix}${branch_safe}-${head_short}.txt"
porcelain_saved="(suppressed: clean working tree)"
porcelain_artifact_note="suppressed (clean working tree)"

porcelain_raw="$(git status --porcelain || true)"
porcelain_normalized=""

if [[ -n "$porcelain_raw" ]]; then
  porcelain_normalized="$(printf "%s\n" "$porcelain_raw" | sed -E 's/^[[:space:]]+//')"
  porcelain_count="$(printf "%s\n" "$porcelain_normalized" | wc -l | tr -d '[:space:]')"
  status_summary="dirty"
  porcelain_saved="$porcelain_path"
  porcelain_artifact_note="emitted"
  printf "%s\n" "$porcelain_normalized" > "$porcelain_saved"

  if (( porcelain_count <= 200 )); then
    porcelain_output="$porcelain_normalized"
  else
    porcelain_preview="$(printf "%s\n" "$porcelain_normalized" | head -n 50)"
  fi
fi

last_commit="$(git log -1 --oneline)"

open_out_path="storage/handoff/OPEN-${tag_prefix}${branch_safe}-${head_short}.txt"
: > "$open_out_path"

required_files=(
  "PoT.md"
  "SoP.md"
  "PoW.md"
  "TASK.md"
  "docs/INDEX.md"
  "docs/MANUAL.md"
  "docs/MAP.md"
  "ops/lib/manifests/CONTEXT.md"
)

missing=()
for path in "${required_files[@]}"; do
  if [[ ! -f "$path" ]]; then
    missing+=("$path")
  fi
done

if (( ${#missing[@]} > 0 )); then
  echo "ERROR: expected files missing. Run from repo root." >&2
  for path in "${missing[@]}"; do
    echo "  - $path" >&2
  done
  exit 1
fi

if [[ "$format" == "gemini" ]]; then
  mode_line="Mode: reviewer stance. Prioritize risks, regressions, and missing tests."
else
  mode_line="Mode: collaborator stance. Follow repo canon and request missing context."
fi

emit() {
  if [[ -n "$open_out_path" ]]; then
    tee -a "$open_out_path"
  else
    cat
  fi
}

{
  cat <<EOF
===== OPEN PROMPT =====

Stela OPEN PROMPT

Adhere to the Behavioral Logic Standards defined in PoT.md.
$mode_line

[FRESHNESS GATE]
- Active branch: $branch
- HEAD short hash: $head_short
- DP id/date (if applicable): $dp
- Intent for today: $intent
- STELA_TRACE_ID: $STELA_TRACE_ID

[ROLE CONTRACT]
Integrator (operator): Owns scope, priorities, and approvals.
Contractor (assistant): Executes tasks, flags risks, asks when blocked.
AI stance: Canon-first, explicit about unknowns, no invention.

[DO / DO NOT]
Do:
- PR-only changes; no main edits.
- Run required gates before close.
Do not:
- Edit main directly.
- Skip gates.

[CONSTITUTION / FOCUS]
- PoT.md

[PRIMARY WORK SURFACE]
- TASK.md (DP template + active work log)
- TASK does NOT auto-load unless it is included in your dump/attachments.
- When drafting a DP: follow TASK headings/order; output only the DP; ask if required fields are missing.

[CANON POINTERS]
- PoT.md
- SoP.md
- PoW.md
- TASK.md
- docs/INDEX.md
- docs/MANUAL.md
- docs/MAP.md
- ops/lib/manifests/CONTEXT.md

[DUMP]
- If you need full repo context, run: ./ops/bin/dump --scope=core --format=chatgpt (or gemini).
- For a file output: ./ops/bin/dump --scope=core --format=chatgpt --out=auto
- If factory content is intentionally in scope: ./ops/bin/dump --scope=platform --format=chatgpt --out=auto
- For factory-only inspection: ./ops/bin/dump --scope=factory --format=chatgpt --out=auto

[GIT STATE]
- Working tree: $status_summary
- Porcelain entries: $porcelain_count
- Porcelain artifact: $porcelain_artifact_note
- Porcelain saved: $porcelain_saved
- Last commit: $last_commit
EOF

if [[ "$status_summary" == "dirty" ]]; then
  if (( porcelain_count <= 200 )); then
    cat <<EOF
- Porcelain (git status --porcelain):
$porcelain_output
EOF
  else
    cat <<EOF
- Porcelain preview (truncated to 50 lines):
$porcelain_preview
EOF
  fi
fi

  cat <<EOF

[NEXT OPERATOR MOVES]
- ./ops/bin/bundle --profile=auto --out=auto
- ./ops/bin/dump --scope=core --format=chatgpt

[OPERATOR CONTEXT]
- If any canon pointers are missing, say so.

===== END OPEN PROMPT =====
EOF
} | emit

# IMPORTANT: do not append this line into the OPEN artifact.
if [[ "$out" == "auto" ]]; then
  printf 'OPEN saved: %s\n' "$open_out_path"
fi
