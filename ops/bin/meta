#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
# shellcheck source=/dev/null
source "${REPO_ROOT}/ops/lib/scripts/common.sh"

if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
  die "git repo not found. Run from repo root."
fi

if [[ "$(pwd -P)" != "$REPO_ROOT" ]]; then
  die "Run from repo root: $REPO_ROOT"
fi

project_name="${1:-}"
if [[ -z "$project_name" ]]; then
  die "project name is required"
fi
if [[ $# -ne 1 ]]; then
  die "usage: ops/bin/meta <project-name>"
fi

project_dir="$repo_root/projects/$project_name"
if [[ ! -d "$project_dir" ]]; then
  die "project not found: projects/$project_name"
fi

trap 'emit_binary_leaf "meta" "finish"' EXIT
emit_binary_leaf "meta" "start"

"$REPO_ROOT/ops/bin/open" --intent="Project context: $project_name" --tag="project-$project_name" --out=auto >/dev/null
"$REPO_ROOT/ops/bin/dump" --scope=project --project="$project_name" --format=chatgpt --out=auto >/dev/null

echo "project context generated: $project_name"
