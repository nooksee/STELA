#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
SOP_FILE="${REPO_ROOT}/SoP.md"
TASK_FILE="${REPO_ROOT}/TASK.md"
ARCHIVE_DIR="${REPO_ROOT}/storage/archives/root"
HANDOFF_DIR="${REPO_ROOT}/storage/handoff"
TMP_DIR="${REPO_ROOT}/storage/tmp"
THRESHOLD=30
DP_TARGET=""
SCRUB=0
RESET_TASK=0
RESULTS_GUARD_FATAL="SAFETY VIOLATION: Uncommitted Results artifact detected. Commit or stash before pruning."

usage() {
  cat <<'USAGE'
Usage: ops/bin/prune [--dp=DP-ID] [--scrub] [--reset-task]
USAGE
}

for arg in "$@"; do
  case "$arg" in
    --dp=*)
      DP_TARGET="${arg#--dp=}"
      ;;
    --scrub)
      SCRUB=1
      ;;
    --reset-task)
      RESET_TASK=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "ERROR: Unknown arg: ${arg}" >&2
      exit 1
      ;;
  esac
done

if [[ -n "${DP_TARGET}" && -z "${DP_TARGET// }" ]]; then
  echo "ERROR: --dp requires a non-empty value" >&2
  exit 1
fi

if [[ ! -f "${SOP_FILE}" ]]; then
  echo "ERROR: SoP.md not found at ${SOP_FILE}" >&2
  exit 1
fi

mkdir -p "${TMP_DIR}"

clean_storage_tmp() {
  if [[ ! -d "${TMP_DIR}" ]]; then
    return 0
  fi

  local removed=0
  while IFS= read -r -d '' item; do
    base="$(basename "$item")"
    if [[ "${base}" == ".gitignore" ]]; then
      continue
    fi
    rm -rf "$item"
    removed=$((removed + 1))
  done < <(find "${TMP_DIR}" -mindepth 1 -maxdepth 1 -print0)

  echo "storage/tmp cleanup: removed ${removed} item(s)."
}

results_guard_violation() {
  echo "${RESULTS_GUARD_FATAL}" >&2
  exit 1
}

ensure_results_artifacts_committed_and_clean() {
  local -a candidates=()
  local result_file
  local rel_path

  if [[ -n "${DP_TARGET}" ]]; then
    candidates+=("${HANDOFF_DIR}/${DP_TARGET}-RESULTS.md")
  else
    if [[ ! -d "${HANDOFF_DIR}" ]]; then
      return 0
    fi
    while IFS= read -r -d '' result_file; do
      candidates+=("${result_file}")
    done < <(find "${HANDOFF_DIR}" -maxdepth 1 -type f -name '*-RESULTS.md' -print0)
  fi

  for result_file in "${candidates[@]}"; do
    if [[ ! -f "${result_file}" ]]; then
      continue
    fi

    rel_path="${result_file#${REPO_ROOT}/}"
    if ! git -C "${REPO_ROOT}" ls-files --error-unmatch -- "${rel_path}" >/dev/null 2>&1; then
      results_guard_violation
    fi
    if ! git -C "${REPO_ROOT}" diff --quiet -- "${rel_path}"; then
      results_guard_violation
    fi
    if ! git -C "${REPO_ROOT}" diff --cached --quiet -- "${rel_path}"; then
      results_guard_violation
    fi
  done
}

ensure_task_work_log_clear() {
  if [[ ! -f "${TASK_FILE}" ]]; then
    echo "ERROR: TASK.md not found at ${TASK_FILE}" >&2
    return 1
  fi

  local marker="(No active thread)"
  local issue
  local rc

  if issue="$(awk -v marker="$marker" '
    BEGIN { in_log=0; found=0 }
    /^## 5\. Work Log/ { in_log=1; next }
    {
      if (!in_log) { next }
      if ($0 ~ /^[[:space:]]*$/) { next }
      if (!found && $0 == marker) { found=1; next }
      print $0
      exit 1
    }
    END {
      if (!in_log) { exit 2 }
      if (!found) { exit 3 }
    }
  ' "${TASK_FILE}")"; then
    return 0
  else
    rc=$?
  fi

  case "$rc" in
    1)
      echo "ERROR: TASK.md Work Log is not reset. Closeout Cycle Step 4 (Log) must migrate the Work Log and reset Section 5 before --reset-task. First non-empty entry: ${issue}" >&2
      ;;
    2)
      echo "ERROR: TASK.md Work Log section missing. Closeout Cycle Step 4 (Log) must reset Section 5 before --reset-task." >&2
      ;;
    3)
      echo "ERROR: TASK.md Work Log missing baseline marker: ${marker}. Closeout Cycle Step 4 (Log) must reset Section 5 before --reset-task." >&2
      ;;
    *)
      echo "ERROR: TASK.md Work Log check failed. Closeout Cycle Step 4 (Log) must reset Section 5 before --reset-task." >&2
      ;;
  esac
  return 1
}

scrub_task() {
  if [[ ! -f "${TASK_FILE}" ]]; then
    echo "ERROR: TASK.md not found at ${TASK_FILE}" >&2
    return 1
  fi

  local tmp_task
  tmp_task="$(mktemp "${TMP_DIR}/task-scrub.XXXXXX")"

  awk -v base_head="0000000" -v branch="main" -v work_branch="work/dp-ops-XXXX-YYYY-MM-DD" -v pointer="Session context output (generated by ops/bin/open)" -v prompt="Populate during execution; do not pre-fill in TASK.md." -v receipt_open="- ./ops/bin/open --out=auto --dp=\"DP-OPS-XXXX\"" -v receipt_dump="- ./ops/bin/dump --scope=platform --format=chatgpt --out=auto --bundle" -v receipt_zero="- Zero-byte check: test -s <dump_payload_path>" -v receipt_diff_one="- git diff --name-only" -v receipt_diff_two="- git diff --stat" -v receipt_pasted="- Required pasted outputs: receipts, verification outcomes, and diff output." -v receipt_closing="- Mandatory Closing Block required in RESULTS." '
    BEGIN {
      in_closeout=0
      skip_payload=0
      in_scope=0
      skip_scope=0
      in_plan=0
      skip_plan=0
      in_session_state=0
      in_legacy_gate_artifacts=0
      in_legacy_gate_commands=0
    }
    function emit_prompt() {
      print prompt
      print ""
    }
    /^## 5\. Work Log($|[[:space:]]*\(Timestamped Continuity\))/ {
      print
      print "(No active thread)"
      exit
    }
    /^### DP-/ {
      print "### DP-XXXX: (Template)"
      next
    }
    /^## 1\. Session State/ {
      in_session_state=1
      print
      next
    }
    /^## 2\./ {
      in_session_state=0
      print
      next
    }
    /^[[:space:]]*Pointer:/ {
      print "Pointer: " pointer
      next
    }
    /^[[:space:]]*Active Branch:/ {
      if (in_session_state) {
        next
      }
      print
      next
    }
    /^[[:space:]]*Base HEAD:/ {
      if (in_session_state) {
        next
      }
      print "Base HEAD: " base_head " (Must match session context output)"
      next
    }
    /^[[:space:]]*Base Branch:/ {
      print "Base Branch: " branch
      next
    }
    /^[[:space:]]*Required Work Branch:/ {
      print "Required Work Branch: " work_branch
      next
    }
    /^[[:space:]]*Gate Artifacts \(Must Match\):/ {
      in_legacy_gate_artifacts=1
      next
    }
    in_legacy_gate_artifacts {
      if ($0 ~ /^[[:space:]]*Preconditions:/) {
        in_legacy_gate_artifacts=0
        print
      }
      next
    }
    /^[[:space:]]*Gate Commands \(Must Pass\):/ {
      in_legacy_gate_commands=1
      next
    }
    in_legacy_gate_commands {
      if ($0 ~ /^### 3\.2 /) {
        in_legacy_gate_commands=0
        print
      }
      next
    }
    /^[[:space:]]*[-*][[:space:]]*If any artifact filename hash does not equal Base HEAD, regenerate artifacts and stop\./ {
      next
    }
    /^[[:space:]]*[-*][[:space:]]*Mandatory artifacts \(every execution, no exceptions\):/ {
      next
    }
    /^[[:space:]]*[-*][[:space:]]*If Base HEAD changes, regenerate gate artifacts and update this gate before proceeding\./ {
      print "- If Base HEAD changes, regenerate session artifacts from canonical tools before proceeding."
      next
    }
    /^[[:space:]]*Mandatory Closing Block/ {
      in_closeout=1
      skip_payload=0
      print
      next
    }
    /^## 4\.1 Thread Transition/ {
      in_closeout=0
      skip_payload=0
      in_scope=0
      skip_scope=0
      in_plan=0
      skip_plan=0
      print
      next
    }
    /^### 3\.3 / {
      in_scope=1
      skip_scope=0
      print
      next
    }
    /^### 3\.4 / {
      in_scope=0
      skip_scope=0
      in_plan=1
      skip_plan=1
      print
      print ""
      next
    }
    /^## 4\./ {
      in_scope=0
      skip_scope=0
      in_plan=0
      skip_plan=0
      print
      next
    }
    {
      if (in_scope) {
        if ($0 ~ /^[[:space:]]*Objective:/) {
          print "Objective: " prompt
          skip_scope=1
          next
        }
        if ($0 ~ /^[[:space:]]*In scope:/) {
          print "In scope: " prompt
          skip_scope=1
          next
        }
        if ($0 ~ /^[[:space:]]*Out of scope:/) {
          print "Out of scope: " prompt
          skip_scope=1
          next
        }
        if ($0 ~ /^[[:space:]]*Safety and invariants:/) {
          print "Safety and invariants: " prompt
          print ""
          skip_scope=1
          next
        }
        if ($0 ~ /^[[:space:]]*Target Files allowlist \(hard gate\):/) {
          print $0
          print "- " prompt
          print ""
          skip_scope=1
          next
        }
        if (skip_scope) {
          next
        }
        next
      }
      if (in_plan) {
        if ($0 ~ /^#### 3\.4\.1 /) { print $0; emit_prompt(); skip_plan=1; next }
        if ($0 ~ /^#### 3\.4\.2 /) { print $0; emit_prompt(); skip_plan=1; next }
        if ($0 ~ /^#### 3\.4\.3 /) { print $0; emit_prompt(); skip_plan=1; next }
        if ($0 ~ /^#### 3\.4\.4 /) { print $0; emit_prompt(); skip_plan=1; next }
        if ($0 ~ /^#### 3\.4\.5 /) {
          print $0
          print receipt_open
          print receipt_dump
          print receipt_zero
          print receipt_diff_one
          print receipt_diff_two
          print receipt_pasted
          print receipt_closing
          print ""
          skip_plan=1
          next
        }
        if (skip_plan) {
          next
        }
      }
      if (in_closeout) {
        if ($0 ~ /^[[:space:]]*Primary Commit Header/) {
          print $0
          print ""
          skip_payload=1
          next
        }
        if ($0 ~ /^[[:space:]]*Pull Request Title/) {
          print $0
          print ""
          skip_payload=1
          next
        }
        if ($0 ~ /^[[:space:]]*Pull Request Description/) {
          print $0
          print ""
          skip_payload=1
          next
        }
        if ($0 ~ /^[[:space:]]*Final Squash Stub/) {
          print $0
          print ""
          skip_payload=1
          next
        }
        if ($0 ~ /^[[:space:]]*Extended Technical Manifest/) {
          print $0
          print ""
          skip_payload=1
          next
        }
        if ($0 ~ /^[[:space:]]*Review Conversation Starter/) {
          print $0
          print ""
          skip_payload=1
          next
        }
        if (skip_payload) {
          next
        }
      }
      print
    }
  ' "${TASK_FILE}" > "${tmp_task}"

  if ! (cd "${REPO_ROOT}" && bash tools/lint/task.sh "${tmp_task}"); then
    echo "ERROR: Scrubbed TASK output failed TASK lint; refusing to overwrite TASK.md." >&2
    rm -f "${tmp_task}"
    return 1
  fi

  mv "${tmp_task}" "${TASK_FILE}"
  echo "Scrubbed TASK.md to template baseline."
}

ensure_results_artifacts_committed_and_clean

entry_count="$(grep -cE '^## [0-9]{4}-[0-9]{2}-[0-9]{2} ' "${SOP_FILE}" || true)"

if [[ -z "${entry_count}" ]]; then
  entry_count=0
fi

echo "SoP entries: ${entry_count}"

if (( entry_count > THRESHOLD )); then
  mkdir -p "${ARCHIVE_DIR}"
  tmp_keep="$(mktemp "${TMP_DIR}/sop-keep.XXXXXX")"

  awk -v threshold="${THRESHOLD}" -v keep_file="${tmp_keep}" -v archive_dir="${ARCHIVE_DIR}" '
    BEGIN { entry=0; archive_file="" }
    /^## [0-9]{4}-[0-9]{2}-[0-9]{2} / {
      entry++
      if (entry > threshold) {
        match($0, /^## ([0-9]{4})-([0-9]{2})-([0-9]{2})/, parts)
        archive_file = archive_dir "/SoP-archive-" parts[1] "-" parts[2] ".md"
      }
    }
    {
      if (entry <= threshold) {
        print $0 >> keep_file
      } else {
        print $0 >> archive_file
      }
    }
  ' "${SOP_FILE}"

  mv "${tmp_keep}" "${SOP_FILE}"
  echo "Archived entries beyond ${THRESHOLD}."
else
  echo "SoP within threshold (${THRESHOLD})."
fi

if [[ -n "${DP_TARGET}" ]]; then
  echo "Pruning artifacts for Dispatch Packet: ${DP_TARGET}"
  deleted=0
  for dir in "${HANDOFF_DIR}" "${REPO_ROOT}/storage/dumps"; do
    if [[ ! -d "${dir}" ]]; then
      continue
    fi
    while IFS= read -r -d '' file; do
      base="$(basename "${file}")"
      if [[ "${base}" == ".gitkeep" ]]; then
        continue
      fi
      rm -f "${file}"
      echo "Deleted: ${file}"
      deleted=$((deleted + 1))
    done < <(find "${dir}" -type f -name "*${DP_TARGET}*" ! -name '.gitkeep' -print0)
  done
  if (( deleted == 0 )); then
    echo "No artifacts found for ${DP_TARGET}."
  else
    echo "Removed ${deleted} artifacts."
  fi
else
  if [[ -d "${HANDOFF_DIR}" ]]; then
    dp_id="${DP_ID:-}"
    if [[ -z "${dp_id}" && -f "${TASK_FILE}" ]]; then
      dp_id="$(awk '
        $0 ~ /^## 3\\. Current Dispatch Packet \\(DP\\)/ { in_dp=1; next }
        in_dp && /^## / { exit }
        in_dp && /^### DP-/ {
          line=$0
          sub(/^### /, "", line)
          sub(/:.*/, "", line)
          print line
          exit
        }
      ' "${TASK_FILE}")"
    fi

    deleted=0
    kept=0

    while IFS= read -r -d '' file; do
      base="$(basename "${file}")"
      if [[ "${base}" == ".gitkeep" ]]; then
        continue
      fi
      if [[ -n "${dp_id}" && "${base}" == *"${dp_id}"* ]]; then
        kept=$((kept + 1))
        continue
      fi
      rm -f "${file}"
      deleted=$((deleted + 1))
    done < <(find "${HANDOFF_DIR}" -type f -mtime +7 ! -name '.gitkeep' -print0)

    echo "Handoff cleanup: deleted ${deleted}, kept ${kept}."
  fi
fi

if (( RESET_TASK )); then
  ensure_task_work_log_clear
  scrub_task
fi

if (( SCRUB )); then
  clean_storage_tmp
fi

if (( SCRUB || RESET_TASK )); then
  echo "Routing scrub complete."
fi
