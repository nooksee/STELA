#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
source "${SCRIPT_DIR}/../lib/scripts/common.sh"
source "${SCRIPT_DIR}/../lib/scripts/ledger.sh"

SOP_PATH="${REPO_ROOT}/SoP.md"
POW_PATH="${REPO_ROOT}/PoW.md"
RESUME_DIR="${REPO_ROOT}/var/tmp"
POLICY_PATH="${REPO_ROOT}/ops/etc/retention.manifest"
PERSISTENCE_POLICY_PATH="${REPO_ROOT}/ops/etc/persistence.manifest"
TARGET="sop"
DRY_RUN=0
SCRUB=0
PHASE=""
APPROVE_TOKEN=""
USE_QUARANTINE=0
QUARANTINE_PATH_OVERRIDE=""
RESULTS_GUARD_FATAL="SAFETY VIOLATION: Uncommitted Results artifact detected. Commit or stash before pruning."
POW_GUARD_FATAL="SAFETY VIOLATION: PoW prune requires committed RESULTS/OPEN/DUMP receipt pointers in prune-candidate entries."

POLICY_DEFAULT_PHASE=""
POLICY_APPLY_TOKEN=""
HIGH_WATERMARK=0
LOW_WATERMARK=0
TARGET_SOP_TIER=""
TARGET_POW_TIER=""
WEIGHT_OPERATIONAL=1
WEIGHT_HISTORICAL=1
POLICY_QUARANTINE_PATH=""

declare -a CRITICAL_PATTERNS=()
declare -a DENYLIST_PATTERNS=()
declare -a STORAGE_REPORT_CLASS_NAMES=()
declare -A STORAGE_REPORT_CLASS_PATTERNS=()
declare -A STORAGE_REPORT_CLASS_TIERS=()
declare -A STORAGE_REPORT_CLASS_WEIGHTS=()
declare -a DUMP_REPORT_CLASS_NAMES=()
declare -A DUMP_REPORT_CLASS_PATTERNS=()
declare -A DUMP_REPORT_CLASS_TIERS=()
declare -A DUMP_REPORT_CLASS_WEIGHTS=()
declare -A DUMP_REPORT_CLASS_RETENTION=()
declare -A DUMP_REPORT_CLASS_APPLY=()
declare -a REPO_REPORT_CLASS_NAMES=()
declare -A REPO_REPORT_CLASS_PATTERNS=()
declare -A REPO_REPORT_CLASS_TIERS=()
declare -A REPO_REPORT_CLASS_WEIGHTS=()
declare -A REPO_REPORT_CLASS_RETENTION=()

usage() {
  cat <<'USAGE'
Usage: ops/bin/prune [--target=sop|pow|both|storage|dump] [--phase=report|apply] [--approve=TOKEN]
                    [--dry-run] [--scrub] [--quarantine] [--quarantine-path=PATH]

Notes:
- report phase is non-mutating and is the default from policy.
- apply phase requires --approve token that matches PRUNE policy.
- storage target is report-only in this slice.
- dump target reports dump-visible pressure and allows bounded apply only for dump-visible disposable classes.
USAGE
}

guard_fail() { echo "$1" >&2; exit 1; }

resolve_surface_leaf() {
  local path="$1" raw=""
  [[ -f "$path" ]] && raw="$(normalize_path_token "$(tr -d '\r' < "$path")")"
  if [[ "$raw" == archives/surfaces/*.md && -f "${REPO_ROOT}/${raw}" ]]; then
    echo "${REPO_ROOT}/${raw}"
  else
    echo "$path"
  fi
}

results_guard() {
  local rel
  local -a tracked_receipts=()
  mapfile -t tracked_receipts < <(
    git -C "${REPO_ROOT}" ls-files -- \
      'storage/handoff/*-RESULTS.md' \
      'storage/handoff/CLOSING-DP-OPS-*.md'
  )

  for rel in "${tracked_receipts[@]}"; do
    [[ -n "$rel" ]] || continue
    git -C "${REPO_ROOT}" ls-files --error-unmatch -- "${rel}" >/dev/null 2>&1 || guard_fail "${RESULTS_GUARD_FATAL}"
    git -C "${REPO_ROOT}" diff --quiet -- "${rel}" || guard_fail "${RESULTS_GUARD_FATAL}"
    git -C "${REPO_ROOT}" diff --cached --quiet -- "${rel}" || guard_fail "${RESULTS_GUARD_FATAL}"
  done
}

clean_state_guard() {
  if ! git -C "${REPO_ROOT}" diff --quiet; then
    guard_fail "SAFETY VIOLATION: apply phase requires clean tracked unstaged state."
  fi
  if ! git -C "${REPO_ROOT}" diff --cached --quiet; then
    guard_fail "SAFETY VIOLATION: apply phase requires clean tracked staged state."
  fi
}

scrub_resume() {
  local item removed=0
  [[ -d "${RESUME_DIR}" ]] || return 0
  while IFS= read -r -d '' item; do
    if (( DRY_RUN )); then
      echo "DRY-RUN scrub: ${item#${REPO_ROOT}/}"
      continue
    fi
    rm -rf "$item"
    removed=$((removed + 1))
  done < <(find "${RESUME_DIR}" -mindepth 1 -maxdepth 1 ! -name '.gitkeep' -print0 | sort -z)

  if (( ! DRY_RUN )); then
    echo "var/tmp cleanup: removed ${removed} item(s)."
  fi
}

policy_scalar() {
  local key="$1"
  local value
  value="$(awk -F'=' -v key="$key" '$1==key { print substr($0, index($0, "=") + 1); exit }' "$POLICY_PATH")"
  trim "$value"
}

policy_patterns() {
  local section_heading="$1"
  awk -v section="$section_heading" '
    $0 == section { in_section=1; next }
    in_section && /^## / { exit }
    in_section && /^pattern=/ {
      sub(/^pattern=/, "", $0)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0)
      if ($0 != "") {
        print $0
      }
    }
  ' "$POLICY_PATH"
}

require_int() {
  local name="$1"
  local value="$2"
  [[ "$value" =~ ^[0-9]+$ ]] || die "invalid integer policy value: ${name}=${value}"
}

load_prune_policy() {
  [[ -f "$POLICY_PATH" ]] || die "retention policy missing: ${POLICY_PATH#${REPO_ROOT}/}"
  [[ -f "$PERSISTENCE_POLICY_PATH" ]] || die "persistence policy missing: ${PERSISTENCE_POLICY_PATH#${REPO_ROOT}/}"

  POLICY_DEFAULT_PHASE="$(policy_scalar default_phase)"
  POLICY_APPLY_TOKEN="$(policy_scalar apply_token)"
  HIGH_WATERMARK="$(policy_scalar high_watermark)"
  LOW_WATERMARK="$(policy_scalar low_watermark)"
  TARGET_SOP_TIER="$(policy_scalar target_sop_tier)"
  TARGET_POW_TIER="$(policy_scalar target_pow_tier)"
  WEIGHT_OPERATIONAL="$(policy_scalar weight_operational)"
  WEIGHT_HISTORICAL="$(policy_scalar weight_historical)"
  POLICY_QUARANTINE_PATH="$(policy_scalar quarantine_path)"

  [[ "$POLICY_DEFAULT_PHASE" == "report" || "$POLICY_DEFAULT_PHASE" == "apply" ]] || die "invalid default_phase in retention.manifest"
  [[ -n "$POLICY_APPLY_TOKEN" ]] || die "missing apply_token in retention.manifest"

  require_int high_watermark "$HIGH_WATERMARK"
  require_int low_watermark "$LOW_WATERMARK"
  require_int weight_operational "$WEIGHT_OPERATIONAL"
  require_int weight_historical "$WEIGHT_HISTORICAL"

  (( HIGH_WATERMARK > LOW_WATERMARK )) || die "retention.manifest requires high_watermark > low_watermark"
  [[ "$TARGET_SOP_TIER" == "critical" || "$TARGET_SOP_TIER" == "operational" || "$TARGET_SOP_TIER" == "historical" ]] || die "invalid target_sop_tier in retention.manifest"
  [[ "$TARGET_POW_TIER" == "critical" || "$TARGET_POW_TIER" == "operational" || "$TARGET_POW_TIER" == "historical" ]] || die "invalid target_pow_tier in retention.manifest"

  mapfile -t CRITICAL_PATTERNS < <(policy_patterns "## Critical Patterns")
  mapfile -t DENYLIST_PATTERNS < <(policy_patterns "## Denylist")

  (( ${#CRITICAL_PATTERNS[@]} > 0 )) || die "retention.manifest missing critical patterns"
  (( ${#DENYLIST_PATTERNS[@]} > 0 )) || die "retention.manifest missing denylist patterns"
  load_storage_report_classes
  load_dump_report_classes
  load_repo_report_classes
}

collect_policy_class_rows() {
  local policy_path="$1"
  local section_heading="$2"
  awk -v section="$section_heading" '
    $0 == section { in_section=1; next }
    in_section && /^## / { exit }
    in_section {
      line=$0
      sub(/^[[:space:]]+/, "", line)
      sub(/[[:space:]]+$/, "", line)
      if (line != "" && line !~ /^#/) {
        print line
      }
    }
  ' "$policy_path"
}

load_policy_report_classes() {
  local policy_path="$1"
  local section_heading="$2"
  local names_name="$3"
  local patterns_name="$4"
  local tiers_name="$5"
  local weights_name="$6"
  local retention_name="${7:-}"
  local apply_name="${8:-}"

  local -n names_ref="$names_name"
  local -n patterns_ref="$patterns_name"
  local -n tiers_ref="$tiers_name"
  local -n weights_ref="$weights_name"
  local use_retention=0
  local use_apply=0
  if [[ -n "$retention_name" ]]; then
    use_retention=1
    local -n retention_ref="$retention_name"
  fi
  if [[ -n "$apply_name" ]]; then
    use_apply=1
    local -n apply_ref="$apply_name"
  fi

  names_ref=()
  patterns_ref=()
  tiers_ref=()
  weights_ref=()
  if (( use_retention )); then
    retention_ref=()
  fi
  if (( use_apply )); then
    apply_ref=()
  fi

  while IFS= read -r raw_line; do
    [[ -n "$raw_line" ]] || continue
    local class_name="" pattern="" tier="" weight="" retention="" apply="" field field_key field_value
    IFS='|' read -ra fields <<< "$raw_line"
    for field in "${fields[@]}"; do
      field_key="${field%%=*}"
      field_value="${field#*=}"
      field_key="$(trim "$field_key")"
      field_value="$(trim "$field_value")"
      case "$field_key" in
        class) class_name="$field_value" ;;
        pattern) pattern="$field_value" ;;
        tier) tier="$field_value" ;;
        weight) weight="$field_value" ;;
        retention) retention="$field_value" ;;
        apply) apply="$field_value" ;;
      esac
    done

    [[ -n "$class_name" ]] || die "retention.manifest class missing class field in ${section_heading}"
    [[ -n "$pattern" ]] || die "retention.manifest class missing pattern field (${class_name})"
    [[ "$tier" == "critical" || "$tier" == "operational" || "$tier" == "historical" ]] || die "retention.manifest class has invalid tier (${class_name})"
    require_int "${section_heading}:${class_name}:weight" "$weight"
    if (( use_retention )); then
      [[ "$retention" == "canonical" || "$retention" == "disposable" ]] || die "retention.manifest class has invalid retention (${class_name})"
    fi
    if (( use_apply )); then
      [[ "$apply" == "0" || "$apply" == "1" ]] || die "retention.manifest class has invalid apply flag (${class_name})"
    fi

    names_ref+=("$class_name")
    patterns_ref["$class_name"]="$pattern"
    tiers_ref["$class_name"]="$tier"
    weights_ref["$class_name"]="$weight"
    if (( use_retention )); then
      retention_ref["$class_name"]="$retention"
    fi
    if (( use_apply )); then
      apply_ref["$class_name"]="$apply"
    fi
  done < <(collect_policy_class_rows "$policy_path" "$section_heading")
}

load_storage_report_classes() {
  load_policy_report_classes \
    "$POLICY_PATH" \
    "## Storage Report Classes" \
    STORAGE_REPORT_CLASS_NAMES \
    STORAGE_REPORT_CLASS_PATTERNS \
    STORAGE_REPORT_CLASS_TIERS \
    STORAGE_REPORT_CLASS_WEIGHTS
}

load_dump_report_classes() {
  load_policy_report_classes \
    "$PERSISTENCE_POLICY_PATH" \
    "## Dump Report Classes" \
    DUMP_REPORT_CLASS_NAMES \
    DUMP_REPORT_CLASS_PATTERNS \
    DUMP_REPORT_CLASS_TIERS \
    DUMP_REPORT_CLASS_WEIGHTS \
    DUMP_REPORT_CLASS_RETENTION \
    DUMP_REPORT_CLASS_APPLY
}

load_repo_report_classes() {
  load_policy_report_classes \
    "$PERSISTENCE_POLICY_PATH" \
    "## Repo Pressure Classes" \
    REPO_REPORT_CLASS_NAMES \
    REPO_REPORT_CLASS_PATTERNS \
    REPO_REPORT_CLASS_TIERS \
    REPO_REPORT_CLASS_WEIGHTS \
    REPO_REPORT_CLASS_RETENTION
}

path_matches_any_pattern() {
  local path="$1"
  shift
  local pattern
  for pattern in "$@"; do
    if [[ "$path" == $pattern ]]; then
      return 0
    fi
  done
  return 1
}

denylist_guard() {
  local path="$1"
  local rel_path="${path#${REPO_ROOT}/}"
  local pattern
  for pattern in "${DENYLIST_PATTERNS[@]}"; do
    if [[ "$rel_path" == $pattern ]]; then
      guard_fail "SAFETY VIOLATION: prune target ${rel_path} matches denylist pattern ${pattern}."
    fi
  done
}

critical_guard() {
  local path="$1"
  local rel_path="${path#${REPO_ROOT}/}"
  local pattern
  for pattern in "${CRITICAL_PATTERNS[@]}"; do
    if [[ "$rel_path" == $pattern ]]; then
      guard_fail "SAFETY VIOLATION: prune target ${rel_path} matches critical pattern ${pattern}."
    fi
  done
}

weight_for_tier() {
  local tier="$1"
  case "$tier" in
    critical) echo 0 ;;
    operational) echo "$WEIGHT_OPERATIONAL" ;;
    historical) echo "$WEIGHT_HISTORICAL" ;;
    *) die "unknown tier '${tier}'" ;;
  esac
}

tier_for_target() {
  local target_key="$1"
  case "$target_key" in
    sop) echo "$TARGET_SOP_TIER" ;;
    pow) echo "$TARGET_POW_TIER" ;;
    *) die "unknown target key '${target_key}'" ;;
  esac
}

emit_candidate_report() {
  local target_key="$1"
  local tier="$2"
  local keep_count="$3"
  local ledger_file="$4"
  local action="$5"
  local weight
  local rank=0
  local total_bytes=0
  local score=0
  local entry_index=""
  local header=""
  local bytes=""

  weight="$(weight_for_tier "$tier")"

  while IFS=$'\t' read -r entry_index header bytes; do
    [[ -n "$entry_index" ]] || continue
    rank=$((rank + 1))
    score=$((weight * rank))
    total_bytes=$((total_bytes + bytes))
    echo "${action}: target=${target_key} tier=${tier} entry_index=${entry_index} score=${score} bytes=${bytes} reason=above_high_watermark"
  done < <(ledger_candidate_metrics "$ledger_file" "$keep_count")

  echo "SUMMARY: target=${target_key} tier=${tier} keep_count=${keep_count} bytes_total=${total_bytes} action=${action}"
}

emit_storage_report() {
  local class_name="" pattern="" tier="" weight="" tier_weight=""
  local class_count=0 protected_count=0 bytes_total=0 weighted_bytes=0
  local total_count=0 total_protected=0 total_bytes=0 total_weighted_bytes=0
  local rel_path="" file_bytes=0 matched_class=""
  declare -A class_counts=()
  declare -A class_protected_counts=()
  declare -A class_bytes=()

  if [[ "$PHASE" == "apply" && "$DRY_RUN" -eq 0 ]]; then
    guard_fail "SAFETY VIOLATION: storage target is report-only in this slice."
  fi

  while IFS=$'\t' read -r rel_path file_bytes; do
    [[ -n "$rel_path" ]] || continue
    matched_class=""
    for class_name in "${STORAGE_REPORT_CLASS_NAMES[@]}"; do
      pattern="${STORAGE_REPORT_CLASS_PATTERNS[$class_name]}"
      if [[ "$rel_path" == $pattern ]]; then
        matched_class="$class_name"
        break
      fi
    done
    [[ -n "$matched_class" ]] || continue

    if path_matches_any_pattern "$rel_path" "${CRITICAL_PATTERNS[@]}" || path_matches_any_pattern "$rel_path" "${DENYLIST_PATTERNS[@]}"; then
      class_protected_counts["$matched_class"]=$(( ${class_protected_counts["$matched_class"]:-0} + 1 ))
      continue
    fi

    class_counts["$matched_class"]=$(( ${class_counts["$matched_class"]:-0} + 1 ))
    class_bytes["$matched_class"]=$(( ${class_bytes["$matched_class"]:-0} + file_bytes ))
  done < <(find logs storage/dumps storage/handoff -maxdepth 1 -type f -printf '%p\t%s\n' 2>/dev/null)

  for class_name in "${STORAGE_REPORT_CLASS_NAMES[@]}"; do
    pattern="${STORAGE_REPORT_CLASS_PATTERNS[$class_name]}"
    tier="${STORAGE_REPORT_CLASS_TIERS[$class_name]}"
    weight="${STORAGE_REPORT_CLASS_WEIGHTS[$class_name]}"
    tier_weight="$(weight_for_tier "$tier")"
    class_count="${class_counts[$class_name]:-0}"
    protected_count="${class_protected_counts[$class_name]:-0}"
    bytes_total="${class_bytes[$class_name]:-0}"
    weighted_bytes=$((bytes_total * weight * tier_weight))
    total_count=$((total_count + class_count))
    total_protected=$((total_protected + protected_count))
    total_bytes=$((total_bytes + bytes_total))
    total_weighted_bytes=$((total_weighted_bytes + weighted_bytes))

    echo "REPORT: target=storage class=${class_name} tier=${tier} tier_weight=${tier_weight} class_weight=${weight} pattern=${pattern} count=${class_count} protected=${protected_count} bytes_total=${bytes_total} weighted_bytes=${weighted_bytes}"
  done

  echo "SUMMARY: target=storage action=report-only class_count=${#STORAGE_REPORT_CLASS_NAMES[@]} count_total=${total_count} protected_total=${total_protected} bytes_total=${total_bytes} weighted_bytes_total=${total_weighted_bytes}"
}

dump_inventory_stream() {
  [[ -d "${REPO_ROOT}/archives" ]] && find "${REPO_ROOT}/archives" -type f -printf 'archives/%P\t%s\n' 2>/dev/null
  [[ -d "${REPO_ROOT}/docs" ]] && find "${REPO_ROOT}/docs" -type f -printf 'docs/%P\t%s\n' 2>/dev/null
  [[ -d "${REPO_ROOT}/ops" ]] && find "${REPO_ROOT}/ops" -type f -printf 'ops/%P\t%s\n' 2>/dev/null
  [[ -d "${REPO_ROOT}/tools" ]] && find "${REPO_ROOT}/tools" -type f -printf 'tools/%P\t%s\n' 2>/dev/null
  [[ -d "${REPO_ROOT}/opt" ]] && find "${REPO_ROOT}/opt" -type f -printf 'opt/%P\t%s\n' 2>/dev/null
  [[ -d "${REPO_ROOT}/storage/handoff" ]] && find "${REPO_ROOT}/storage/handoff" -maxdepth 1 -type f \
    \( -name 'TOPIC.md' -o -name 'PLAN.md' -o -name '*-RESULTS.md' -o -name 'CLOSING-DP-OPS-*.md' \) \
    -printf 'storage/handoff/%P\t%s\n' 2>/dev/null
}

repo_pressure_inventory_stream() {
  [[ -d "${REPO_ROOT}/archives" ]] && find "${REPO_ROOT}/archives" -type f -printf 'archives/%P\t%s\n' 2>/dev/null
  [[ -d "${REPO_ROOT}/logs" ]] && find "${REPO_ROOT}/logs" -type f -printf 'logs/%P\t%s\n' 2>/dev/null
  [[ -d "${REPO_ROOT}/storage" ]] && find "${REPO_ROOT}/storage" -type f -printf 'storage/%P\t%s\n' 2>/dev/null
}

emit_policy_report_from_inventory() {
  local target_label="$1"
  local inventory_fn="$2"
  local names_name="$3"
  local patterns_name="$4"
  local tiers_name="$5"
  local weights_name="$6"
  local retention_name="${7:-}"

  local -n names_ref="$names_name"
  local -n patterns_ref="$patterns_name"
  local -n tiers_ref="$tiers_name"
  local -n weights_ref="$weights_name"
  local use_retention=0
  if [[ -n "$retention_name" ]]; then
    use_retention=1
    local -n retention_ref="$retention_name"
  fi

  local class_name="" pattern="" tier="" weight="" tier_weight="" retention="n/a"
  local class_count=0 protected_count=0 bytes_total=0 weighted_bytes=0
  local total_count=0 total_protected=0 total_bytes=0 total_weighted_bytes=0
  local rel_path="" file_bytes=0 matched_class=""
  declare -A class_counts=()
  declare -A class_protected_counts=()
  declare -A class_bytes=()
  declare -A class_top_paths=()
  declare -A class_top_bytes=()

  while IFS=$'\t' read -r rel_path file_bytes; do
    [[ -n "$rel_path" ]] || continue
    matched_class=""
    for class_name in "${names_ref[@]}"; do
      pattern="${patterns_ref[$class_name]}"
      if [[ "$rel_path" == $pattern ]]; then
        matched_class="$class_name"
        break
      fi
    done
    [[ -n "$matched_class" ]] || continue

    class_counts["$matched_class"]=$(( ${class_counts["$matched_class"]:-0} + 1 ))
    class_bytes["$matched_class"]=$(( ${class_bytes["$matched_class"]:-0} + file_bytes ))
    if (( file_bytes > ${class_top_bytes["$matched_class"]:-0} )); then
      class_top_bytes["$matched_class"]="$file_bytes"
      class_top_paths["$matched_class"]="$rel_path"
    fi

    if path_matches_any_pattern "$rel_path" "${CRITICAL_PATTERNS[@]}" || path_matches_any_pattern "$rel_path" "${DENYLIST_PATTERNS[@]}"; then
      class_protected_counts["$matched_class"]=$(( ${class_protected_counts["$matched_class"]:-0} + 1 ))
    fi
  done < <("$inventory_fn")

  for class_name in "${names_ref[@]}"; do
    pattern="${patterns_ref[$class_name]}"
    tier="${tiers_ref[$class_name]}"
    weight="${weights_ref[$class_name]}"
    if (( use_retention )); then
      retention="${retention_ref[$class_name]}"
    else
      retention="n/a"
    fi
    tier_weight="$(weight_for_tier "$tier")"
    class_count="${class_counts[$class_name]:-0}"
    protected_count="${class_protected_counts[$class_name]:-0}"
    bytes_total="${class_bytes[$class_name]:-0}"
    weighted_bytes=$((bytes_total * weight * tier_weight))
    total_count=$((total_count + class_count))
    total_protected=$((total_protected + protected_count))
    total_bytes=$((total_bytes + bytes_total))
    total_weighted_bytes=$((total_weighted_bytes + weighted_bytes))

    echo "REPORT: target=${target_label} class=${class_name} tier=${tier} tier_weight=${tier_weight} class_weight=${weight} retention=${retention} pattern=${pattern} count=${class_count} protected=${protected_count} bytes_total=${bytes_total} weighted_bytes=${weighted_bytes} top_path=${class_top_paths[$class_name]:-(none)} top_bytes=${class_top_bytes[$class_name]:-0}"
  done

  echo "SUMMARY: target=${target_label} action=report class_count=${#names_ref[@]} count_total=${total_count} protected_total=${total_protected} bytes_total=${total_bytes} weighted_bytes_total=${total_weighted_bytes}"
}

emit_dump_report() {
  emit_policy_report_from_inventory \
    "dump" \
    dump_inventory_stream \
    DUMP_REPORT_CLASS_NAMES \
    DUMP_REPORT_CLASS_PATTERNS \
    DUMP_REPORT_CLASS_TIERS \
    DUMP_REPORT_CLASS_WEIGHTS \
    DUMP_REPORT_CLASS_RETENTION

  emit_policy_report_from_inventory \
    "repo-context" \
    repo_pressure_inventory_stream \
    REPO_REPORT_CLASS_NAMES \
    REPO_REPORT_CLASS_PATTERNS \
    REPO_REPORT_CLASS_TIERS \
    REPO_REPORT_CLASS_WEIGHTS \
    REPO_REPORT_CLASS_RETENTION
}

path_matches_class_map() {
  local rel_path="$1"
  local names_name="$2"
  local patterns_name="$3"
  local -n names_ref="$names_name"
  local -n patterns_ref="$patterns_name"
  local class_name=""
  for class_name in "${names_ref[@]}"; do
    if [[ "$rel_path" == ${patterns_ref[$class_name]} ]]; then
      printf '%s' "$class_name"
      return 0
    fi
  done
  return 1
}

apply_dump_prune() {
  local action="would_remove"
  if [[ "$PHASE" == "apply" && "$DRY_RUN" -eq 0 ]]; then
    action="did_remove"
  fi

  local class_name="" rel_path="" file_bytes=0 removed_count=0 removed_bytes=0
  while IFS=$'\t' read -r rel_path file_bytes; do
    [[ -n "$rel_path" ]] || continue
    class_name="$(path_matches_class_map "$rel_path" DUMP_REPORT_CLASS_NAMES DUMP_REPORT_CLASS_PATTERNS || true)"
    [[ -n "$class_name" ]] || continue
    [[ "${DUMP_REPORT_CLASS_RETENTION[$class_name]:-canonical}" == "disposable" ]] || continue
    [[ "${DUMP_REPORT_CLASS_APPLY[$class_name]:-0}" == "1" ]] || continue
    if path_matches_any_pattern "$rel_path" "${CRITICAL_PATTERNS[@]}" || path_matches_any_pattern "$rel_path" "${DENYLIST_PATTERNS[@]}"; then
      continue
    fi
    if git -C "${REPO_ROOT}" ls-files --error-unmatch -- "${rel_path}" >/dev/null 2>&1; then
      continue
    fi

    echo "APPLY: target=dump class=${class_name} action=${action} path=${rel_path} bytes=${file_bytes}"
    removed_count=$((removed_count + 1))
    removed_bytes=$((removed_bytes + file_bytes))
    if [[ "$PHASE" == "apply" && "$DRY_RUN" -eq 0 ]]; then
      rm -f -- "${REPO_ROOT}/${rel_path}"
    fi
  done < <(dump_inventory_stream)

  echo "SUMMARY: target=dump action=${action} removed_count=${removed_count} removed_bytes=${removed_bytes}"
}

run_target() {
  local target_key="$1"
  local ledger_file="$2"
  local ledger_name="$3"
  local archive_prefix="$4"

  local tier
  tier="$(tier_for_target "$target_key")"

  local entry_count
  entry_count="$(ledger_entry_count "$ledger_file")"
  [[ -z "$entry_count" ]] && entry_count=0

  if [[ "$tier" == "critical" ]]; then
    echo "SUMMARY: target=${target_key} tier=critical action=skip reason=critical_tier"
    return 0
  fi

  if (( entry_count <= HIGH_WATERMARK )); then
    echo "SUMMARY: target=${target_key} tier=${tier} action=none reason=below_high_watermark count=${entry_count}"
    return 0
  fi

  local keep_count="$LOW_WATERMARK"
  local entry_index=""
  local results_path=""
  local open_path=""
  local dump_path=""

  if [[ "$target_key" == "pow" ]]; then
    # Validate pointer triples for rows that would be pruned.
    while IFS=$'\t' read -r entry_index results_path open_path dump_path; do
      [[ -n "$entry_index" ]] || continue
      echo "PoW candidate #${entry_index}: ${results_path} | ${open_path} | ${dump_path}"
    done < <(ledger_extract_candidates "$POW_PATH" "$SOP_PATH" "$keep_count")
  fi

  local action="would_remove"
  if [[ "$PHASE" == "apply" && "$DRY_RUN" -eq 0 ]]; then
    action="did_remove"
  fi

  emit_candidate_report "$target_key" "$tier" "$keep_count" "$ledger_file" "$action"

  if [[ "$PHASE" == "apply" && "$DRY_RUN" -eq 0 ]]; then
    denylist_guard "$ledger_file"
    critical_guard "$ledger_file"

    if (( USE_QUARANTINE )); then
      local quarantine_abs="${REPO_ROOT}/${POLICY_QUARANTINE_PATH}"
      if [[ -n "$QUARANTINE_PATH_OVERRIDE" ]]; then
        [[ "$QUARANTINE_PATH_OVERRIDE" != /* ]] || die "--quarantine-path must be repo-relative"
        quarantine_abs="${REPO_ROOT}/${QUARANTINE_PATH_OVERRIDE}"
      fi
      mkdir -p "$quarantine_abs"
      cp "$ledger_file" "$quarantine_abs/${ledger_name}-before-prune-$(date -u +%Y%m%dT%H%M%SZ).md"
      echo "Quarantine snapshot written: ${quarantine_abs#${REPO_ROOT}/}"
    fi

    ledger_prune_surface "$ledger_name" "$ledger_file" "$archive_prefix" "$keep_count"
  fi
}

for arg in "$@"; do
  case "$arg" in
    --target=sop|--target=pow|--target=both|--target=storage|--target=dump)
      TARGET="${arg#--target=}"
      ;;
    --dry-run)
      DRY_RUN=1
      ;;
    --scrub)
      SCRUB=1
      ;;
    --phase=report|--phase=apply)
      PHASE="${arg#--phase=}"
      ;;
    --approve=*)
      APPROVE_TOKEN="${arg#--approve=}"
      ;;
    --quarantine)
      USE_QUARANTINE=1
      ;;
    --quarantine-path=*)
      USE_QUARANTINE=1
      QUARANTINE_PATH_OVERRIDE="${arg#--quarantine-path=}"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown arg: ${arg}"
      ;;
  esac
done

[[ "$TARGET" == "sop" || "$TARGET" == "pow" || "$TARGET" == "both" || "$TARGET" == "storage" || "$TARGET" == "dump" ]] || die "--target must be one of: sop, pow, both, storage, dump"

SOP_PATH="$(resolve_surface_leaf "${SOP_PATH}")"
POW_PATH="$(resolve_surface_leaf "${POW_PATH}")"

trap 'emit_binary_leaf "prune" "finish"' EXIT
emit_binary_leaf "prune" "start"

load_prune_policy

if [[ -z "$PHASE" ]]; then
  PHASE="$POLICY_DEFAULT_PHASE"
fi
[[ "$PHASE" == "report" || "$PHASE" == "apply" ]] || die "--phase must be report or apply"

results_guard

if [[ "$PHASE" == "apply" && "$DRY_RUN" -eq 0 ]]; then
  [[ -n "$APPROVE_TOKEN" ]] || guard_fail "SAFETY VIOLATION: apply phase requires --approve token"
  [[ "$APPROVE_TOKEN" == "$POLICY_APPLY_TOKEN" ]] || guard_fail "SAFETY VIOLATION: invalid --approve token"
  clean_state_guard
fi

if [[ "$TARGET" == "sop" || "$TARGET" == "both" ]]; then
  run_target "sop" "$SOP_PATH" "SoP" "SoP"
fi
if [[ "$TARGET" == "pow" || "$TARGET" == "both" ]]; then
  run_target "pow" "$POW_PATH" "PoW" "PoW"
fi
if [[ "$TARGET" == "storage" ]]; then
  emit_storage_report
fi
if [[ "$TARGET" == "dump" ]]; then
  emit_dump_report
  apply_dump_prune
fi

if (( SCRUB )); then
  scrub_resume
fi

echo "Prune phase complete: phase=${PHASE} target=${TARGET} dry_run=${DRY_RUN}"
