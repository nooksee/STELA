#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
SOP_FILE="${REPO_ROOT}/SoP.md"
POW_FILE="${REPO_ROOT}/PoW.md"
TASK_FILE="${REPO_ROOT}/TASK.md"
TASK_TEMPLATE_PATH="${REPO_ROOT}/ops/src/surfaces/task.md.tpl"
TEMPLATE_BIN="${REPO_ROOT}/ops/bin/template"
ARCHIVE_DIR="${REPO_ROOT}/archives/surfaces"
HANDOFF_DIR="${REPO_ROOT}/storage/handoff"
DUMPS_DIR="${REPO_ROOT}/storage/dumps"
RESUME_DIR="${REPO_ROOT}/var/tmp"
THRESHOLD=30
DP_TARGET=""
TARGET="sop"
SCRUB=0
RESET_TASK=0
DRY_RUN=0
RESULTS_GUARD_FATAL="SAFETY VIOLATION: Uncommitted Results artifact detected. Commit or stash before pruning."
POW_GUARD_FATAL="SAFETY VIOLATION: PoW prune requires committed RESULTS/OPEN/DUMP receipt pointers in prune-candidate entries."

usage() {
  cat <<'USAGE'
Usage: ops/bin/prune [--dp=DP-ID] [--target=sop|pow|both] [--dry-run] [--scrub] [--reset-task]
USAGE
}

die() {
  echo "ERROR: $*" >&2
  exit 1
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

normalize_path_token() {
  local value
  value="$(trim "$1")"
  value="${value#\`}"; value="${value%\`}"
  value="${value#\"}"; value="${value%\"}"
  value="${value#./}"
  if [[ "$value" == "${REPO_ROOT}/"* ]]; then
    value="${value#${REPO_ROOT}/}"
  fi
  printf '%s' "$value"
}

results_guard_violation() {
  echo "${RESULTS_GUARD_FATAL}" >&2
  exit 1
}

ensure_results_artifacts_committed_and_clean() {
  local -a candidates=()
  local result_file
  local rel_path

  if [[ -n "${DP_TARGET}" ]]; then
    candidates+=("${HANDOFF_DIR}/${DP_TARGET}-RESULTS.md")
  else
    if [[ ! -d "${HANDOFF_DIR}" ]]; then
      return 0
    fi
    while IFS= read -r -d '' result_file; do
      candidates+=("${result_file}")
    done < <(find "${HANDOFF_DIR}" -maxdepth 1 -type f -name '*-RESULTS.md' -print0)
  fi

  for result_file in "${candidates[@]}"; do
    if [[ ! -f "${result_file}" ]]; then
      continue
    fi

    rel_path="${result_file#${REPO_ROOT}/}"
    if ! git -C "${REPO_ROOT}" ls-files --error-unmatch -- "${rel_path}" >/dev/null 2>&1; then
      results_guard_violation
    fi
    if ! git -C "${REPO_ROOT}" diff --quiet -- "${rel_path}"; then
      results_guard_violation
    fi
    if ! git -C "${REPO_ROOT}" diff --cached --quiet -- "${rel_path}"; then
      results_guard_violation
    fi
  done
}

reset_task_from_template() {
  if [[ ! -f "${TASK_TEMPLATE_PATH}" ]]; then
    die "TASK template not found at ${TASK_TEMPLATE_PATH}"
  fi
  if [[ ! -x "${TEMPLATE_BIN}" ]]; then
    die "Template binary not found or not executable at ${TEMPLATE_BIN}"
  fi

  local tmp_task
  tmp_task="$(mktemp "${RESUME_DIR}/task-template.XXXXXX")"

  if ! "${TEMPLATE_BIN}" render task-surface --out="${tmp_task}"; then
    rm -f "$tmp_task"
    die "Failed to render TASK surface template from ${TASK_TEMPLATE_PATH}"
  fi

  if ! (cd "${REPO_ROOT}" && bash tools/lint/task.sh "$tmp_task"); then
    rm -f "$tmp_task"
    die "TASK template at ${TASK_TEMPLATE_PATH} failed TASK lint; refusing to continue."
  fi

  if (( DRY_RUN )); then
    echo "[DRY-RUN] TASK reset would overwrite TASK.md from SSOT template ops/src/surfaces/task.md.tpl"
    rm -f "$tmp_task"
    return 0
  fi

  mv "$tmp_task" "${TASK_FILE}"
  echo "Reset TASK.md from SSOT template ops/src/surfaces/task.md.tpl."
}

ledger_entry_count() {
  local ledger_file="$1"
  grep -cE '^## [0-9]{4}-[0-9]{2}-[0-9]{2} ' "$ledger_file" || true
}

ledger_archive_plan() {
  local ledger_file="$1"
  local archive_prefix="$2"

  awk -v threshold="$THRESHOLD" -v archive_dir="$ARCHIVE_DIR" -v prefix="$archive_prefix" '
    /^## [0-9]{4}-[0-9]{2}-[0-9]{2} / {
      entry++
      if (entry > threshold) {
        if (match($0, /^## ([0-9]{4})-([0-9]{2})-([0-9]{2})/, parts)) {
          archive_file = archive_dir "/" prefix "-archive-" parts[1] "-" parts[2] ".md"
          counts[archive_file]++
        }
      }
    }
    END {
      for (file in counts) {
        print file "\t" counts[file]
      }
    }
  ' "$ledger_file" | sort
}

validate_pow_prune_candidates() {
  local pow_file="$1"
  local pointers_tmp
  pointers_tmp="$(mktemp "${RESUME_DIR}/pow-prune-pointers.XXXXXX")"

  if ! awk -v threshold="$THRESHOLD" '
    function trim(s) {
      gsub(/^[[:space:]]+/, "", s)
      gsub(/[[:space:]]+$/, "", s)
      return s
    }
    function reset_fields() {
      packet=0; timestamp=0; work_branch=0; base_head=0; scope=0
      allowlist=0; receipts=0; verification=0; notes=0
      results=0; open=0; dump=0
      results_path=""; open_path=""; dump_path=""
    }
    function finalize_entry(missing) {
      if (entry <= threshold) {
        return
      }

      missing=""
      if (!packet)      missing=missing " Packet ID"
      if (!timestamp)   missing=missing " Timestamp"
      if (!work_branch) missing=missing " Work Branch"
      if (!base_head)   missing=missing " Base HEAD"
      if (!scope)       missing=missing " Scope"
      if (!allowlist)   missing=missing " Target Files allowlist"
      if (!receipts)    missing=missing " Receipt pointers"
      if (!verification) missing=missing " Verification commands"
      if (!notes)       missing=missing " Notes"
      if (!results)     missing=missing " RESULTS"
      if (!open)        missing=missing " OPEN"
      if (!dump)        missing=missing " DUMP"

      if (missing != "") {
        printf "ERROR: PoW prune blocked. Entry missing required fields: %s ::%s\n", header, missing > "/dev/stderr"
        exit 1
      }

      printf "%s\tRESULTS\t%s\n", header, trim(results_path)
      printf "%s\tOPEN\t%s\n", header, trim(open_path)
      printf "%s\tDUMP\t%s\n", header, trim(dump_path)
    }
    /^## [0-9]{4}-[0-9]{2}-[0-9]{2} / {
      if (in_entry) {
        finalize_entry()
      }
      entry++
      in_entry=1
      header=$0
      reset_fields()
      next
    }
    {
      if (!in_entry || entry <= threshold) {
        next
      }

      if ($0 ~ /^[[:space:]]*-[[:space:]]*Packet ID:[[:space:]]*.+$/) packet=1
      if ($0 ~ /^[[:space:]]*-[[:space:]]*Timestamp:[[:space:]]*.+$/) timestamp=1
      if ($0 ~ /^[[:space:]]*-[[:space:]]*Work Branch:[[:space:]]*.+$/) work_branch=1
      if ($0 ~ /^[[:space:]]*-[[:space:]]*Base HEAD:[[:space:]]*.+$/) base_head=1
      if ($0 ~ /^[[:space:]]*-[[:space:]]*Scope:[[:space:]]*.+$/) scope=1
      if ($0 ~ /^[[:space:]]*-[[:space:]]*Target Files allowlist:[[:space:]]*$/) allowlist=1
      if ($0 ~ /^[[:space:]]*-[[:space:]]*Receipt pointers:[[:space:]]*$/) receipts=1
      if ($0 ~ /^[[:space:]]*-[[:space:]]*Verification commands:[[:space:]]*$/) verification=1
      if ($0 ~ /^[[:space:]]*-[[:space:]]*Notes:[[:space:]]*.+$/) notes=1

      if (match($0, /^[[:space:]]*-[[:space:]]*RESULTS:[[:space:]]*(.+)$/, m)) {
        results=1
        results_path=m[1]
      }
      if (match($0, /^[[:space:]]*-[[:space:]]*OPEN:[[:space:]]*(.+)$/, m)) {
        open=1
        open_path=m[1]
      }
      if (match($0, /^[[:space:]]*-[[:space:]]*DUMP:[[:space:]]*(.+)$/, m)) {
        dump=1
        dump_path=m[1]
      }
    }
    END {
      if (in_entry) {
        finalize_entry()
      }
    }
  ' "$pow_file" > "$pointers_tmp"; then
    rm -f "$pointers_tmp"
    echo "${POW_GUARD_FATAL}" >&2
    exit 1
  fi

  local header
  local kind
  local pointer
  local normalized
  local rel_path
  while IFS=$'\t' read -r header kind pointer; do
    [[ -z "$header" ]] && continue

    normalized="$(normalize_path_token "$pointer")"
    if [[ -z "$normalized" ]]; then
      rm -f "$pointers_tmp"
      echo "${POW_GUARD_FATAL}" >&2
      die "PoW prune blocked: empty ${kind} pointer in entry '${header}'."
    fi

    case "$kind" in
      RESULTS)
        if [[ "$normalized" != storage/handoff/*-RESULTS.md ]]; then
          rm -f "$pointers_tmp"
          echo "${POW_GUARD_FATAL}" >&2
          die "PoW prune blocked: RESULTS pointer must target storage/handoff/*-RESULTS.md (${normalized})."
        fi
        ;;
      OPEN)
        if [[ "$normalized" != storage/handoff/OPEN-* ]]; then
          rm -f "$pointers_tmp"
          echo "${POW_GUARD_FATAL}" >&2
          die "PoW prune blocked: OPEN pointer must target storage/handoff/OPEN-* (${normalized})."
        fi
        ;;
      DUMP)
        if [[ "$normalized" != storage/dumps/dump-* ]]; then
          rm -f "$pointers_tmp"
          echo "${POW_GUARD_FATAL}" >&2
          die "PoW prune blocked: DUMP pointer must target storage/dumps/dump-* (${normalized})."
        fi
        ;;
      *)
        rm -f "$pointers_tmp"
        echo "${POW_GUARD_FATAL}" >&2
        die "PoW prune blocked: unknown receipt pointer type '${kind}'."
        ;;
    esac

    rel_path="$normalized"
    if [[ ! -f "${REPO_ROOT}/${rel_path}" ]]; then
      rm -f "$pointers_tmp"
      echo "${POW_GUARD_FATAL}" >&2
      die "PoW prune blocked: pointer target missing (${rel_path})."
    fi
    if ! git -C "${REPO_ROOT}" ls-files --error-unmatch -- "$rel_path" >/dev/null 2>&1; then
      rm -f "$pointers_tmp"
      echo "${POW_GUARD_FATAL}" >&2
      die "PoW prune blocked: pointer target is not committed (${rel_path})."
    fi
    if ! git -C "${REPO_ROOT}" diff --quiet -- "$rel_path"; then
      rm -f "$pointers_tmp"
      echo "${POW_GUARD_FATAL}" >&2
      die "PoW prune blocked: pointer target has unstaged changes (${rel_path})."
    fi
    if ! git -C "${REPO_ROOT}" diff --cached --quiet -- "$rel_path"; then
      rm -f "$pointers_tmp"
      echo "${POW_GUARD_FATAL}" >&2
      die "PoW prune blocked: pointer target has staged changes (${rel_path})."
    fi
  done < "$pointers_tmp"

  rm -f "$pointers_tmp"
}

prune_ledger() {
  local ledger_name="$1"
  local ledger_file="$2"
  local archive_prefix="$3"

  if [[ ! -f "$ledger_file" ]]; then
    die "${ledger_name}.md not found at ${ledger_file}"
  fi

  local entry_count
  entry_count="$(ledger_entry_count "$ledger_file")"
  [[ -z "$entry_count" ]] && entry_count=0

  echo "${ledger_name} entries: ${entry_count}"

  if (( entry_count <= THRESHOLD )); then
    echo "${ledger_name} within threshold (${THRESHOLD})."
    return 0
  fi

  local prune_count=$((entry_count - THRESHOLD))
  local cut_line
  cut_line="$(grep -nE '^## [0-9]{4}-[0-9]{2}-[0-9]{2} ' "$ledger_file" | awk -F: -v threshold="$THRESHOLD" 'NR==threshold+1 { print $1; exit }')"
  if [[ -z "$cut_line" ]]; then
    die "Unable to determine prune cut line for ${ledger_name}."
  fi

  if [[ "$ledger_name" == "PoW" ]]; then
    validate_pow_prune_candidates "$ledger_file"
  fi

  local archive_plan
  archive_plan="$(ledger_archive_plan "$ledger_file" "$archive_prefix")"

  if (( DRY_RUN )); then
    echo "[DRY-RUN] ${ledger_name}: would prune ${prune_count} entries (cut line: ${cut_line})."
    while IFS=$'\t' read -r archive_path count; do
      [[ -z "$archive_path" ]] && continue
      echo "[DRY-RUN] ${ledger_name}: archive ${archive_path#${REPO_ROOT}/} (${count} entries)."
    done <<< "$archive_plan"
    return 0
  fi

  mkdir -p "${ARCHIVE_DIR}"
  local tmp_keep
  tmp_keep="$(mktemp "${RESUME_DIR}/${archive_prefix,,}-keep.XXXXXX")"

  awk -v threshold="$THRESHOLD" -v keep_file="$tmp_keep" -v archive_dir="$ARCHIVE_DIR" -v prefix="$archive_prefix" '
    BEGIN { entry=0; archive_file="" }
    /^## [0-9]{4}-[0-9]{2}-[0-9]{2} / {
      entry++
      if (entry > threshold) {
        match($0, /^## ([0-9]{4})-([0-9]{2})-([0-9]{2})/, parts)
        archive_file = archive_dir "/" prefix "-archive-" parts[1] "-" parts[2] ".md"
      }
    }
    {
      if (entry <= threshold) {
        print >> keep_file
      } else {
        print >> archive_file
      }
    }
  ' "$ledger_file"

  mv "$tmp_keep" "$ledger_file"
  echo "Archived ${prune_count} ${ledger_name} entries beyond ${THRESHOLD}."
  while IFS=$'\t' read -r archive_path count; do
    [[ -z "$archive_path" ]] && continue
    echo "${ledger_name} archive wrote ${count} entries to ${archive_path#${REPO_ROOT}/}."
  done <<< "$archive_plan"
}

detect_task_dp_id() {
  if [[ ! -f "${TASK_FILE}" ]]; then
    return 0
  fi

  awk '
    $0 ~ /^## 3\. Current Dispatch Packet \(DP\)/ { in_dp=1; next }
    in_dp && /^## / { exit }
    in_dp && /^### / {
      line=$0
      sub(/^###[[:space:]]+/, "", line)
      if (match(line, /DP-[A-Z]+-[0-9]{4,}|DP-XXXX/)) {
        print substr(line, RSTART, RLENGTH)
        exit
      }
    }
  ' "${TASK_FILE}"
}

ensure_pow_entry_exists() {
  if [[ ! -f "${POW_FILE}" ]]; then
    die "PoW.md not found at ${POW_FILE}"
  fi

  local dp_id
  dp_id="${DP_TARGET:-}"
  if [[ -z "$dp_id" ]]; then
    dp_id="$(detect_task_dp_id)"
  fi

  if [[ -z "$dp_id" ]]; then
    die "--reset-task blocked: active DP id not found in TASK.md. Provide --dp=DP-OPS-XXXX or set an active DP heading in TASK Section 3."
  fi
  if [[ "$dp_id" == "DP-XXXX" ]]; then
    die "--reset-task blocked: active DP id is template placeholder '${dp_id}'. Provide --dp=DP-OPS-XXXX and record PoW first."
  fi
  if [[ ! "$dp_id" =~ ^DP-[A-Z]+-[0-9]{4,}$ ]]; then
    die "--reset-task blocked: invalid active DP id '${dp_id}'. Expected DP-<AREA>-<####>."
  fi

  if ! grep -Fq -- "- Packet ID: ${dp_id}" "${POW_FILE}"; then
    die "--reset-task blocked: PoW.md missing '- Packet ID: ${dp_id}'. Update PoW for the active DP id before reset-task."
  fi
}

cleanup_handoff() {
  if [[ ! -d "${HANDOFF_DIR}" ]]; then
    return 0
  fi

  local dp_id
  dp_id="${DP_ID:-}"
  if [[ -z "$dp_id" ]]; then
    dp_id="$(detect_task_dp_id)"
  fi

  local deleted=0
  local kept=0
  local file
  local base

  while IFS= read -r -d '' file; do
    base="$(basename "$file")"
    if [[ "$base" == ".gitkeep" ]]; then
      continue
    fi

    if [[ -n "$dp_id" && "$base" == *"$dp_id"* ]]; then
      kept=$((kept + 1))
      continue
    fi

    if (( DRY_RUN )); then
      echo "[DRY-RUN] handoff cleanup would delete: ${file#${REPO_ROOT}/}"
      deleted=$((deleted + 1))
    else
      rm -f "$file"
      deleted=$((deleted + 1))
    fi
  done < <(find "${HANDOFF_DIR}" -type f -mtime +7 ! -name '.gitkeep' -print0 | sort -z)

  if (( DRY_RUN )); then
    echo "[DRY-RUN] handoff cleanup summary: delete ${deleted}, keep ${kept}."
  else
    echo "Handoff cleanup: deleted ${deleted}, kept ${kept}."
  fi
}

cleanup_dp_target_artifacts() {
  local deleted=0
  local file

  for dir in "${HANDOFF_DIR}" "${DUMPS_DIR}"; do
    if [[ ! -d "$dir" ]]; then
      continue
    fi

    while IFS= read -r -d '' file; do
      if (( DRY_RUN )); then
        echo "[DRY-RUN] DP prune would delete: ${file#${REPO_ROOT}/}"
      else
        rm -f "$file"
        echo "Deleted: ${file}"
      fi
      deleted=$((deleted + 1))
    done < <(find "$dir" -type f -name "*${DP_TARGET}*" ! -name '.gitkeep' -print0 | sort -z)
  done

  if (( deleted == 0 )); then
    echo "No artifacts found for ${DP_TARGET}."
    return 0
  fi

  if (( DRY_RUN )); then
    echo "[DRY-RUN] DP prune summary: would remove ${deleted} artifacts."
  else
    echo "Removed ${deleted} artifacts."
  fi
}

clean_resume_cache() {
  if [[ ! -d "${RESUME_DIR}" ]]; then
    return 0
  fi

  local -a items=()
  local item

  while IFS= read -r -d '' item; do
    items+=("$item")
  done < <(find "${RESUME_DIR}" -mindepth 1 -maxdepth 1 ! -name '.gitkeep' -print0 | sort -z)

  if (( DRY_RUN )); then
    echo "[DRY-RUN] var/tmp cleanup: would remove ${#items[@]} item(s)."
    for item in "${items[@]}"; do
      echo "[DRY-RUN] var/tmp cleanup candidate: ${item#${REPO_ROOT}/}"
    done
    return 0
  fi

  local removed=0
  for item in "${items[@]}"; do
    rm -rf "$item"
    removed=$((removed + 1))
  done

  echo "var/tmp cleanup: removed ${removed} item(s)."
}

stage_clean() {
  if [[ -n "${DP_TARGET}" && -z "${DP_TARGET// }" ]]; then
    die "--dp requires a non-empty value"
  fi

  if [[ "$TARGET" != "sop" && "$TARGET" != "pow" && "$TARGET" != "both" ]]; then
    die "--target must be one of: sop, pow, both"
  fi

  if [[ "$TARGET" == "sop" || "$TARGET" == "both" ]]; then
    [[ -f "${SOP_FILE}" ]] || die "SoP.md not found at ${SOP_FILE}"
  fi
  if [[ "$TARGET" == "pow" || "$TARGET" == "both" ]]; then
    [[ -f "${POW_FILE}" ]] || die "PoW.md not found at ${POW_FILE}"
  fi
  if (( RESET_TASK )); then
    [[ -f "${TASK_FILE}" ]] || die "TASK.md not found at ${TASK_FILE}"
    [[ -f "${TASK_TEMPLATE_PATH}" ]] || die "TASK template not found at ${TASK_TEMPLATE_PATH}"
  fi

  mkdir -p "${ARCHIVE_DIR}" "${RESUME_DIR}"

  if (( !DRY_RUN )); then
    ensure_results_artifacts_committed_and_clean
  fi
}

stage_archive() {
  case "$TARGET" in
    sop)
      prune_ledger "SoP" "$SOP_FILE" "SoP"
      ;;
    pow)
      prune_ledger "PoW" "$POW_FILE" "PoW"
      ;;
    both)
      prune_ledger "SoP" "$SOP_FILE" "SoP"
      prune_ledger "PoW" "$POW_FILE" "PoW"
      ;;
  esac
}

stage_reset() {
  if (( RESET_TASK )); then
    ensure_pow_entry_exists
    reset_task_from_template
  fi
}

for arg in "$@"; do
  case "$arg" in
    --dp=*)
      DP_TARGET="${arg#--dp=}"
      ;;
    --target=sop|--target=pow|--target=both)
      TARGET="${arg#--target=}"
      ;;
    --dry-run)
      DRY_RUN=1
      ;;
    --scrub)
      SCRUB=1
      ;;
    --reset-task)
      RESET_TASK=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown arg: ${arg}"
      ;;
  esac
done

stage_clean
stage_archive

if [[ -n "${DP_TARGET}" ]]; then
  echo "Pruning artifacts for Dispatch Packet: ${DP_TARGET}"
  cleanup_dp_target_artifacts
else
  cleanup_handoff
fi

stage_reset

if (( SCRUB )); then
  clean_resume_cache
fi

if (( DRY_RUN )); then
  echo "Dry-run complete. No files were modified."
fi

if (( SCRUB || RESET_TASK )); then
  echo "Routing scrub complete."
fi
