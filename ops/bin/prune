#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
SOP_FILE="${REPO_ROOT}/SoP.md"
TASK_FILE="${REPO_ROOT}/TASK.md"
ARCHIVE_DIR="${REPO_ROOT}/storage/archives/root"
HANDOFF_DIR="${REPO_ROOT}/storage/handoff"
TMP_DIR="${REPO_ROOT}/storage/tmp"
THRESHOLD=30
DP_TARGET=""
SCRUB=0

usage() {
  cat <<'USAGE'
Usage: ops/bin/prune [--dp=DP-ID] [--scrub]
USAGE
}

for arg in "$@"; do
  case "$arg" in
    --dp=*)
      DP_TARGET="${arg#--dp=}"
      ;;
    --scrub)
      SCRUB=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "ERROR: Unknown arg: ${arg}" >&2
      exit 1
      ;;
  esac
done

if [[ -n "${DP_TARGET}" && -z "${DP_TARGET// }" ]]; then
  echo "ERROR: --dp requires a non-empty value" >&2
  exit 1
fi

if [[ ! -f "${SOP_FILE}" ]]; then
  echo "ERROR: SoP.md not found at ${SOP_FILE}" >&2
  exit 1
fi

mkdir -p "${TMP_DIR}"

clean_storage_tmp() {
  if [[ ! -d "${TMP_DIR}" ]]; then
    return 0
  fi

  local removed=0
  while IFS= read -r -d '' item; do
    base="$(basename "$item")"
    if [[ "${base}" == ".gitignore" ]]; then
      continue
    fi
    rm -rf "$item"
    removed=$((removed + 1))
  done < <(find "${TMP_DIR}" -mindepth 1 -maxdepth 1 -print0)

  echo "storage/tmp cleanup: removed ${removed} item(s)."
}

scrub_task() {
  if [[ ! -f "${TASK_FILE}" ]]; then
    echo "ERROR: TASK.md not found at ${TASK_FILE}" >&2
    return 1
  fi

  local tmp_task
  tmp_task="$(mktemp "${TMP_DIR}/task-scrub.XXXXXX")"

  awk -v base_head="0000000" -v branch="main" -v work_branch="work/dp-ops-XXXX-YYYY-MM-DD" -v pointer="Session context output (generated by ops/bin/open)" -v prompt="Populate during execution; do not pre-fill in TASK.md." '
    BEGIN {
      in_closeout=0
      skip_payload=0
      in_scope=0
      skip_scope=0
      in_plan=0
      skip_plan=0
    }
    function emit_instruction() {
      print "(Generate at closeout; do not pre-fill in TASK.md)"
      print ""
    }
    function emit_prompt() {
      print prompt
      print ""
    }
    /^## 5\. Work Log \(Timestamped Continuity\)/ {
      print
      print "(No active thread)"
      exit
    }
    /^### DP-/ {
      print "### DP-XXXX: (Template)"
      next
    }
    /^[[:space:]]*Pointer:/ {
      print "Pointer: " pointer
      next
    }
    /^[[:space:]]*Active Branch:/ {
      print "Active Branch: " branch " (Must match session context output)"
      next
    }
    /^[[:space:]]*Base HEAD:/ {
      print "Base HEAD: " base_head " (Must match session context output)"
      next
    }
    /^[[:space:]]*Base Branch:/ {
      print "Base Branch: " branch
      next
    }
    /^[[:space:]]*Required Work Branch:/ {
      print "Required Work Branch: " work_branch
      next
    }
    /^[[:space:]]*[-*][[:space:]]*OPEN-PORCELAIN:/ {
      sub(/:.*/, ": Base HEAD " base_head)
      print
      next
    }
    /^[[:space:]]*[-*][[:space:]]*OPEN:/ {
      sub(/:.*/, ": Base HEAD " base_head)
      print
      next
    }
    /^[[:space:]]*[-*][[:space:]]*Dump Manifest:/ {
      sub(/:.*/, ": Base HEAD " base_head)
      print
      next
    }
    /^[[:space:]]*[-*][[:space:]]*Dump:/ {
      sub(/:.*/, ": Base HEAD " base_head)
      print
      next
    }
    /^[[:space:]]*Mandatory Closing Block/ {
      in_closeout=1
      skip_payload=0
      print
      next
    }
    /^## 4\.1 Thread Transition/ {
      in_closeout=0
      skip_payload=0
      in_scope=0
      skip_scope=0
      in_plan=0
      skip_plan=0
      print
      next
    }
    /^### 3\.3 / {
      in_scope=1
      skip_scope=0
      print
      next
    }
    /^### 3\.4 / {
      in_scope=0
      skip_scope=0
      in_plan=1
      skip_plan=1
      print
      print ""
      next
    }
    /^## 4\./ {
      in_scope=0
      skip_scope=0
      in_plan=0
      skip_plan=0
      print
      next
    }
    {
      if (in_scope) {
        if ($0 ~ /^[[:space:]]*Objective:/) {
          print "Objective: " prompt
          skip_scope=1
          next
        }
        if ($0 ~ /^[[:space:]]*In scope:/) {
          print "In scope: " prompt
          skip_scope=1
          next
        }
        if ($0 ~ /^[[:space:]]*Out of scope:/) {
          print "Out of scope: " prompt
          skip_scope=1
          next
        }
        if ($0 ~ /^[[:space:]]*Safety and invariants:/) {
          print "Safety and invariants: " prompt
          print ""
          skip_scope=1
          next
        }
        if ($0 ~ /^[[:space:]]*Target Files allowlist \(hard gate\):/) {
          print $0
          print "- " prompt
          print ""
          skip_scope=1
          next
        }
        if (skip_scope) {
          next
        }
        next
      }
      if (in_plan) {
        if ($0 ~ /^#### 3\.4\.1 /) { print $0; emit_prompt(); skip_plan=1; next }
        if ($0 ~ /^#### 3\.4\.2 /) { print $0; emit_prompt(); skip_plan=1; next }
        if ($0 ~ /^#### 3\.4\.3 /) { print $0; emit_prompt(); skip_plan=1; next }
        if ($0 ~ /^#### 3\.4\.4 /) { print $0; emit_prompt(); skip_plan=1; next }
        if ($0 ~ /^#### 3\.4\.5 /) { print $0; emit_prompt(); skip_plan=1; next }
        if (skip_plan) {
          next
        }
      }
      if (in_closeout) {
        if ($0 ~ /^[[:space:]]*Primary Commit Header/) {
          print $0
          emit_instruction()
          skip_payload=1
          next
        }
        if ($0 ~ /^[[:space:]]*Pull Request Title/) {
          print $0
          emit_instruction()
          skip_payload=1
          next
        }
        if ($0 ~ /^[[:space:]]*Pull Request Description/) {
          print $0
          emit_instruction()
          skip_payload=1
          next
        }
        if ($0 ~ /^[[:space:]]*Final Squash Stub/) {
          print $0
          emit_instruction()
          skip_payload=1
          next
        }
        if ($0 ~ /^[[:space:]]*Extended Technical Manifest/) {
          print $0
          emit_instruction()
          skip_payload=1
          next
        }
        if ($0 ~ /^[[:space:]]*Review Conversation Starter/) {
          print $0
          emit_instruction()
          skip_payload=1
          next
        }
        if (skip_payload) {
          next
        }
      }
      print
    }
  ' "${TASK_FILE}" > "${tmp_task}"

  mv "${tmp_task}" "${TASK_FILE}"
  echo "Scrubbed TASK.md to template baseline."
}

entry_count="$(grep -cE '^## [0-9]{4}-[0-9]{2}-[0-9]{2} ' "${SOP_FILE}" || true)"

if [[ -z "${entry_count}" ]]; then
  entry_count=0
fi

echo "SoP entries: ${entry_count}"

if (( entry_count > THRESHOLD )); then
  mkdir -p "${ARCHIVE_DIR}"
  tmp_keep="$(mktemp "${TMP_DIR}/sop-keep.XXXXXX")"

  awk -v threshold="${THRESHOLD}" -v keep_file="${tmp_keep}" -v archive_dir="${ARCHIVE_DIR}" '
    BEGIN { entry=0; archive_file="" }
    /^## [0-9]{4}-[0-9]{2}-[0-9]{2} / {
      entry++
      if (entry > threshold) {
        match($0, /^## ([0-9]{4})-([0-9]{2})-([0-9]{2})/, parts)
        archive_file = archive_dir "/SoP-archive-" parts[1] "-" parts[2] ".md"
      }
    }
    {
      if (entry <= threshold) {
        print $0 >> keep_file
      } else {
        print $0 >> archive_file
      }
    }
  ' "${SOP_FILE}"

  mv "${tmp_keep}" "${SOP_FILE}"
  echo "Archived entries beyond ${THRESHOLD}."
else
  echo "SoP within threshold (${THRESHOLD})."
fi

if [[ -n "${DP_TARGET}" ]]; then
  echo "Pruning artifacts for Dispatch Packet: ${DP_TARGET}"
  deleted=0
  for dir in "${HANDOFF_DIR}" "${REPO_ROOT}/storage/dumps" "${REPO_ROOT}/storage/_scratch"; do
    if [[ ! -d "${dir}" ]]; then
      continue
    fi
    while IFS= read -r -d '' file; do
      base="$(basename "${file}")"
      if [[ "${base}" == ".gitkeep" ]]; then
        continue
      fi
      rm -f "${file}"
      echo "Deleted: ${file}"
      deleted=$((deleted + 1))
    done < <(find "${dir}" -type f -name "*${DP_TARGET}*" ! -name '.gitkeep' -print0)
  done
  if (( deleted == 0 )); then
    echo "No artifacts found for ${DP_TARGET}."
  else
    echo "Removed ${deleted} artifacts."
  fi
else
  if [[ -d "${HANDOFF_DIR}" ]]; then
    dp_id="${DP_ID:-}"
    if [[ -z "${dp_id}" && -f "${TASK_FILE}" ]]; then
      dp_id="$(awk '
        $0 ~ /^## 3\\. Current Dispatch Packet \\(DP\\)/ { in_dp=1; next }
        in_dp && /^## / { exit }
        in_dp && /^### DP-/ {
          line=$0
          sub(/^### /, "", line)
          sub(/:.*/, "", line)
          print line
          exit
        }
      ' "${TASK_FILE}")"
    fi

    deleted=0
    kept=0

    while IFS= read -r -d '' file; do
      base="$(basename "${file}")"
      if [[ "${base}" == ".gitkeep" ]]; then
        continue
      fi
      if [[ -n "${dp_id}" && "${base}" == *"${dp_id}"* ]]; then
        kept=$((kept + 1))
        continue
      fi
      rm -f "${file}"
      deleted=$((deleted + 1))
    done < <(find "${HANDOFF_DIR}" -type f -mtime +7 ! -name '.gitkeep' -print0)

    echo "Handoff cleanup: deleted ${deleted}, kept ${kept}."
  fi
fi

if (( SCRUB )); then
  scrub_task
  clean_storage_tmp
  echo "Routing scrub complete."
fi
