#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
source "${SCRIPT_DIR}/../lib/scripts/common.sh"
source "${SCRIPT_DIR}/../lib/scripts/ledger.sh"

SOP_PATH="${REPO_ROOT}/SoP.md"
POW_PATH="${REPO_ROOT}/PoW.md"
HANDOFF_DIR="${REPO_ROOT}/storage/handoff"
RESUME_DIR="${REPO_ROOT}/var/tmp"
THRESHOLD=30
TARGET="sop"
DRY_RUN=0
SCRUB=0
RESULTS_GUARD_FATAL="SAFETY VIOLATION: Uncommitted Results artifact detected. Commit or stash before pruning."
POW_GUARD_FATAL="SAFETY VIOLATION: PoW prune requires committed RESULTS/OPEN/DUMP receipt pointers in prune-candidate entries."

usage() { echo "Usage: ops/bin/prune [--target=sop|pow|both] [--dry-run] [--scrub]"; }
guard_fail() { echo "$1" >&2; exit 1; }

resolve_surface_leaf() {
  local path="$1" raw=""
  [[ -f "$path" ]] && raw="$(normalize_path_token "$(tr -d '\r' < "$path")")"
  if [[ "$raw" == archives/surfaces/*.md && -f "${REPO_ROOT}/${raw}" ]]; then echo "${REPO_ROOT}/${raw}"; else echo "$path"; fi
}

results_guard() {
  local f rel
  [[ -d "${HANDOFF_DIR}" ]] || return 0
  while IFS= read -r -d '' f; do
    rel="${f#${REPO_ROOT}/}"
    git -C "${REPO_ROOT}" ls-files --error-unmatch -- "${rel}" >/dev/null 2>&1 || guard_fail "${RESULTS_GUARD_FATAL}"
    git -C "${REPO_ROOT}" diff --quiet -- "${rel}" || guard_fail "${RESULTS_GUARD_FATAL}"
    git -C "${REPO_ROOT}" diff --cached --quiet -- "${rel}" || guard_fail "${RESULTS_GUARD_FATAL}"
  done < <(find "${HANDOFF_DIR}" -maxdepth 1 -type f \( -name '*-RESULTS.md' -o -name 'CLOSING-DP-OPS-*.md' \) -print0)
}

scrub_resume() {
  local item removed=0
  [[ -d "${RESUME_DIR}" ]] || return 0
  while IFS= read -r -d '' item; do
    (( DRY_RUN )) && { echo "DRY-RUN scrub: ${item#${REPO_ROOT}/}"; continue; }
    rm -rf "$item"; removed=$((removed + 1))
  done < <(find "${RESUME_DIR}" -mindepth 1 -maxdepth 1 ! -name '.gitkeep' -print0 | sort -z)
  (( DRY_RUN )) || echo "var/tmp cleanup: removed ${removed} item(s)."
}

for arg in "$@"; do
  case "$arg" in
    --target=sop|--target=pow|--target=both) TARGET="${arg#--target=}" ;;
    --dry-run) DRY_RUN=1 ;;
    --scrub) SCRUB=1 ;;
    -h|--help) usage; exit 0 ;;
    *) die "Unknown arg: ${arg}" ;;
  esac
done

[[ "$TARGET" == "sop" || "$TARGET" == "pow" || "$TARGET" == "both" ]] || die "--target must be one of: sop, pow, both"
SOP_PATH="$(resolve_surface_leaf "${SOP_PATH}")"
POW_PATH="$(resolve_surface_leaf "${POW_PATH}")"

trap 'emit_binary_leaf "prune" "finish"' EXIT
emit_binary_leaf "prune" "start"

results_guard

if [[ "$TARGET" == "pow" || "$TARGET" == "both" ]]; then
  while IFS=$'\t' read -r entry_index results_path open_path dump_path; do
    for p in "$results_path" "$open_path" "$dump_path"; do
      p="$(normalize_path_token "$p")"
      [[ -n "$p" ]] || guard_fail "${POW_GUARD_FATAL}"
      git -C "${REPO_ROOT}" ls-files --error-unmatch -- "$p" >/dev/null 2>&1 || guard_fail "${POW_GUARD_FATAL}"
    done
    echo "PoW candidate #${entry_index}: ${results_path} | ${open_path} | ${dump_path}"
  done < <(ledger_extract_candidates "${POW_PATH}" "${SOP_PATH}")
fi

if (( DRY_RUN )); then
  echo "DRY-RUN complete for target=${TARGET}"
  (( SCRUB )) && scrub_resume
  exit 0
fi

[[ "$TARGET" == "sop" || "$TARGET" == "both" ]] && ledger_prune_surface "SoP" "${SOP_PATH}" "SoP"
[[ "$TARGET" == "pow" || "$TARGET" == "both" ]] && ledger_prune_surface "PoW" "${POW_PATH}" "PoW"
(( SCRUB )) && scrub_resume
