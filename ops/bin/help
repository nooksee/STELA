#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
# shellcheck source=/dev/null
source "${REPO_ROOT}/ops/lib/scripts/common.sh"

usage() {
  cat <<'USAGE'
Usage: ops/bin/help [specs|doctrine|curriculum|term]
USAGE
}

color_init() {
  if [[ -n "${TERM:-}" ]] && command -v tput >/dev/null 2>&1 && tput sgr0 >/dev/null 2>&1; then
    bold="$(tput bold)"
    dim="$(tput dim)"
    green="$(tput setaf 2)"
    cyan="$(tput setaf 6)"
    reset="$(tput sgr0)"
  else
    bold=""
    dim=""
    green=""
    cyan=""
    reset=""
  fi
}

say() {
  printf 'Stela System: %s\n' "$*"
}

require_repo_root() {
  if ! command -v git >/dev/null 2>&1; then
    die "git is required but was not found on PATH."
  fi

  if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    die "git repo not found. Run from repo root."
  fi

  if [[ "$(pwd -P)" != "$repo_root" ]]; then
    die "Run from repo root: $repo_root"
  fi
}

require_docs() {
  if [[ ! -d "docs" ]]; then
    die "docs/ directory not found."
  fi
}

require_specs() {
  if [[ ! -d "docs/ops/specs" ]]; then
    die "Spec directory not found: docs/ops/specs"
  fi
}

search_in_tree() {
  local term="$1"
  shift

  if command -v rg >/dev/null 2>&1; then
    rg -n --no-heading --color=never --fixed-strings -- "$term" "$@" || true
  else
    grep -RIn --binary-files=without-match -- "$term" "$@" || true
  fi
}

search_specs() {
  local term="$1"
  local matches=""

  require_specs
  matches="$(search_in_tree "$term" docs/ops/specs)"
  if [[ -n "$matches" ]]; then
    say "Spec references for \"$term\" (authoritative first):"
    printf '%s\n' "$matches"
    return 0
  fi
  return 1
}

search_docs_without_specs() {
  local term="$1"

  if command -v rg >/dev/null 2>&1; then
    rg -n --no-heading --color=never --fixed-strings --glob '!docs/ops/specs/**' -- "$term" docs || true
  else
    grep -RIn --binary-files=without-match --exclude-dir=specs -- "$term" docs || true
  fi
}

search_docs() {
  local term="$1"
  local matches=""

  if [[ -z "$term" ]]; then
    die "Search term required."
  fi

  require_docs

  say "Processing search for \"$term\"."
  if search_specs "$term"; then
    say "Additional references in docs/ (excluding docs/ops/specs):"
  else
    say "No spec references found. Scanning docs/."
  fi

  matches="$(search_docs_without_specs "$term")"
  if [[ -n "$matches" ]]; then
    say "I have located the following references regarding \"$term\":"
    printf '%s\n' "$matches"
  else
    say "No references found regarding \"$term\" in docs/."
  fi
}

show_specs() {
  local spec_root="docs/ops/specs"
  local current_group=""
  local file rel group

  require_specs

  mapfile -t spec_files < <(find "$spec_root" -type f -name '*.md' -print | LC_ALL=C sort)
  if (( ${#spec_files[@]} == 0 )); then
    say "No specification documents found under ${spec_root}."
    return 0
  fi

  say "Ops specification documents (recursive, grouped):"
  for file in "${spec_files[@]}"; do
    rel="${file#${spec_root}/}"
    if [[ "$rel" == "$file" ]]; then
      group="root"
    else
      group="${rel%%/*}"
      if [[ "$group" == "$rel" ]]; then
        group="root"
      fi
    fi

    if [[ "$group" != "$current_group" ]]; then
      if [[ -n "$current_group" ]]; then
        printf '\n'
      fi
      printf '%s[%s]%s\n' "$bold" "$group" "$reset"
      current_group="$group"
    fi

    printf '  %s\n' "$file"
  done
}

extract_lines_between() {
  local file="$1"
  local start_regex="$2"
  local stop_regex="$3"

  awk -v start="$start_regex" -v stop="$stop_regex" '
    BEGIN { in_block=0 }
    $0 ~ start { in_block=1; next }
    in_block && $0 ~ stop { exit }
    in_block { print }
  ' "$file"
}

extract_read_order() {
  local file="$1"
  awk '
    /^Source of Truth Read-in Order:/ { in_block=1; next }
    in_block && /^## / { exit }
    in_block && /^[0-9]+\./ { print }
  ' "$file"
}

print_or_fallback() {
  local content="$1"
  local fallback="$2"

  if [[ -n "$(printf '%s\n' "$content" | sed '/^[[:space:]]*$/d')" ]]; then
    printf '%s\n' "$content"
  else
    printf '%s\n' "$fallback"
  fi
}

show_doctrine() {
  local pot_file="PoT.md"
  local filing=""
  local axioms=""
  local canon=""
  local read_order=""

  if [[ ! -f "$pot_file" ]]; then
    die "PoT.md not found. Doctrine mode requires PoT.md."
  fi

  filing="$(extract_lines_between "$pot_file" '^### 1\\.1 Filing Doctrine$' '^### 1\\.2 ' )"
  axioms="$(extract_lines_between "$pot_file" '^### 1\\.2 Axioms$' '^### 1\\.3 ' )"
  canon="$(extract_lines_between "$pot_file" '^### 1\\.3 Canon Surfaces$' '^Source of Truth Read-in Order:' )"
  read_order="$(extract_read_order "$pot_file")"

  say "Doctrine mode: constitutional operator guidance from PoT."

  printf '%sFiling Doctrine%s\n' "$bold" "$reset"
  print_or_fallback "$filing" '- See PoT.md Section 1.1.'
  printf '\n'

  printf '%sAxioms%s\n' "$bold" "$reset"
  print_or_fallback "$axioms" '- See PoT.md Section 1.2.'
  printf '\n'

  printf '%sCanon Surfaces%s\n' "$bold" "$reset"
  print_or_fallback "$canon" '- See PoT.md Section 1.3.'
  printf '\n'

  printf '%sRead Sequence%s\n' "$bold" "$reset"
  print_or_fallback "$read_order" '1. PoT.md\n2. SoP.md\n3. PoW.md\n4. TASK.md\n5. docs/MAP.md'
  printf '\n'

  printf '%sOperator Reminder%s\n' "$bold" "$reset"
  printf '%s\n' '- Enforce pointer-first workflow: OPEN and RESULTS are artifacts, TASK is routing, PoW is proof.'
  printf '%s\n' '- If canon conflicts with execution intent, stop and resolve with PoT authority first.'
}

show_curriculum() {
  say "Curriculum mode: guided startup and closeout sequences."

  cat <<EOF_CURRICULUM
${bold}Startup Sequence${reset}
1. Open freshness snapshot:
   ${green}./ops/bin/open --out=auto --dp="DP-OPS-XXXX"${reset}
2. Capture Ops state:
   ${green}./ops/bin/dump --scope=core --format=chatgpt --out=auto --bundle${reset}
3. Run dispatch preflight gates before edits:
   ${green}bash tools/lint/dp.sh --test${reset}
   ${green}bash tools/lint/dp.sh TASK.md${reset}
   ${green}bash tools/lint/task.sh${reset}
4. Load canon in order:
   ${green}PoT.md -> SoP.md -> TASK.md -> docs/MAP.md -> docs/MANUAL.md -> ops/lib/manifests/CONTEXT.md${reset}
5. Execute DP Section 3 in order and keep freeze discipline.

${bold}Closeout Sequence${reset}
1. Verify:
   ${green}./tools/verify.sh${reset}
   ${green}bash tools/lint/truth.sh${reset}
   ${green}bash tools/lint/style.sh${reset}
   ${green}bash tools/lint/dp.sh TASK.md${reset}
   ${green}bash tools/lint/dp.sh storage/handoff/RESULTS.md${reset}
   ${green}bash tools/lint/llms.sh${reset}
2. Record proof and history:
   - Update RESULTS receipts.
   - Append SoP history entry.
   - Append PoW proof entry with RESULTS, OPEN, and DUMP pointers.
3. Refresh navigation bundles when applicable:
   ${green}./ops/bin/map${reset}
   ${green}./ops/bin/llms --out-dir="$(pwd)"${reset}
4. Prune last:
   ${green}./ops/bin/prune --scrub${reset}

${bold}Routing References${reset}
- Dispatch contract: ${cyan}TASK.md${reset}
- Closeout doctrine: ${cyan}docs/MANUAL.md${reset}
- Wayfinding map: ${cyan}docs/MAP.md${reset}
EOF_CURRICULUM
}

show_menu() {
  say "Processing help request."
  cat <<EOF_MENU
${bold}Stela Help${reset}
${dim}CLI wayfinding surface aligned with docs/MAP.md.${reset}

${bold}Shipping Spine${reset}
  ${dim}TOPIC.md -> PLAN.md -> DP.md -> execution -> RESULTS + CLOSING -> audit bundle -> merge${reset}

${bold}Command Index${reset}
  ${cyan}open${reset}       Session freshness and trace anchor (STELA_TRACE_ID required by certify).
  ${cyan}draft${reset}      Generate canonical DP from template; saves to storage/dp/intake/ and TASK.md.
  ${cyan}dump${reset}       Platform context capture (use --selection=dp+allowlist for CDD; --scope=core for operator audit).
  ${cyan}bundle${reset}     Delivery transport for planning, draft, audit, foreman, conform profiles.
  ${cyan}certify${reset}    Generate RESULTS receipt, emit SoP/PoW/TASK archive leaves, move DP to processed.
  ${cyan}addendum${reset}   Issuance tool for operator/foreman-authorized addendum artifacts.
  ${cyan}context${reset}    Context archive assembly.
  ${cyan}map${reset}        Refresh MAP auto-generated index block.
  ${cyan}llms${reset}       Refresh llms root bundles from One Truth manifests.
  ${cyan}prune${reset}      Ledger retention and storage hygiene.
  ${cyan}project${reset}    Project and task status helpers.
  ${cyan}help${reset}       Wayfinding, doctrine, curriculum, and docs search.

${bold}Help Modes${reset}
  ${cyan}specs${reset}       Recursive spec index grouped by category.
  ${cyan}doctrine${reset}    PoT-based constitutional guidance.
  ${cyan}curriculum${reset}  Guided startup and closeout sequence.
  ${cyan}<term>${reset}      Specs-first docs search.

${bold}Quick Start (Main Spine)${reset}
  1) Read constitution and active contract: ${green}PoT.md${reset}, ${green}TASK.md${reset}
  2) Open session: ${green}./ops/bin/open --out=auto${reset}
  3) Run preflight gates: ${green}bash tools/lint/dp.sh --test${reset}, ${green}bash tools/lint/dp.sh TASK.md${reset}, ${green}bash tools/lint/task.sh${reset}
  4) Execute DP. Certify: ${green}./ops/bin/certify --dp=DP-OPS-XXXX --out=auto${reset}
  5) Audit: ${green}./ops/bin/bundle --profile=audit --out=auto${reset}
  6) Operator: commit, PR, merge per CLOSING sidecar.

${bold}Wayfinding${reset}
  MAP analogue: ${green}./ops/bin/help${reset}
  Spec index:   ${green}./ops/bin/help specs${reset}
  Full spine:   ${green}docs/MAP.md§5${reset}, ${green}docs/MANUAL.md§0${reset}
EOF_MENU
}

color_init
require_repo_root

if (( $# > 1 )); then
  die "Too many arguments."
fi

trap 'emit_binary_leaf "help" "finish"' EXIT
emit_binary_leaf "help" "start"

case "${1:-}" in
  "")
    show_menu
    ;;
  -h|--help)
    usage
    ;;
  specs)
    show_specs
    ;;
  doctrine)
    show_doctrine
    ;;
  curriculum)
    show_curriculum
    ;;
  *)
    search_docs "$1"
    ;;
esac
