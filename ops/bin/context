#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
# shellcheck source=/dev/null
source "${REPO_ROOT}/ops/lib/scripts/project.sh"

SYNTH_BIN="${REPO_ROOT}/ops/lib/scripts/synthesize.sh"
OPEN_BIN="${REPO_ROOT}/ops/bin/open"
COMPILE_BIN="${REPO_ROOT}/ops/bin/compile"
MANIFEST_PATH="ops/lib/manifests/OPS.md"
OUT_PATH=""
DP_ID=""

usage() {
  cat <<'USAGE'
Usage: ops/bin/context [--manifest=ops/lib/manifests/OPS.md] [--dp=DP-OPS-XXXX] [--out=auto|PATH]
USAGE
}

display_path() {
  local path="$1"
  if [[ "$path" == "${PROJECT_REPO_ROOT}/"* ]]; then
    printf './%s' "${path#"${PROJECT_REPO_ROOT}/"}"
  else
    printf '%s' "$path"
  fi
}

for arg in "$@"; do
  case "$arg" in
    --manifest=*)
      MANIFEST_PATH="${arg#--manifest=}"
      ;;
    --dp=*)
      DP_ID="${arg#--dp=}"
      ;;
    --out=*)
      OUT_PATH="${arg#--out=}"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      project_die "Unknown arg: ${arg}"
      ;;
  esac
done

project_require_repo_root
project_require_executable "$COMPILE_BIN"
project_require_executable "$SYNTH_BIN"
project_require_executable "$OPEN_BIN"
"$COMPILE_BIN" >/dev/null
project_require_file "${PROJECT_REPO_ROOT}/${MANIFEST_PATH}"

mkdir -p "${PROJECT_REPO_ROOT}/storage/handoff"
mkdir -p "${PROJECT_REPO_ROOT}/var/tmp"

open_args=(--out=auto)
if [[ -n "$DP_ID" ]]; then
  open_args+=("--dp=${DP_ID}")
fi
open_output="$("$OPEN_BIN" "${open_args[@]}")"
open_path="$(printf '%s\n' "$open_output" | sed -n 's/^OPEN saved: //p' | tail -n 1)"
if [[ -z "$open_path" ]]; then
  project_die "OPEN artifact path not found in open output"
fi

open_path="${open_path#./}"
project_require_file "${PROJECT_REPO_ROOT}/${open_path}"

branch_name="$(git -C "${PROJECT_REPO_ROOT}" rev-parse --abbrev-ref HEAD)"
head_short="$(git -C "${PROJECT_REPO_ROOT}" rev-parse --short HEAD)"
branch_safe="${branch_name//\//-}"

tmp_file="$(mktemp "${PROJECT_REPO_ROOT}/var/tmp/context-stream.XXXXXX")"
cleanup() {
  rm -f "$tmp_file"
}
trap cleanup EXIT

{
  echo "===== SESSION CONTEXT ====="
  echo "Manifest: ${MANIFEST_PATH}"
  echo "OPEN artifact: ${open_path}"
  if [[ -n "$DP_ID" ]]; then
    echo "DP: ${DP_ID}"
  fi
  echo
  cat "${PROJECT_REPO_ROOT}/${open_path}"
  echo
  echo "===== SYNTHESIZED STREAM ====="
  "$SYNTH_BIN" --manifest="$MANIFEST_PATH" --mode=stream
  echo "===== END SESSION CONTEXT ====="
} > "$tmp_file"

cat "$tmp_file"

if [[ -n "$OUT_PATH" ]]; then
  dest_path=""
  if [[ "$OUT_PATH" == "auto" ]]; then
    tag="context-${branch_safe}-${head_short}.txt"
    if [[ -n "$DP_ID" ]]; then
      dp_safe="${DP_ID//\//-}"
      tag="context-${dp_safe}-${branch_safe}-${head_short}.txt"
    fi
    dest_path="${PROJECT_REPO_ROOT}/storage/handoff/${tag}"
  elif [[ "$OUT_PATH" = /* ]]; then
    dest_path="$OUT_PATH"
  else
    dest_path="${PROJECT_REPO_ROOT}/${OUT_PATH}"
  fi

  mkdir -p "$(dirname "$dest_path")"
  cp "$tmp_file" "$dest_path"
  printf 'CONTEXT saved: %s\n' "$(display_path "$dest_path")"
fi
