#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
TEMPLATE_BIN="${REPO_ROOT}/ops/bin/template"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/../lib/scripts/common.sh"

usage() {
  cat <<'USAGE'
Usage:
  ops/bin/addendum --base-dp=DP-OPS-XXXX --slots-file=PATH

Required:
- --base-dp=DP-OPS-XXXX
- --slots-file=PATH
USAGE
}

sha256_file() {
  local path="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$path" | awk '{print $1}'
    return
  fi
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$path" | awk '{print $1}'
    return
  fi
  die "sha256 tool not found (need sha256sum or shasum)"
}

read_addendum_lint_constants() {
  local lint_path="$REPO_ROOT/tools/lint/dp.sh"
  local template_hash

  [[ -f "$lint_path" ]] || die "missing tools/lint/dp.sh"

  ADDENDUM_TEMPLATE_PATH="$(awk -F'"' '/^CANONICAL_ADDENDUM_TEMPLATE_PATH="/{print $2; exit}' "$lint_path")"
  template_hash="$(awk -F'"' '/^CANONICAL_ADDENDUM_TEMPLATE_SHA256="/{print $2; exit}' "$lint_path")"

  [[ -n "$ADDENDUM_TEMPLATE_PATH" ]] || die "failed to read CANONICAL_ADDENDUM_TEMPLATE_PATH from tools/lint/dp.sh"
  [[ -n "$template_hash" ]] || die "failed to read CANONICAL_ADDENDUM_TEMPLATE_SHA256 from tools/lint/dp.sh"
  [[ "$template_hash" =~ ^[0-9a-f]{64}$ ]] || die "invalid CANONICAL_ADDENDUM_TEMPLATE_SHA256 in tools/lint/dp.sh"

  ADDENDUM_TEMPLATE_PATH="$REPO_ROOT/$ADDENDUM_TEMPLATE_PATH"
  [[ -f "$ADDENDUM_TEMPLATE_PATH" ]] || die "canonical addendum template missing: ${ADDENDUM_TEMPLATE_PATH}"

  local actual_hash
  actual_hash="$(sha256_file "$ADDENDUM_TEMPLATE_PATH")"
  if [[ "$actual_hash" != "$template_hash" ]]; then
    die "template preflight failed: canonical addendum template hash mismatch (expected ${template_hash}, got ${actual_hash})"
  fi
}

contains_placeholder() {
  local lowered
  lowered="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"

  if [[ -z "$lowered" ]]; then
    return 0
  fi

  case "$lowered" in
    *"tbd"*|*"todo"*|*"populate during execution"*|*"do not pre-fill"*|*"dp-xxxx"*|*"xxxx"*|*"0000000"*|*"{{"*|*"}}"*|*"<fill"*|*"replace_"*|*"enter_"*)
      return 0
      ;;
  esac

  return 1
}

extract_field_value() {
  local label="$1"
  local path="$2"
  awk -v label="$label" '
    {
      if ($0 ~ "^" label ":[[:space:]]*") {
        text=$0
        sub("^" label ":[[:space:]]*", "", text)
        print text
        exit
      }
    }
  ' "$path"
}

extract_block() {
  local path="$1"
  local start_pattern="$2"
  local stop_pattern="$3"
  awk -v start_regex="$start_pattern" -v stop_regex="$stop_pattern" '
    BEGIN { in_block=0 }
    $0 ~ start_regex { in_block=1; next }
    in_block && $0 ~ stop_regex { exit }
    in_block { print }
  ' "$path"
}

extract_tail_after() {
  local path="$1"
  local start_text="$2"
  awk -v needle="$start_text" '
    BEGIN { in_block=0 }
    {
      if (in_block) {
        print
        next
      }
      if (index($0, needle) > 0) {
        in_block=1
      }
    }
  ' "$path"
}

require_non_placeholder_value() {
  local label="$1"
  local value="$2"
  local compact

  compact="$(printf '%s\n' "$value" | sed '/^[[:space:]]*$/d')"
  [[ -n "$compact" ]] || die "missing required addendum content for ${label}"
  if contains_placeholder "$compact"; then
    die "placeholder value detected for ${label}"
  fi
}

task_lineage_leaf_contains_packet() {
  local source_path="$1"
  local dp_id="$2"
  awk -v expected="$dp_id" '
    /^packet_id:[[:space:]]*/ {
      line=$0
      sub(/^packet_id:[[:space:]]*/, "", line)
      if (line == expected) {
        found=1
        exit
      }
    }
    /^###[[:space:]]*/ {
      line=$0
      sub(/^###[[:space:]]*/, "", line)
      sub(/:.*/, "", line)
      if (line == expected) {
        found=1
        exit
      }
    }
    END { exit found ? 0 : 1 }
  ' "$source_path"
}

find_task_lineage_leaf_for_packet() {
  local dp_id="$1"
  local task_head_path="$REPO_ROOT/TASK.md"
  local pointer_rel=""

  if [[ -f "$task_head_path" ]] && [[ "$(awk 'END { print NR }' "$task_head_path")" == "1" ]]; then
    pointer_rel="$(trim "$(cat "$task_head_path")")"
    pointer_rel="${pointer_rel#./}"
    if [[ -n "$pointer_rel" && -f "$REPO_ROOT/$pointer_rel" ]] && task_lineage_leaf_contains_packet "$REPO_ROOT/$pointer_rel" "$dp_id"; then
      printf '%s' "$REPO_ROOT/$pointer_rel"
      return 0
    fi
  fi

  mapfile -t matches < <(find "$REPO_ROOT/archives/surfaces" -maxdepth 1 -type f -name "TASK-${dp_id}-*.md" | sort)
  if (( ${#matches[@]} > 0 )); then
    printf '%s' "${matches[-1]}"
    return 0
  fi

  return 1
}

addendum_lineage_leaf_glob() {
  local dp_id="$1"
  printf '%s/archives/surfaces/ADDENDUM-%s-*.md' "$REPO_ROOT" "$dp_id"
}

require_base_dp_lineage() {
  local base_dp="$1"
  local active_dp_path="$REPO_ROOT/storage/dp/intake/DP.md"

  if [[ -f "$active_dp_path" ]] && grep -Eq "^###[[:space:]]+${base_dp}:" "$active_dp_path"; then
    return 0
  fi

  find_task_lineage_leaf_for_packet "$base_dp" >/dev/null || die "base DP not found in active intake or TASK leaf lineage: ${base_dp}"
}

extract_addendum_id() {
  local source_path="$1"
  local value=""
  value="$(trim "$(extract_field_value "Addendum ID" "$source_path")")"
  if [[ -n "$value" ]]; then
    printf '%s' "$value"
    return 0
  fi
  awk '
    /^###[[:space:]]+Addendum[[:space:]]+[A-Z][[:space:]]+to[[:space:]]+DP-[A-Z]+-[0-9]{4,}[[:space:]]*$/ {
      line=$0
      sub(/^###[[:space:]]+Addendum[[:space:]]+/, "", line)
      sub(/[[:space:]]+to.*/, "", line)
      print line
      exit
    }
  ' "$source_path"
}

next_addendum_letter() {
  local base_dp="$1"
  local intake_dir="$REPO_ROOT/storage/dp/intake"
  local active_addendum_path="${intake_dir}/ADDENDUM.md"
  local active_base_dp=""
  local active_addendum_id=""
  local archived_addendum=""
  local archived_letter=""
  declare -A used_letters=()
  local code
  local letter

  mkdir -p "$intake_dir"

  if [[ -f "$active_addendum_path" ]]; then
    active_base_dp="$(trim "$(extract_field_value "Base Packet" "$active_addendum_path")")"
    active_addendum_id="$(extract_addendum_id "$active_addendum_path")"
    active_addendum_id="$(trim "$active_addendum_id")"
    if [[ "$active_base_dp" == "$base_dp" && "$active_addendum_id" =~ ^[A-Z]$ ]]; then
      used_letters["$active_addendum_id"]=1
    fi
  fi

  while IFS= read -r archived_addendum || [[ -n "$archived_addendum" ]]; do
    [[ -f "$archived_addendum" ]] || continue
    archived_letter="$(extract_addendum_id "$archived_addendum")"
    archived_letter="$(trim "$archived_letter")"
    if [[ "$archived_letter" =~ ^[A-Z]$ ]]; then
      used_letters["$archived_letter"]=1
    fi
  done < <(find "$REPO_ROOT/archives/surfaces" -maxdepth 1 -type f -name "ADDENDUM-${base_dp}-*.md" | sort)

  for code in $(seq 65 90); do
    printf -v letter '%b' "\\$(printf '%03o' "$code")"
    if [[ -n "${used_letters[$letter]+set}" ]]; then
      continue
    fi
    printf '%s' "$letter"
    return 0
  done

  die "no addendum letter available for ${base_dp} (A-Z exhausted)"
}

validate_rendered_addendum() {
  local rendered_path="$1"
  local expected_base_dp="$2"
  local expected_letter="$3"
  local base_packet
  local addendum_id
  local operator_authorization
  local scope_delta
  local addendum_objective
  local addendum_receipt

  base_packet="$(trim "$(extract_field_value "Base Packet" "$rendered_path")")"
  addendum_id="$(trim "$(extract_field_value "Addendum ID" "$rendered_path")")"
  operator_authorization="$(extract_block "$rendered_path" '^Operator Authorization:[[:space:]]*$' '^Base Packet:[[:space:]]*')"
  scope_delta="$(extract_block "$rendered_path" '^## A[.]2 Scope Delta[[:space:]]*$' '^## A[.]3 Addendum Objective[[:space:]]*$')"
  addendum_objective="$(extract_block "$rendered_path" '^## A[.]3 Addendum Objective[[:space:]]*$' '^## A[.]4 Context Load[[:space:]]*$')"
  addendum_receipt="$(extract_tail_after "$rendered_path" '**Addendum-specific receipt commands:**')"

  [[ "$base_packet" == "$expected_base_dp" ]] || die "rendered BASE_DP_ID mismatch (expected ${expected_base_dp}, got ${base_packet:-<empty>})"
  [[ "$addendum_id" == "$expected_letter" ]] || die "rendered ADDENDUM_ID mismatch (expected ${expected_letter}, got ${addendum_id:-<empty>})"

  require_non_placeholder_value "OPERATOR_AUTHORIZATION" "$operator_authorization"
  require_non_placeholder_value "SCOPE_DELTA" "$scope_delta"
  require_non_placeholder_value "ADDENDUM_OBJECTIVE" "$addendum_objective"
  require_non_placeholder_value "ADDENDUM_RECEIPT" "$addendum_receipt"

  if grep -Fq '$(' "$rendered_path"; then
    die "rendered addendum contains command substitution token \$(: certify replay requires literal commands"
  fi
}

BASE_DP_ID=""
SLOTS_FILE=""

for arg in "$@"; do
  case "$arg" in
    --base-dp=*)
      BASE_DP_ID="${arg#--base-dp=}"
      ;;
    --slots-file=*)
      SLOTS_FILE="${arg#--slots-file=}"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown arg: ${arg}"
      ;;
  esac
done

[[ -n "$BASE_DP_ID" ]] || die "missing required --base-dp"
[[ -n "$SLOTS_FILE" ]] || die "missing required --slots-file"
[[ "$BASE_DP_ID" =~ ^DP-OPS-[0-9]{4}$ ]] || die "invalid --base-dp format (expected DP-OPS-XXXX): ${BASE_DP_ID}"
[[ -f "$SLOTS_FILE" ]] || die "slots file not found: ${SLOTS_FILE}"
[[ -r "$SLOTS_FILE" ]] || die "slots file is not readable: ${SLOTS_FILE}"
[[ -x "$TEMPLATE_BIN" ]] || die "template binary missing or not executable: ${TEMPLATE_BIN}"

trap 'emit_binary_leaf "addendum" "finish"' EXIT
emit_binary_leaf "addendum" "start"

read_addendum_lint_constants
require_base_dp_lineage "$BASE_DP_ID"

ADDENDUM_LETTER="$(next_addendum_letter "$BASE_DP_ID")"
OUTPUT_PATH="$REPO_ROOT/storage/dp/intake/ADDENDUM.md"
RENDERED_TMP="$(mktemp)"

"$TEMPLATE_BIN" render addendum \
  "--out=${RENDERED_TMP}" \
  "--slots-file=${SLOTS_FILE}" \
  "--slot=BASE_DP_ID=${BASE_DP_ID}" \
  "--slot=ADDENDUM_ID=${ADDENDUM_LETTER}"

validate_rendered_addendum "$RENDERED_TMP" "$BASE_DP_ID" "$ADDENDUM_LETTER"

cat "$RENDERED_TMP"
cp "$RENDERED_TMP" "$OUTPUT_PATH"
rm -f "$RENDERED_TMP"

echo
echo "Wrote: ${OUTPUT_PATH#${REPO_ROOT}/}"
