#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
# shellcheck source=/dev/null
source "${REPO_ROOT}/ops/lib/scripts/common.sh"
# shellcheck source=/dev/null
source "${REPO_ROOT}/ops/lib/scripts/project.sh"

SYNTH_BIN="${REPO_ROOT}/ops/lib/scripts/synthesize.sh"
COMPILE_BIN="${REPO_ROOT}/ops/bin/compile"
CORE_MANIFEST="ops/lib/manifests/CORE.md"
FULL_MANIFEST="ops/lib/manifests/DISCOVERY.md"
OUT_DIR="${REPO_ROOT}"
ROOT_OUT_DIR="${REPO_ROOT}"
work_dir=""

usage() {
  cat <<'USAGE'
Usage: ops/bin/llms [--out-dir=PATH] [--core-manifest=PATH] [--full-manifest=PATH]

Notes:
- Root outputs are always refreshed: llms.txt, llms-core.txt, llms-full.txt.
- If --out-dir is non-root, mirrored copies are also written there.
USAGE
}

for arg in "$@"; do
  case "$arg" in
    --out-dir=*)
      OUT_DIR="${arg#--out-dir=}"
      ;;
    --core-manifest=*)
      CORE_MANIFEST="${arg#--core-manifest=}"
      ;;
    --full-manifest=*)
      FULL_MANIFEST="${arg#--full-manifest=}"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      project_die "Unknown arg: ${arg}"
      ;;
  esac
done

project_require_repo_root
project_require_executable "$COMPILE_BIN"
project_require_executable "$SYNTH_BIN"
project_require_file "${PROJECT_REPO_ROOT}/${CORE_MANIFEST}"
project_require_file "${PROJECT_REPO_ROOT}/${FULL_MANIFEST}"

cleanup() {
  emit_binary_leaf "llms" "finish"
  [[ -n "$work_dir" ]] && rm -rf "$work_dir"
}
trap cleanup EXIT
emit_binary_leaf "llms" "start"

"$COMPILE_BIN" >/dev/null

if [[ "$OUT_DIR" != /* ]]; then
  OUT_DIR="${PROJECT_REPO_ROOT}/${OUT_DIR}"
fi

mkdir -p "$OUT_DIR"
mkdir -p "$ROOT_OUT_DIR"

work_dir="$(mktemp -d)"

core_tmp="${work_dir}/llms-core.txt"
full_tmp="${work_dir}/llms-full.txt"
index_tmp="${work_dir}/llms.txt"

"$SYNTH_BIN" --manifest="$CORE_MANIFEST" --mode=stream > "$core_tmp"
"$SYNTH_BIN" --manifest="$FULL_MANIFEST" --mode=stream > "$full_tmp"

if [[ ! -s "$core_tmp" ]]; then
  project_die "generated llms-core.txt is empty"
fi
if [[ ! -s "$full_tmp" ]]; then
  project_die "generated llms-full.txt is empty"
fi

deprecated_files=(
  "llms-small.txt"
  "llms-ops.txt"
  "llms-governance.txt"
)

for file in "${deprecated_files[@]}"; do
  if [[ -e "${ROOT_OUT_DIR}/${file}" ]]; then
    project_die "deprecated llms slice must not exist: ${file}"
  fi
done

head_short="$(git -C "${PROJECT_REPO_ROOT}" rev-parse --short HEAD)"
head_time="$(git -C "${PROJECT_REPO_ROOT}" show -s --format=%cI HEAD)"

{
  echo "# Stela llms.txt"
  echo "# HEAD: ${head_short}"
  echo "# HEAD commit time: ${head_time}"
  echo "# Refresh: ./ops/bin/llms"
  echo "# One Truth bundle index."
  echo
  echo "## 0. Root Bundles"
  echo "- llms-core.txt - Layer 0 (CORE) synthesis output."
  echo "- llms-full.txt - Layer 2 (DISCOVERY) synthesis output."
  echo "- llms.txt - This pointer index."
  echo
  echo "## 1. Manifest Hierarchy"
  echo "- ops/src/manifests/*.md.tpl - Manifest template source of truth."
  echo "- ops/lib/manifests/CORE.md - Immutable Physical Laws manifest."
  echo "- ops/lib/manifests/OPS.md - Session operations manifest (inherits CORE)."
  echo "- ops/lib/manifests/DISCOVERY.md - Discovery manifest (inherits CORE)."
  echo "- ops/lib/manifests/CONTEXT.md - Canonical layer pointer surface."
  echo "- ops/bin/compile - Deterministic compiler from templates to manifests."
  echo
  echo "## 2. Synthesis Engine"
  echo "- ops/lib/scripts/synthesize.sh - Unified parser, hazard enforcement, and emitter."
  echo "- ops/bin/context - Session wrapper over synthesize.sh (OPS default + OPEN state)."
  echo "- ops/bin/llms - Static bundle wrapper over synthesize.sh (CORE and DISCOVERY)."
  echo
  echo "## 3. Core Pointers"
  echo "- PoT.md"
  echo "- SoP.md"
  echo "- PoW.md"
  echo "- TASK.md"
  echo "- docs/MAP.md"
} > "$index_tmp"

write_bundle() {
  local src="$1"
  local name="$2"

  cp "$src" "${ROOT_OUT_DIR}/${name}"
  if [[ "$OUT_DIR" != "$ROOT_OUT_DIR" ]]; then
    cp "$src" "${OUT_DIR}/${name}"
  fi
}

write_bundle "$core_tmp" "llms-core.txt"
write_bundle "$full_tmp" "llms-full.txt"
write_bundle "$index_tmp" "llms.txt"

written=("${ROOT_OUT_DIR}/llms-core.txt" "${ROOT_OUT_DIR}/llms-full.txt" "${ROOT_OUT_DIR}/llms.txt")
if [[ "$OUT_DIR" != "$ROOT_OUT_DIR" ]]; then
  written+=("${OUT_DIR}/llms-core.txt" "${OUT_DIR}/llms-full.txt" "${OUT_DIR}/llms.txt")
fi

printf 'Wrote %s\n' "${written[*]}"
