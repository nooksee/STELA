#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd -P)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/../lib/scripts/common.sh"

scope="platform"
format="chatgpt"
out_path=""
compress_mode=""
bundle_mode=0
max_lines=0
target=""
selection_mode="scope"
from_dp=""

# Optional refiners (apply after scope selection)
include_dirs=()
exclude_dirs=()
ignore_patterns=()
include_files=()
include_file_lists=()
forbidden_prefixes=()

# Retained output metadata knob for compatibility.
include_binary="meta"
ALLOWLIST_BASELINE_PATH="${REPO_ROOT}/var/tmp/baseline-storage-dp-active-allowlist.txt"

usage() {
  cat <<'USAGE'
Usage: ops/bin/dump [--scope=core|platform|full|factory|project] [--project=<slug>] [--format=chatgpt|gemini|claude]
                   [--max-lines=n] [--out=path|auto] [--compress=tar.xz] [--bundle]
                   [--include-binary=meta|raw|base64]
                   [--include-dir=DIR] [--exclude-dir=DIR] [--ignore-file=GLOB]
                   [--selection=scope|dp|dp+allowlist] [--from-dp=PATH|auto]
                   [--include-file=PATH] [--include-file-list=FILE]
                   [--fail-on-forbidden-prefix=PREFIX]

Notes:
- Scopes and refiners are resolved by ops/lib/scripts/traverse.sh.
- --project is required when --scope=project.
- --selection=scope preserves traverse-based selection behavior.
USAGE
}

for arg in "$@"; do
  case "$arg" in
    --scope=core|--scope=platform|--scope=full|--scope=factory|--scope=project)
      scope="${arg#--scope=}"
      ;;
    --project=*)
      target="${arg#--project=}"
      if [[ -z "$target" ]]; then
        die "--project requires a value"
      fi
      ;;
    --target=*)
      target="${arg#--target=}"
      if [[ -z "$target" ]]; then
        die "--target requires a value"
      fi
      ;;
    --format=chatgpt|--format=gemini|--format=claude)
      format="${arg#--format=}"
      ;;
    --max-lines=*)
      max_lines="${arg#--max-lines=}"
      if [[ -z "$max_lines" ]]; then
        die "--max-lines requires a value"
      fi
      if ! [[ "$max_lines" =~ ^[0-9]+$ ]]; then
        die "--max-lines must be a non-negative integer"
      fi
      ;;
    --out=*)
      out_path="${arg#--out=}"
      if [[ -z "$out_path" ]]; then
        die "--out requires a path"
      fi
      if [[ "$out_path" == "auto.tar.xz" ]]; then
        out_path="auto"
        compress_mode="tar.xz"
      fi
      ;;
    --compress=tar.xz)
      compress_mode="tar.xz"
      ;;
    --bundle|--bundle=receipt)
      bundle_mode=1
      ;;
    --include-binary=meta|--include-binary=raw|--include-binary=base64)
      include_binary="${arg#--include-binary=}"
      ;;
    --include-dir=*)
      d="$(normalize_path_token "${arg#--include-dir=}")"
      d="${d%/}"
      [[ -n "$d" ]] || die "--include-dir requires a value"
      include_dirs+=("$d")
      ;;
    --exclude-dir=*)
      d="$(normalize_path_token "${arg#--exclude-dir=}")"
      d="${d%/}"
      [[ -n "$d" ]] || die "--exclude-dir requires a value"
      exclude_dirs+=("$d")
      ;;
    --ignore-file=*)
      p="${arg#--ignore-file=}"
      [[ -n "$p" ]] || die "--ignore-file requires a value"
      ignore_patterns+=("$p")
      ;;
    --selection=*)
      selection_mode="${arg#--selection=}"
      if [[ -z "$selection_mode" ]]; then
        die "--selection requires a value"
      fi
      ;;
    --from-dp=*)
      from_dp="$(normalize_path_token "${arg#--from-dp=}")"
      if [[ -z "$from_dp" ]]; then
        die "--from-dp requires PATH or auto"
      fi
      ;;
    --include-file=*)
      p="$(normalize_path_token "${arg#--include-file=}")"
      [[ -n "$p" ]] || die "--include-file requires a path"
      include_files+=("$p")
      ;;
    --include-file-list=*)
      p="$(normalize_path_token "${arg#--include-file-list=}")"
      [[ -n "$p" ]] || die "--include-file-list requires a path"
      include_file_lists+=("$p")
      ;;
    --fail-on-forbidden-prefix=*)
      p="$(normalize_path_token "${arg#--fail-on-forbidden-prefix=}")"
      [[ -n "$p" ]] || die "--fail-on-forbidden-prefix requires a value"
      forbidden_prefixes+=("$p")
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $arg"
      ;;
  esac
done

if [[ "$selection_mode" != "scope" && "$selection_mode" != "dp" && "$selection_mode" != "dp+allowlist" ]]; then
  die "unknown --selection value: ${selection_mode}"
fi

if [[ "$scope" == "project" && -z "$target" ]]; then
  die "--scope=project requires --project=<slug>"
fi

if [[ "$scope" != "project" && -n "$target" ]]; then
  die "--project is only valid with --scope=project"
fi

if [[ -n "$target" && "$target" == */* ]]; then
  die "--project must be a project slug"
fi

if [[ -n "$out_path" && "$out_path" != "auto" && -z "$compress_mode" ]]; then
  case "$out_path" in
    *.tar.xz)
      compress_mode="tar.xz"
      ;;
  esac
fi

if [[ -n "$compress_mode" && -z "$out_path" ]]; then
  die "--compress requires --out"
fi

if [[ "$bundle_mode" -eq 1 && -n "$out_path" && -z "$compress_mode" ]]; then
  compress_mode="tar.xz"
fi

if [[ "$scope" == "full" && "$out_path" == "auto" && -z "$compress_mode" ]]; then
  compress_mode="tar.xz"
fi

if ! command -v git >/dev/null 2>&1; then
  die "git is required but was not found on PATH."
fi

if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
  die "git repo not found. Run from repo root."
fi
REPO_ROOT="$repo_root"

if [[ "$(pwd -P)" != "$repo_root" ]]; then
  die "Run from repo root: $repo_root"
fi

required_files=("PoT.md" "SoP.md" "TASK.md")
missing=()
for path in "${required_files[@]}"; do
  if [[ ! -f "$path" ]]; then
    missing+=("$path")
  fi
done
if (( ${#missing[@]} > 0 )); then
  die "expected files missing. Run from repo root: ${missing[*]}"
fi

missing=()
for dir in docs tools ops .github; do
  if [[ ! -d "$dir" ]]; then
    missing+=("$dir/")
  fi
done
if (( ${#missing[@]} > 0 )); then
  die "expected directories missing. Run from repo root: ${missing[*]}"
fi

trap 'emit_binary_leaf "dump" "finish"' EXIT
emit_binary_leaf "dump" "start"

mkdir -p "$repo_root/storage/handoff"
mkdir -p "$repo_root/storage/dumps"

remote_url="$(git remote get-url origin 2>/dev/null || true)"
if [[ -n "$remote_url" ]]; then
  repo_name="$(basename -s .git "$remote_url")"
else
  repo_name="$(basename "$repo_root")"
fi

branch="$(git rev-parse --abbrev-ref HEAD)"
head_short="$(git rev-parse --short HEAD)"
branch_safe="${branch//\//-}"
dump_base="dump-${scope}-${branch_safe}-${head_short}"
payload_path="$repo_root/storage/dumps/${dump_base}.txt"
manifest_path="$repo_root/storage/dumps/${dump_base}.manifest.txt"
manifest_alias_path=""
if [[ "$selection_mode" == "dp" || "$selection_mode" == "dp+allowlist" ]]; then
  manifest_alias_path="$repo_root/storage/dumps/${dump_base}_manifest.txt"
fi

format_label="$format"
case "$format" in
  chatgpt) format_label="ChatGPT" ;;
  gemini) format_label="Gemini" ;;
  claude) format_label="Claude" ;;
esac

resolve_task_source_path() {
  local task_path="${REPO_ROOT}/TASK.md"
  local line_count
  line_count="$(awk 'END { print NR }' "$task_path")"
  if [[ "$line_count" != "1" ]]; then
    printf '%s' "$task_path"
    return 0
  fi

  local pointer_path
  pointer_path="$(trim "$(normalize_path_token "$(cat "$task_path")")")"
  if [[ ! "$pointer_path" =~ ^archives/surfaces/[A-Za-z0-9._/-]+\.md$ ]]; then
    die "--from-dp=auto could not resolve active DP in TASK.md (invalid pointer format)"
  fi

  local resolved_path="${REPO_ROOT}/${pointer_path}"
  if [[ ! -f "$resolved_path" ]]; then
    die "--from-dp=auto could not resolve active DP in TASK.md (missing pointer target: ${pointer_path})"
  fi
  printf '%s' "$resolved_path"
}

extract_paths_from_dp_scoped_load_order() {
  local source_path="$1"

  if grep -Eq '^##[[:space:]]*3[.][[:space:]]*Current Dispatch Packet [(]DP[)][[:space:]]*$' "$source_path"; then
    awk '
      function emit_candidate(line, path) {
        path=""
        if (match(line, /^[[:space:]]*[0-9]+[.][[:space:]]*`([^`]+)`/, m)) {
          path=m[1]
        } else if (match(line, /^[[:space:]]*[0-9]+[.][[:space:]]*([A-Za-z0-9._\/-]+)/, m)) {
          path=m[1]
        }
        if (path != "") {
          print path
        }
      }
      BEGIN {
        in_section=0
        in_dp=0
        in_load_order=0
        saw_dp=0
      }
      /^##[[:space:]]*3[.][[:space:]]*Current Dispatch Packet [(]DP[)][[:space:]]*$/ {
        in_section=1
        next
      }
      in_section && /^##[[:space:]]*[0-9]+[.]/ && $0 !~ /^##[[:space:]]*3[.]/ {
        in_section=0
        in_dp=0
        in_load_order=0
      }
      in_section && /^### DP-[A-Z]+-[0-9]{4,}:[[:space:]]+/ {
        if (saw_dp == 0) {
          saw_dp=1
          in_dp=1
          next
        }
        if (in_dp == 1) {
          exit
        }
      }
      in_dp && /^### 3[.]2[.]2([.]|[[:space:]])/ {
        in_load_order=1
        next
      }
      in_load_order && /^##[[:space:]]*3[.]3([.]|[[:space:]])/ { exit }
      in_load_order && /^### 3[.]3([.]|[[:space:]])/ { exit }
      in_load_order { emit_candidate($0) }
      END {
        if (saw_dp == 0) {
          exit 2
        }
      }
    ' "$source_path"
    return $?
  fi

  awk '
    function emit_candidate(line, path) {
      path=""
      if (match(line, /^[[:space:]]*[0-9]+[.][[:space:]]*`([^`]+)`/, m)) {
        path=m[1]
      } else if (match(line, /^[[:space:]]*[0-9]+[.][[:space:]]*([A-Za-z0-9._\/-]+)/, m)) {
        path=m[1]
      }
      if (path != "") {
        print path
      }
    }
    BEGIN {
      in_load_order=0
      saw_load_order=0
    }
    /^### 3[.]2[.]2([.]|[[:space:]])/ {
      in_load_order=1
      saw_load_order=1
      next
    }
    in_load_order && /^##[[:space:]]*3[.]3([.]|[[:space:]])/ { exit }
    in_load_order && /^### 3[.]3([.]|[[:space:]])/ { exit }
    in_load_order { emit_candidate($0) }
    END {
      if (saw_load_order == 0) {
        exit 3
      }
    }
  ' "$source_path"
}

record_rejected_file() {
  local path="$1"
  local reason="$2"
  rejected_files+=("${path}|${reason}")
}

add_selected_file() {
  local raw_path="$1"
  local normalized_path
  normalized_path="$(normalize_path_token "$raw_path")"
  [[ -n "$normalized_path" ]] || return 0

  if [[ "$normalized_path" == /* ]]; then
    if [[ "$normalized_path" == "${REPO_ROOT}/"* ]]; then
      normalized_path="${normalized_path#${REPO_ROOT}/}"
    else
      record_rejected_file "$normalized_path" "outside-repo"
      return 0
    fi
  fi

  local prefix=""
  for prefix in "${active_forbidden_prefixes[@]}"; do
    [[ -n "$prefix" ]] || continue
    if [[ "$normalized_path" == "$prefix"* ]]; then
      record_rejected_file "$normalized_path" "forbidden-prefix:${prefix}"
      return 0
    fi
  done

  if [[ -n "${selected_file_set[$normalized_path]+set}" ]]; then
    return 0
  fi
  selected_file_set["$normalized_path"]=1
  files+=("$normalized_path")
}

load_include_file_list() {
  local list_path="$1"
  local resolved_list_path="$list_path"
  if [[ "$resolved_list_path" != /* ]]; then
    resolved_list_path="${REPO_ROOT}/${resolved_list_path}"
  fi
  if [[ ! -f "$resolved_list_path" ]]; then
    die "--include-file-list points to missing file: ${list_path}"
  fi

  local raw_line=""
  while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
    raw_line="${raw_line%$'\r'}"
    raw_line="$(trim "$raw_line")"
    [[ -n "$raw_line" ]] || continue
    if [[ "$raw_line" == \#* ]]; then
      continue
    fi
    add_selected_file "$raw_line"
  done < "$resolved_list_path"
}

files=()
rejected_files=()
selected_source_dp="none"
active_forbidden_prefixes=()
declare -A selected_file_set=()

if [[ "$selection_mode" == "scope" ]]; then
  traverse_args=("--scope=${scope}")
  if [[ -n "$target" ]]; then
    traverse_args+=("--project=${target}")
  fi
  for d in "${include_dirs[@]}"; do
    traverse_args+=("--include-dir=${d}")
  done
  for d in "${exclude_dirs[@]}"; do
    traverse_args+=("--exclude-dir=${d}")
  done
  for p in "${ignore_patterns[@]}"; do
    traverse_args+=("--ignore-file=${p}")
  done

  while IFS= read -r filepath; do
    [[ -n "$filepath" ]] || continue
    files+=("$filepath")
  done < <("${SCRIPT_DIR}/../lib/scripts/traverse.sh" "${traverse_args[@]}")
else
  canonical_baseline_files=(
    "PoT.md"
    "SoP.md"
    "PoW.md"
    "TASK.md"
    "docs/MAP.md"
    "docs/MANUAL.md"
    "ops/lib/manifests/CONTEXT.md"
  )
  active_forbidden_prefixes=(
    "opt/_factory/"
    "storage/handoff/OPEN-"
  )
  for prefix in "${forbidden_prefixes[@]}"; do
    active_forbidden_prefixes+=("$prefix")
  done

  for baseline_path in "${canonical_baseline_files[@]}"; do
    add_selected_file "$baseline_path"
  done

  if [[ -n "$from_dp" ]]; then
    dp_source_path="$from_dp"
    if [[ "$from_dp" == "auto" ]]; then
      dp_source_path="$(resolve_task_source_path)"
    elif [[ "$dp_source_path" != /* ]]; then
      dp_source_path="${REPO_ROOT}/${dp_source_path}"
    fi

    if [[ ! -f "$dp_source_path" ]]; then
      die "--from-dp points to missing file: ${from_dp}"
    fi

    selected_source_dp="$(normalize_path_token "$dp_source_path")"
    if [[ -z "$selected_source_dp" ]]; then
      selected_source_dp="$from_dp"
    fi

    if ! dp_scoped_paths="$(extract_paths_from_dp_scoped_load_order "$dp_source_path")"; then
      if [[ "$from_dp" == "auto" ]]; then
        die "--from-dp=auto could not resolve active DP in TASK.md"
      fi
      die "--from-dp file does not contain a parsable 3.2.2 DP-scoped load order: ${from_dp}"
    fi
    while IFS= read -r candidate_path; do
      [[ -n "$candidate_path" ]] || continue
      add_selected_file "$candidate_path"
    done <<< "$dp_scoped_paths"
  fi

  if [[ "$selection_mode" == "dp+allowlist" ]]; then
    for include_path in "${include_files[@]}"; do
      add_selected_file "$include_path"
    done
    for include_list_path in "${include_file_lists[@]}"; do
      load_include_file_list "$include_list_path"
    done
  fi
fi

if (( ${#files[@]} == 0 )); then
  if [[ "$selection_mode" == "scope" ]]; then
    die "No files selected for scope: $scope"
  fi
  die "No files selected for --selection=${selection_mode}"
fi

output_target=""
archive_path=""
if [[ -n "$out_path" ]]; then
  if [[ "$out_path" == "auto" ]]; then
    if [[ "$compress_mode" == "tar.xz" ]]; then
      output_target="$repo_root/storage/dumps/${dump_base}.tar.xz"
    else
      output_target="$payload_path"
    fi
  elif [[ "$out_path" = /* ]]; then
    output_target="$out_path"
  else
    output_target="$repo_root/$out_path"
  fi
fi
if [[ -z "$output_target" ]]; then
  archive_path="$repo_root/storage/dumps/${dump_base}.tar.xz"
elif [[ "$compress_mode" == "tar.xz" ]]; then
  archive_path="$output_target"
fi
mkdir -p "$(dirname "$payload_path")"
if [[ -n "$output_target" ]]; then
  mkdir -p "$(dirname "$output_target")"
fi

display_path() {
  local path="$1"
  if [[ -z "$path" ]]; then
    return 0
  fi
  if [[ "$path" == "$repo_root"/* ]]; then
    printf "./%s" "${path#"$repo_root"/}"
  else
    printf "%s" "$(basename "$path")"
  fi
}

content_snapshot_path() {
  local path="$1"
  if [[ "$path" == "storage/dp/active/allowlist.txt" && -f "$ALLOWLIST_BASELINE_PATH" ]]; then
    printf '%s' "$ALLOWLIST_BASELINE_PATH"
    return 0
  fi
  return 1
}

content_exists() {
  local path="$1"
  local snapshot_path=""
  if snapshot_path="$(content_snapshot_path "$path")"; then
    [[ -f "$snapshot_path" ]]
    return $?
  fi

  if [[ -f "${REPO_ROOT}/${path}" ]]; then
    return 0
  fi

  git cat-file -e "HEAD:$path" 2>/dev/null
}

stream_content() {
  local path="$1"
  local snapshot_path=""
  if snapshot_path="$(content_snapshot_path "$path")"; then
    cat "$snapshot_path"
    return 0
  fi

  if [[ -f "${REPO_ROOT}/${path}" ]]; then
    cat "${REPO_ROOT}/${path}"
    return 0
  fi

  git show "HEAD:$path"
}

count_content_lines() {
  local path="$1"
  stream_content "$path" | awk 'END { print NR }'
}

emit_file_contents() {
  local path="$1"
  local suppress_pipe_errors="$2"
  local max="$3"
  if ! content_exists "$path"; then
    echo "(missing file)"
    return 0
  fi
  if (( max > 0 )); then
    if [[ "$suppress_pipe_errors" -eq 1 ]]; then
      stream_content "$path" 2>/dev/null | awk -v max="$max" '{
        total++
        if (total <= max) {
          print
        }
      }
      END {
        if (total > max) {
          print "(...truncated at " max " lines; use --max-lines=0 for complete)"
        }
      }' 2>/dev/null || true
    else
      stream_content "$path" | awk -v max="$max" '{
        total++
        if (total <= max) {
          print
        }
      }
      END {
        if (total > max) {
          print "(...truncated at " max " lines; use --max-lines=0 for complete)"
        }
      }'
    fi
  else
    if [[ "$suppress_pipe_errors" -eq 1 ]]; then
      stream_content "$path" 2>/dev/null || true
    else
      stream_content "$path"
    fi
  fi
}

is_file_truncated() {
  local path="$1"
  local lines

  if ! content_exists "$path"; then
    return 1
  fi

  if (( max_lines > 0 )); then
    lines="$(count_content_lines "$path")"
    if (( lines > max_lines )); then
      return 0
    fi
  fi
  return 1
}

emit_dump() {
  local suppress_pipe_errors=0
  local files_count
  local truncated_files=0
  local binary_files=0

  if [[ -p /proc/$$/fd/1 ]]; then
    suppress_pipe_errors=1
    exec 2>/dev/null
  fi

  files_count=${#files[@]}
  for path in "${files[@]}"; do
    if is_file_truncated "$path"; then
      truncated_files=$((truncated_files + 1))
    fi
  done

  echo "===== REPO DUMP ====="
  echo "Dump generated by [System] at ./"
  echo "Repo: $repo_name"
  echo "Branch: $branch"
  echo "HEAD: $head_short"
  echo "Scope: $scope"
  if [[ "$scope" == "project" ]]; then
    echo "Target: $target"
  fi
  echo "Format: $format_label"
  echo "Files included: $files_count"
  echo "Binary files: $binary_files"
  echo "Truncated text files: $truncated_files"
  case "$scope" in
    core)     echo "Excluded dirs (scope): projects/ opt/_factory/" ;;
    platform) echo "Excluded dirs (scope): projects/" ;;
    factory)  echo "Excluded dirs (scope): (all except opt/_factory/)" ;;
    project)  echo "Excluded dirs (scope): projects/* (except projects/$target/)" ;;
    full)     echo "Excluded dirs (scope): none" ;;
  esac
  if (( ${#include_dirs[@]} > 0 )); then
    echo "Include dirs (refiner): ${include_dirs[*]}"
  else
    echo "Include dirs (refiner): (none)"
  fi
  if (( ${#exclude_dirs[@]} > 0 )); then
    echo "Exclude dirs (refiner): ${exclude_dirs[*]}"
  else
    echo "Exclude dirs (refiner): (none)"
  fi
  if (( ${#ignore_patterns[@]} > 0 )); then
    echo "Ignore globs (refiner): ${ignore_patterns[*]}"
  else
    echo "Ignore globs (refiner): (none)"
  fi
  echo "Binary handling: $include_binary"
  echo "Max lines (text): $max_lines"
  cat <<'ORIENTATION'
===== DUMP ORIENTATION BEGIN =====
What this file is:
  A Stela repo dump is a structured snapshot of the repository produced by ops/bin/dump.
  It is a session artifact: load it at the start of a session for full context; do not
  commit it, cite it as a canonical source, or reference it in DP content.

Structural zones:
  1. Header   — lines before [INDEX]: branch, HEAD, scope, format, and generation metadata.
  2. Index    — the [INDEX] block: a flat list of all files included in this dump.
  3. File-content blocks — each file delimited by:
       <<< FILE BEGIN: <path>
       <file content>
       >>> FILE END: <path>

Binary file representation (meta mode):
  Binary files are not inlined. Instead, a metadata block appears in place of file content,
  showing file type, size, and path. The raw bytes are excluded from the dump payload.

Integrator consumption guide:
  - Read the Header block to verify branch and HEAD match your session state.
  - Use the Index to navigate to specific files by path without scanning the full payload.
  - Treat each FILE BEGIN/END block as the canonical source for that file's current content.
  - Do not re-read the OPEN prompt from this dump; use the standalone OPEN artifact instead.
===== DUMP ORIENTATION END =====
ORIENTATION
  echo "===== DUMP PAYLOAD BEGIN ====="
  echo "[INDEX]"
  for path in "${files[@]}"; do
    echo "- $path"
  done
  echo ""
  echo "[FILE CONTENTS]"
  for path in "${files[@]}"; do
    echo "<<< FILE BEGIN: $path"
    emit_file_contents "$path" "$suppress_pipe_errors" "$max_lines"
    echo ">>> FILE END: $path"
    echo ""
  done
  echo "===== DUMP PAYLOAD END ====="
}

emit_manifest() {
  local path="$1"
  local payload="$2"
  local output="$3"
  local files_count="${#files[@]}"
  local rejected_entry=""
  local rejected_path=""
  local rejected_reason=""
  {
    echo "Dump Manifest"
    echo "Branch: $branch"
    echo "HEAD: $head_short"
    echo "Scope: $scope"
    if [[ "$scope" == "project" ]]; then
      echo "Target: $target"
    fi
    echo "Format: $format_label"
    echo "Binary handling: $include_binary"
    echo "Max lines (text): $max_lines"
    if (( ${#include_dirs[@]} > 0 )); then
      echo "Include dirs (refiner): ${include_dirs[*]}"
    fi
    if (( ${#exclude_dirs[@]} > 0 )); then
      echo "Exclude dirs (refiner): ${exclude_dirs[*]}"
    fi
    if (( ${#ignore_patterns[@]} > 0 )); then
      echo "Ignore globs (refiner): ${ignore_patterns[*]}"
    fi
    echo "Dump payload: $(display_path "$payload")"
    if [[ -n "$output" ]]; then
      echo "Output target: $(display_path "$output")"
    else
      echo "Output target: (stdout)"
    fi
    echo "Files included: $files_count"
    echo "Included files:"
    for p in "${files[@]}"; do
      echo "- $p"
    done
    if [[ "$selection_mode" == "dp" || "$selection_mode" == "dp+allowlist" ]]; then
      echo ""
      echo "[selection_provenance]"
      echo "selector_mode: ${selection_mode}"
      echo "source_dp: ${selected_source_dp}"
      echo "files_included_count: ${files_count}"
      echo "files_rejected_count: ${#rejected_files[@]}"
      echo "files_rejected:"
      if (( ${#rejected_files[@]} == 0 )); then
        echo "- path: none; reason: none"
      else
        for rejected_entry in "${rejected_files[@]}"; do
          rejected_path="${rejected_entry%%|*}"
          rejected_reason="${rejected_entry#*|}"
          echo "- path: ${rejected_path}; reason: ${rejected_reason}"
        done
      fi
    fi
  } > "$path"
}

sync_manifest_alias() {
  if [[ -z "$manifest_alias_path" ]]; then
    return 0
  fi
  cp "$manifest_path" "$manifest_alias_path"
}

emit_dump > "$payload_path"

manifest_output="$output_target"
if [[ -z "$manifest_output" && -n "$archive_path" ]]; then
  manifest_output="$archive_path"
fi

if [[ "$bundle_mode" -eq 1 ]]; then
  emit_manifest "$manifest_path" "$payload_path" "$manifest_output"
  sync_manifest_alias
fi

if [[ -z "$output_target" ]]; then
  cat "$payload_path"
fi

if [[ -n "$archive_path" ]]; then
  if ! command -v tar >/dev/null 2>&1; then
    die "tar is required for dump archive output but was not found on PATH."
  fi
  tar_items=()
  tar_items+=("$(basename "$payload_path")")
  if [[ "$bundle_mode" -eq 1 ]]; then
    tar_items+=("$(basename "$manifest_path")")
  fi
  tar -cJf "$archive_path" -C "$(dirname "$payload_path")" "${tar_items[@]}"
elif [[ -n "$output_target" && "$output_target" != "$payload_path" ]]; then
  cp "$payload_path" "$output_target"
fi

if [[ "$bundle_mode" -eq 0 ]]; then
  emit_manifest "$manifest_path" "$payload_path" "$manifest_output"
  sync_manifest_alias
fi

if [[ -n "$out_path" ]]; then
  reported_manifest_path="$manifest_path"
  if [[ -n "$manifest_alias_path" ]]; then
    reported_manifest_path="$manifest_alias_path"
  fi
  echo "Dump payload: $(display_path "$payload_path")"
  if [[ -n "$archive_path" ]]; then
    echo "Dump tarball: $(display_path "$archive_path")"
  fi
  echo "Dump manifest: $(display_path "$reported_manifest_path")"
fi
