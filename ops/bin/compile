#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
# shellcheck source=/dev/null
source "${REPO_ROOT}/ops/lib/scripts/common.sh"
# shellcheck source=/dev/null
source "${REPO_ROOT}/ops/lib/scripts/project.sh"

TEMPLATE_DIR="ops/src/manifests"
OUTPUT_DIR="ops/lib/manifests"
ARCHIVE_MANIFESTS_DIR="archives/manifests"
COMPILE_PACKET_DEFAULT="OPS-COMPILE"

declare -A TRACKED_FILES=()
declare -A COMPILE_SEEN_FILES=()
declare -A COMPILE_SEEN_MANIFESTS=()
declare -a COMPILE_RESOLVED_PATHS=()

usage() {
  cat <<'USAGE'
Usage: ops/bin/compile

Compiles manifest templates from ops/src/manifests/*.md.tpl into
explicit manifests under ops/lib/manifests/*.md.
Each successful compile also emits a schema-stamped snapshot leaf in
archives/manifests/ before runtime manifests are updated.
USAGE
}

has_glob() {
  local value="$1"
  [[ "$value" == *"*"* || "$value" == *"?"* || "$value" == *"["* ]]
}

load_tracked_files() {
  local tracked
  while IFS= read -r tracked; do
    [[ -z "$tracked" ]] && continue
    TRACKED_FILES["$tracked"]=1
  done < <(git -C "${PROJECT_REPO_ROOT}" ls-files | LC_ALL=C sort)
}

require_template_file() {
  local template_rel="$1"
  local template_clean
  template_clean="$(trim "$template_rel")"
  template_clean="${template_clean#./}"

  if [[ -z "$template_clean" ]]; then
    project_die "template path is required"
  fi

  if [[ ! -f "${PROJECT_REPO_ROOT}/${template_clean}" ]]; then
    project_die "template not found: ${template_clean}"
  fi

  printf '%s' "$template_clean"
}

require_tracked_file_entry() {
  local entry="$1"
  local clean
  clean="$(trim "$entry")"
  clean="${clean#./}"

  if [[ -z "$clean" ]]; then
    project_die "template entry is empty"
  fi

  if [[ ! -f "${PROJECT_REPO_ROOT}/${clean}" ]]; then
    if [[ -z "${TRACKED_FILES[$clean]:-}" ]]; then
      project_die "template entry is not tracked and missing: ${clean}"
    fi
    project_die "template entry missing file: ${clean}"
  fi

  printf '%s\n' "$clean"
}

expand_glob_entry() {
  local pattern="$1"
  local clean
  clean="$(trim "$pattern")"
  clean="${clean#./}"

  local -a matches=()
  mapfile -t matches < <(git -C "${PROJECT_REPO_ROOT}" ls-files "$clean" | LC_ALL=C sort)

  if (( ${#matches[@]} == 0 )); then
    project_die "template glob matched no tracked files: ${clean}"
  fi

  local had_file=0
  local match
  for match in "${matches[@]}"; do
    if [[ -f "${PROJECT_REPO_ROOT}/${match}" ]]; then
      had_file=1
      printf '%s\n' "$match"
    fi
  done

  if (( had_file == 0 )); then
    project_die "template glob matched no files: ${clean}"
  fi
}

add_compiled_path() {
  local rel="$1"
  if [[ -z "${COMPILE_SEEN_FILES[$rel]:-}" ]]; then
    COMPILE_SEEN_FILES["$rel"]=1
    COMPILE_RESOLVED_PATHS+=("$rel")
  fi
}

resolve_template_recursive() {
  local template_rel="$1"
  local normalized
  normalized="$(require_template_file "$template_rel")"

  if [[ -n "${COMPILE_SEEN_MANIFESTS[$normalized]:-}" ]]; then
    return 0
  fi
  COMPILE_SEEN_MANIFESTS["$normalized"]=1

  local -a entries=()
  mapfile -t entries < <(awk -F'`' 'NF >= 3 { for (i = 2; i <= NF; i += 2) print $i }' "${PROJECT_REPO_ROOT}/${normalized}")

  local entry
  for entry in "${entries[@]}"; do
    entry="$(trim "$entry")"
    [[ -z "$entry" ]] && continue

    if [[ "$entry" == @manifest:* ]]; then
      local include_rel="${entry#@manifest:}"
      include_rel="${include_rel#./}"
      resolve_template_recursive "$include_rel"
      continue
    fi

    if has_glob "$entry"; then
      local expanded
      while IFS= read -r expanded; do
        [[ -z "$expanded" ]] && continue
        add_compiled_path "$expanded"
      done < <(expand_glob_entry "$entry")
      continue
    fi

    local single
    while IFS= read -r single; do
      [[ -z "$single" ]] && continue
      add_compiled_path "$single"
    done < <(require_tracked_file_entry "$entry")
  done
}

resolve_template_members() {
  local template_rel="$1"

  COMPILE_RESOLVED_PATHS=()
  unset COMPILE_SEEN_FILES COMPILE_SEEN_MANIFESTS
  declare -gA COMPILE_SEEN_FILES=()
  declare -gA COMPILE_SEEN_MANIFESTS=()

  resolve_template_recursive "$template_rel"

  if (( ${#COMPILE_RESOLVED_PATHS[@]} == 0 )); then
    project_die "template resolved to no files: ${template_rel}"
  fi

  printf '%s\n' "${COMPILE_RESOLVED_PATHS[@]}" | LC_ALL=C sort -u
}

render_compiled_manifest() {
  local template_rel="$1"
  local output_rel="$2"
  local output_base_dir="$3"
  shift 3
  local members=("$@")

  local title
  title="$(basename "$output_rel")"
  title="${title%.md}"

  local output_abs="${output_base_dir}/${output_rel}"
  local tmp_file
  tmp_file="$(mktemp)"

  {
    echo "# ${title} Manifest"
    echo
    echo "<!-- GENERATED FILE. DO NOT EDIT. -->"
    echo "<!-- Source template: ${template_rel} -->"
    echo "<!-- Generator: ops/bin/compile -->"
    echo
    echo "## Members"
    local member
    for member in "${members[@]}"; do
      printf -- '- `%s`\n' "$member"
    done
  } > "$tmp_file"

  mkdir -p "$(dirname "$output_abs")"
  mv "$tmp_file" "$output_abs"
}

generate_trace_id() {
  local stamp
  local suffix
  stamp="$(date -u '+%Y%m%dT%H%M%SZ')"
  suffix="$(printf '%04x%04x' "$RANDOM" "$RANDOM")"
  printf 'stela-%s-%s' "$stamp" "$suffix"
}

resolve_trace_id() {
  local trace_id="${STELA_TRACE_ID:-}"
  if [[ -z "$trace_id" ]]; then
    trace_id="$(generate_trace_id)"
  fi
  printf '%s' "$trace_id"
}

resolve_packet_id() {
  local packet_id="${STELA_PACKET_ID:-}"
  if [[ -z "$packet_id" ]]; then
    packet_id="$COMPILE_PACKET_DEFAULT"
  fi
  printf '%s' "$packet_id"
}

created_at_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

filename_stamp_utc() {
  date -u +"%Y-%m-%dT%H%M%S"
}

git_short_head() {
  git -C "$PROJECT_REPO_ROOT" rev-parse --short HEAD
}

is_manifest_snapshot_candidate() {
  local filename="$1"
  [[ "$filename" =~ ^compile-[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{6}-[0-9a-f]{7,}\.md$ ]]
}

resolve_previous_manifest_leaf() {
  local manifests_abs="$1"
  local -a candidates=()
  local path
  mapfile -t candidates < <(find "$manifests_abs" -maxdepth 1 -type f -name 'compile-*.md' -printf '%P\n' | LC_ALL=C sort)

  local -a filtered=()
  for path in "${candidates[@]}"; do
    if is_manifest_snapshot_candidate "$path"; then
      filtered+=("$path")
    fi
  done

  if (( ${#filtered[@]} == 0 )); then
    printf '(none)'
    return 0
  fi

  local latest_index=$(( ${#filtered[@]} - 1 ))
  printf '%s/%s' "$ARCHIVE_MANIFESTS_DIR" "${filtered[$latest_index]}"
}

resolve_leaf_rel_path() {
  local manifests_abs="$1"
  local git_short="$2"

  local stamp
  local leaf_name
  local leaf_abs
  local attempts=0

  while true; do
    stamp="$(filename_stamp_utc)"
    leaf_name="compile-${stamp}-${git_short}.md"
    leaf_abs="${manifests_abs}/${leaf_name}"

    if [[ ! -e "$leaf_abs" ]]; then
      printf '%s/%s' "$ARCHIVE_MANIFESTS_DIR" "$leaf_name"
      return 0
    fi

    attempts=$((attempts + 1))
    if (( attempts >= 5 )); then
      project_die "manifest snapshot leaf already exists after retry window: ${ARCHIVE_MANIFESTS_DIR}/${leaf_name}"
    fi
    sleep 1
  done
}

emit_manifest_snapshot_leaf() {
  local manifests_abs="$1"
  local compile_tmp_root="$2"
  local trace_id="$3"
  local packet_id="$4"
  local created_at="$5"
  local previous="$6"
  local leaf_rel_path="$7"

  local leaf_abs_path="${PROJECT_REPO_ROOT}/${leaf_rel_path}"
  local tmp_leaf
  tmp_leaf="$(mktemp)"

  {
    printf -- '---\n'
    printf 'trace_id: %s\n' "$trace_id"
    printf 'packet_id: %s\n' "$packet_id"
    printf 'created_at: %s\n' "$created_at"
    printf 'previous: %s\n' "$previous"
    printf -- '---\n'
    printf '# Compile Manifest Snapshot\n\n'
    printf -- '- leaf: %s\n' "$leaf_rel_path"
    printf -- '- source: ops/bin/compile\n'
    printf -- '- output_dir: %s\n\n' "$OUTPUT_DIR"

    local manifest_rel
    for manifest_rel in \
      "${OUTPUT_DIR}/CORE.md" \
      "${OUTPUT_DIR}/OPS.md" \
      "${OUTPUT_DIR}/DISCOVERY.md" \
      "${OUTPUT_DIR}/CONTEXT.md"; do
      local manifest_abs="${compile_tmp_root}/${manifest_rel}"
      [[ -f "$manifest_abs" ]] || project_die "compiled manifest missing during snapshot assembly: ${manifest_rel}"

      printf '## %s\n\n' "$manifest_rel"
      printf '```markdown\n'
      cat "$manifest_abs"
      printf '\n```\n\n'
    done
  } > "$tmp_leaf"

  mkdir -p "$manifests_abs"
  mv "$tmp_leaf" "$leaf_abs_path"
}

promote_compiled_manifests() {
  local compile_tmp_root="$1"

  mkdir -p "${PROJECT_REPO_ROOT}/${OUTPUT_DIR}"

  local -a compiled_paths=()
  local compiled_path
  mapfile -t compiled_paths < <(find "${compile_tmp_root}/${OUTPUT_DIR}" -maxdepth 1 -type f -name '*.md' -printf '%P\n' | LC_ALL=C sort)
  if (( ${#compiled_paths[@]} == 0 )); then
    project_die "no compiled manifests found in temporary output"
  fi

  for compiled_path in "${compiled_paths[@]}"; do
    mv "${compile_tmp_root}/${OUTPUT_DIR}/${compiled_path}" "${PROJECT_REPO_ROOT}/${OUTPUT_DIR}/${compiled_path}"
  done
}

main() {
  for arg in "$@"; do
    case "$arg" in
      -h|--help)
        usage
        exit 0
        ;;
      *)
        project_die "Unknown arg: ${arg}"
        ;;
    esac
  done

  project_require_repo_root
  emit_binary_leaf "compile" "start"

  if [[ ! -d "${PROJECT_REPO_ROOT}/${TEMPLATE_DIR}" ]]; then
    project_die "missing template dir: ${TEMPLATE_DIR}"
  fi

  local manifests_abs="${PROJECT_REPO_ROOT}/${ARCHIVE_MANIFESTS_DIR}"
  mkdir -p "$manifests_abs"

  load_tracked_files

  local -a templates=()
  mapfile -t templates < <(find "${PROJECT_REPO_ROOT}/${TEMPLATE_DIR}" -maxdepth 1 -type f -name '*.md.tpl' -printf '%P\n' | LC_ALL=C sort)
  if (( ${#templates[@]} == 0 )); then
    project_die "no manifest templates found in ${TEMPLATE_DIR}"
  fi

  mkdir -p "${PROJECT_REPO_ROOT}/var/tmp"
  local compile_tmp_root=""
  compile_tmp_root="$(mktemp -d "${PROJECT_REPO_ROOT}/var/tmp/compile.XXXXXX")"

  cleanup() {
    emit_binary_leaf "compile" "finish"
    local tmp_root="${compile_tmp_root:-}"
    if [[ -n "$tmp_root" && -d "$tmp_root" ]]; then
      rm -rf "$tmp_root"
    fi
  }
  trap cleanup EXIT

  local template_file
  for template_file in "${templates[@]}"; do
    local template_rel="${TEMPLATE_DIR}/${template_file}"
    local output_name="${template_file%.tpl}"
    if [[ "$output_name" == *.md ]]; then
      local output_stem="${output_name%.md}"
      output_name="$(printf '%s.md' "$(printf '%s' "$output_stem" | tr '[:lower:]' '[:upper:]')")"
    else
      output_name="$(printf '%s' "$output_name" | tr '[:lower:]' '[:upper:]')"
    fi
    local output_rel="${OUTPUT_DIR}/${output_name}"

    local -a members=()
    mapfile -t members < <(resolve_template_members "$template_rel")
    render_compiled_manifest "$template_rel" "$output_rel" "$compile_tmp_root" "${members[@]}"
  done

  local trace_id
  trace_id="$(resolve_trace_id)"
  local packet_id
  packet_id="$(resolve_packet_id)"
  local created_at
  created_at="$(created_at_utc)"
  local previous
  previous="$(resolve_previous_manifest_leaf "$manifests_abs")"
  local git_short
  git_short="$(git_short_head)"
  local leaf_rel_path
  leaf_rel_path="$(resolve_leaf_rel_path "$manifests_abs" "$git_short")"

  emit_manifest_snapshot_leaf \
    "$manifests_abs" \
    "$compile_tmp_root" \
    "$trace_id" \
    "$packet_id" \
    "$created_at" \
    "$previous" \
    "$leaf_rel_path"

  promote_compiled_manifests "$compile_tmp_root"

  printf 'MANIFEST_LEAF: %s\n' "$leaf_rel_path"
}

main "$@"
