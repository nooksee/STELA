#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
# shellcheck source=/dev/null
source "${REPO_ROOT}/ops/lib/scripts/common.sh"

MODE="${1:-}"
[ -z "$MODE" ] && die "template: template type argument is required"

if [[ "$MODE" == "render" ]]; then
  TEMPLATE_TYPE="${2:-}"
  [ -z "$TEMPLATE_TYPE" ] && die "template: template type argument is required"
else
  TEMPLATE_TYPE="$MODE"
fi

trap 'emit_binary_leaf "template" "finish"' EXIT
emit_binary_leaf "template" "start"

case "$TEMPLATE_TYPE" in
  agent|task|skill)
    "${SCRIPT_DIR}/factory" "$@"
    ;;
  dp|results|task-surface|spec|addendum|closing|stance-analyst|stance-architect|stance-auditor|stance-audit|stance-foreman|stance-authority|stance-conformist)
    "${SCRIPT_DIR}/manifest" "$@"
    ;;
  *)
    die "template: unknown template type '${TEMPLATE_TYPE}'"
    ;;
esac
