#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

usage() {
  cat <<'USAGE'
Usage:
  ops/bin/template render <dp|results|task-surface|agent|task|skill> --out=PATH [options]

Options:
  --slots-file=PATH          Load [TOKEN] blocks from a slots file.
  --slot=TOKEN=VALUE         Set/override a slot value (repeatable).
  --id=DP-OPS-XXXX           Convenience mapping for DP_ID.
  --title=...                Convenience mapping for DP_TITLE.
  --base-branch=...          Convenience mapping for BASE_BRANCH.
  --work-branch=...          Convenience mapping for WORK_BRANCH.
  --base-head=...            Convenience mapping for BASE_HEAD.
  --freshness-stamp=...      Convenience mapping for FRESHNESS_STAMP.
  --non-strict               Allow unresolved {{TOKEN}} placeholders.
  --strict                   Enforce strict mode (default).
  --out=-                    Write rendered output to stdout.
USAGE
}

die() {
  echo "ERROR: $*" >&2
  exit 1
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

slugify_heading() {
  local value="$1"
  value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')"
  value="$(printf '%s' "$value" | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"
  printf '%s' "$value"
}

is_nonempty_block() {
  local value="$1"
  [[ -n "$(printf '%s\n' "$value" | sed '/^[[:space:]]*$/d')" ]]
}

declare -A TEMPLATE_PATHS=(
  [dp]="ops/src/surfaces/dp.md.tpl"
  [results]="ops/src/surfaces/results.md.tpl"
  [task-surface]="ops/src/surfaces/task.md.tpl"
  [agent]="ops/src/definitions/agent.md.tpl"
  [task]="ops/src/definitions/task.md.tpl"
  [skill]="ops/src/definitions/skill.md.tpl"
)

declare -A SLOT_VALUES=()
declare -A META_SCALARS=()
declare -a META_REQUIRES_SLOTS=()
declare -a META_INCLUDES=()
declare -a SLOT_PAIRS=()

strict_mode=1
slots_file=""
out_path=""
command=""
render_key=""

template_path=""

set_slot_value() {
  local token="$1"
  local value="$2"

  if [[ ! "$token" =~ ^[A-Z0-9_]+$ ]]; then
    die "invalid slot token '${token}' (expected [A-Z0-9_]+)"
  fi

  SLOT_VALUES["$token"]="$value"
}

load_slots_file() {
  local file_path="$1"
  local current_key=""
  local buffer=""
  local line=""

  [[ -f "$file_path" ]] || die "slots file not found: ${file_path}"

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^\[[A-Z0-9_]+\][[:space:]]*$ ]]; then
      local token
      token="${line#[}"
      token="${token%%]*}"
      if [[ -n "$current_key" ]]; then
        while [[ "$buffer" == *$'\n' ]]; do
          buffer="${buffer%$'\n'}"
        done
        set_slot_value "$current_key" "$buffer"
      fi
      current_key="$token"
      buffer=""
      continue
    fi

    if [[ -n "$current_key" ]]; then
      buffer+="$line"$'\n'
    fi
  done < "$file_path"

  if [[ -n "$current_key" ]]; then
    while [[ "$buffer" == *$'\n' ]]; do
      buffer="${buffer%$'\n'}"
    done
    set_slot_value "$current_key" "$buffer"
  fi
}

parse_frontmatter() {
  local source_path="$1"
  local meta_out="$2"
  local body_out="$3"

  : > "$meta_out"
  : > "$body_out"

  awk -v meta_out="$meta_out" -v body_out="$body_out" '
    BEGIN {
      in_meta=0
      has_frontmatter=0
    }
    NR==1 {
      if ($0 == "---") {
        in_meta=1
        has_frontmatter=1
        next
      }
    }
    {
      if (in_meta) {
        if ($0 == "---") {
          in_meta=0
          next
        }
        print >> meta_out
        next
      }
      print >> body_out
    }
    END {
      if (in_meta) {
        exit 2
      }
    }
  ' "$source_path" || {
    local status=$?
    if [[ "$status" -eq 2 ]]; then
      die "unclosed YAML frontmatter in ${source_path}"
    fi
    die "failed to parse frontmatter from ${source_path}"
  }
}

parse_metadata() {
  local meta_path="$1"
  local line=""
  local current_list_key=""

  META_SCALARS=()
  META_REQUIRES_SLOTS=()
  META_INCLUDES=()

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^[[:space:]]*# ]] || [[ -z "$(trim "$line")" ]]; then
      continue
    fi

    if [[ "$line" =~ ^([a-zA-Z0-9_]+):[[:space:]]*(.*)$ ]]; then
      local key="${BASH_REMATCH[1]}"
      local value="$(trim "${BASH_REMATCH[2]}")"
      META_SCALARS["$key"]="$value"

      if [[ -z "$value" ]]; then
        current_list_key="$key"
      else
        current_list_key=""
      fi
      continue
    fi

    if [[ "$line" =~ ^[[:space:]]*-[[:space:]]*(.+)$ ]] && [[ -n "$current_list_key" ]]; then
      local item="$(trim "${BASH_REMATCH[1]}")"
      case "$current_list_key" in
        requires_slots)
          META_REQUIRES_SLOTS+=("$item")
          ;;
        includes)
          META_INCLUDES+=("$item")
          ;;
      esac
      continue
    fi
  done < "$meta_path"
}

resolve_template_path() {
  local key="$1"
  local rel_path="${TEMPLATE_PATHS[$key]:-}"

  [[ -n "$rel_path" ]] || die "unknown template key '${key}'"
  template_path="${REPO_ROOT}/${rel_path}"
  [[ -f "$template_path" ]] || die "template not found for '${key}': ${rel_path}"
}

resolve_include_path() {
  local include_path="$1"
  local current_file="$2"
  local candidate=""

  if [[ "$include_path" == /* ]]; then
    candidate="$include_path"
  else
    local current_dir
    current_dir="$(cd "$(dirname "$current_file")" && pwd)"

    if [[ -f "${current_dir}/${include_path}" ]]; then
      candidate="${current_dir}/${include_path}"
    else
      candidate="${REPO_ROOT}/${include_path}"
    fi
  fi

  [[ -f "$candidate" ]] || die "include target missing: ${include_path} (from ${current_file})"

  local resolved_dir
  resolved_dir="$(cd "$(dirname "$candidate")" && pwd)"
  printf '%s/%s' "$resolved_dir" "$(basename "$candidate")"
}

extract_section_from_file() {
  local source_path="$1"
  local section_anchor="$2"
  local out_path="$3"

  local normalized
  normalized="$(slugify_heading "${section_anchor#\#}")"
  [[ -n "$normalized" ]] || die "invalid include section anchor '${section_anchor}' in ${source_path}"

  awk -v anchor="$normalized" '
    function slugify(value, tmp) {
      tmp=tolower(value)
      gsub(/[^a-z0-9]+/, "-", tmp)
      gsub(/^-+/, "", tmp)
      gsub(/-+$/, "", tmp)
      return tmp
    }
    BEGIN {
      found=0
      capture=0
      base_level=0
    }
    {
      if (match($0, /^(#{1,6})[[:space:]]+(.*)$/, parts)) {
        level=length(parts[1])
        heading=parts[2]
        heading_slug=slugify(heading)

        if (!found) {
          if (heading_slug == anchor || index(heading_slug, anchor) == 1 || index(anchor, heading_slug) == 1) {
            found=1
            capture=1
            base_level=level
          }
        } else if (capture && level <= base_level) {
          exit
        }
      }

      if (capture) {
        print
      }
    }
    END {
      if (!found) {
        exit 2
      }
    }
  ' "$source_path" > "$out_path" || {
    local status=$?
    if [[ "$status" -eq 2 ]]; then
      die "include section not found: ${source_path}#${section_anchor}"
    fi
    die "failed to extract section from include: ${source_path}#${section_anchor}"
  }
}

stack_contains() {
  local stack="$1"
  local descriptor="$2"

  case "|${stack}|" in
    *"|${descriptor}|"*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

split_include_ref() {
  local raw_ref="$1"
  local path_part
  local section_part=""

  path_part="$raw_ref"
  if [[ "$raw_ref" == *"#"* ]]; then
    path_part="${raw_ref%%#*}"
    section_part="${raw_ref#*#}"
  fi

  path_part="$(trim "$path_part")"
  section_part="$(trim "$section_part")"

  [[ -n "$path_part" ]] || die "invalid include directive '${raw_ref}'"

  INCLUDE_PATH_PART="$path_part"
  INCLUDE_SECTION_PART="$section_part"
}

expand_include_directives() {
  local text="$1"
  local current_file="$2"
  local stack="$3"

  local tmp_input
  tmp_input="$(mktemp)"
  printf '%s' "$text" > "$tmp_input"

  local output=""
  local line=""

  while IFS= read -r line || [[ -n "$line" ]]; do
    local rendered_line="$line"

    while [[ "$rendered_line" =~ \{\{@include:([^}]+)\}\} ]]; do
      local directive="${BASH_REMATCH[0]}"
      local include_ref="${BASH_REMATCH[1]}"

      split_include_ref "$include_ref"

      local resolved_include
      resolved_include="$(resolve_include_path "$INCLUDE_PATH_PART" "$current_file")"

      local descriptor="${resolved_include}#${INCLUDE_SECTION_PART}"
      if stack_contains "$stack" "$descriptor"; then
        rm -f "$tmp_input"
        die "circular include detected: ${descriptor}"
      fi

      local include_content
      include_content="$(render_file_body "$resolved_include" "$INCLUDE_SECTION_PART" "${stack}|${descriptor}")"

      local prefix="${rendered_line%%"$directive"*}"
      local suffix="${rendered_line#*"$directive"}"
      rendered_line="${prefix}${include_content}${suffix}"
    done

    output+="${rendered_line}"$'\n'
  done < "$tmp_input"

  rm -f "$tmp_input"
  printf '%s' "$output"
}

render_file_body() {
  local source_path="$1"
  local section_anchor="$2"
  local stack="$3"

  local tmp_meta
  local tmp_body
  tmp_meta="$(mktemp)"
  tmp_body="$(mktemp)"

  parse_frontmatter "$source_path" "$tmp_meta" "$tmp_body"

  local source_block="$tmp_body"
  local tmp_section=""
  if [[ -n "$section_anchor" ]]; then
    tmp_section="$(mktemp)"
    extract_section_from_file "$tmp_body" "$section_anchor" "$tmp_section"
    source_block="$tmp_section"
  fi

  local raw_text
  raw_text="$(cat "$source_block")"

  local expanded
  expanded="$(expand_include_directives "$raw_text" "$source_path" "$stack")"

  rm -f "$tmp_meta" "$tmp_body"
  if [[ -n "$tmp_section" ]]; then
    rm -f "$tmp_section"
  fi

  printf '%s' "$expanded"
}

validate_metadata_includes() {
  local root_template="$1"
  local stack="$2"
  local include_ref

  for include_ref in "${META_INCLUDES[@]}"; do
    split_include_ref "$include_ref"

    local resolved_include
    resolved_include="$(resolve_include_path "$INCLUDE_PATH_PART" "$root_template")"

    local descriptor="${resolved_include}#${INCLUDE_SECTION_PART}"
    if stack_contains "$stack" "$descriptor"; then
      die "circular include detected in metadata includes: ${descriptor}"
    fi

    render_file_body "$resolved_include" "$INCLUDE_SECTION_PART" "${stack}|${descriptor}" >/dev/null
  done
}

apply_slots() {
  local input_text="$1"
  local output_text="$input_text"
  local token

  for token in "${!SLOT_VALUES[@]}"; do
    output_text="${output_text//\{\{${token}\}\}/${SLOT_VALUES[$token]}}"
  done

  printf '%s' "$output_text"
}

validate_required_slots() {
  local required
  for required in "${META_REQUIRES_SLOTS[@]}"; do
    if [[ -z "${SLOT_VALUES[$required]+set}" ]]; then
      die "missing required slot: ${required}"
    fi
    if ! is_nonempty_block "${SLOT_VALUES[$required]}"; then
      die "required slot '${required}' is empty"
    fi
  done
}

check_unresolved_placeholders() {
  local rendered_text="$1"

  if grep -qE '\{\{@include:[^}]+\}\}' <<< "$rendered_text"; then
    die "unresolved include directive remains after rendering"
  fi

  if (( strict_mode )); then
    local unresolved
    unresolved="$(grep -oE '\{\{[A-Z0-9_]+\}\}' <<< "$rendered_text" | sort -u || true)"
    if [[ -n "$unresolved" ]]; then
      local inline_unresolved
      inline_unresolved="$(printf '%s' "$unresolved" | tr '\n' ' ')"
      inline_unresolved="$(trim "$inline_unresolved")"
      die "unresolved template token(s): ${inline_unresolved}"
    fi
  fi
}

parse_args() {
  if [[ "$#" -lt 3 ]]; then
    usage >&2
    exit 1
  fi

  command="$1"
  render_key="$2"
  shift 2

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --out=*)
        out_path="${1#--out=}"
        shift
        ;;
      --out)
        [[ "$#" -ge 2 ]] || die "--out requires a value"
        out_path="$2"
        shift 2
        ;;
      --slots-file=*)
        slots_file="${1#--slots-file=}"
        shift
        ;;
      --slots-file)
        [[ "$#" -ge 2 ]] || die "--slots-file requires a value"
        slots_file="$2"
        shift 2
        ;;
      --slot=*)
        SLOT_PAIRS+=("${1#--slot=}")
        shift
        ;;
      --slot)
        [[ "$#" -ge 2 ]] || die "--slot requires TOKEN=VALUE"
        SLOT_PAIRS+=("$2")
        shift 2
        ;;
      --id=*)
        set_slot_value "DP_ID" "${1#--id=}"
        shift
        ;;
      --title=*)
        set_slot_value "DP_TITLE" "${1#--title=}"
        shift
        ;;
      --base-branch=*)
        set_slot_value "BASE_BRANCH" "${1#--base-branch=}"
        shift
        ;;
      --work-branch=*)
        set_slot_value "WORK_BRANCH" "${1#--work-branch=}"
        shift
        ;;
      --base-head=*)
        set_slot_value "BASE_HEAD" "${1#--base-head=}"
        shift
        ;;
      --freshness-stamp=*)
        set_slot_value "FRESHNESS_STAMP" "${1#--freshness-stamp=}"
        shift
        ;;
      --non-strict)
        strict_mode=0
        shift
        ;;
      --strict)
        strict_mode=1
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown arg: $1"
        ;;
    esac
  done

  [[ "$command" == "render" ]] || die "unknown command '${command}'"
  [[ -n "$out_path" ]] || die "--out is required"
}

apply_slot_pairs() {
  local pair
  for pair in "${SLOT_PAIRS[@]}"; do
    if [[ "$pair" != *=* ]]; then
      die "invalid --slot value '${pair}' (expected TOKEN=VALUE)"
    fi

    local token="${pair%%=*}"
    local value="${pair#*=}"
    set_slot_value "$token" "$value"
  done
}

write_output() {
  local content="$1"

  if [[ "$out_path" == "-" ]]; then
    printf '%s' "$content"
    return 0
  fi

  mkdir -p "$(dirname "$out_path")"
  printf '%s' "$content" > "$out_path"
}

main() {
  parse_args "$@"
  resolve_template_path "$render_key"

  if [[ -n "$slots_file" ]]; then
    load_slots_file "$slots_file"
  fi
  apply_slot_pairs

  local tmp_meta
  local tmp_body
  tmp_meta="$(mktemp)"
  tmp_body="$(mktemp)"

  parse_frontmatter "$template_path" "$tmp_meta" "$tmp_body"
  parse_metadata "$tmp_meta"

  local root_descriptor="${template_path}#"
  validate_metadata_includes "$template_path" "$root_descriptor"

  if (( strict_mode )); then
    validate_required_slots
  fi

  local base_body
  base_body="$(cat "$tmp_body")"
  local expanded_body
  expanded_body="$(expand_include_directives "$base_body" "$template_path" "$root_descriptor")"

  local rendered
  rendered="$(apply_slots "$expanded_body")"

  check_unresolved_placeholders "$rendered"
  write_output "$rendered"

  rm -f "$tmp_meta" "$tmp_body"
}

main "$@"
