#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/../lib/scripts/common.sh"

MODE="${1:-}"
[ -z "$MODE" ] && die "template: template type argument is required"

if [[ "$MODE" == "render" ]]; then
  TEMPLATE_TYPE="${2:-}"
  [ -z "$TEMPLATE_TYPE" ] && die "template: template type argument is required"
else
  TEMPLATE_TYPE="$MODE"
fi

case "$TEMPLATE_TYPE" in
  agent|task|skill)
    exec "${SCRIPT_DIR}/factory" "$@"
    ;;
  dp|results|task-surface)
    exec "${SCRIPT_DIR}/manifest" "$@"
    ;;
  *)
    die "template: unknown template type '${TEMPLATE_TYPE}'"
    ;;
esac
